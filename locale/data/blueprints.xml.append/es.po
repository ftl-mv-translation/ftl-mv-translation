"data/blueprints.xml.append$//augBlueprint[@name=\"NANOBOT_DEFENSE_SYSTEM\"]/title"
msgstr "Dispersion de Bots Asesinos"

#: src-en/data/blueprints.xml.append:13017
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"NANOBOT_DEFENSE_SYSTEM\"]/desc"
