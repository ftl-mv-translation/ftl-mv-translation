#: src-en/data/blueprints.xml.append:11469
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"CURA_SURGES_DRONES\"]/title"
msgstr "Controlador de Sobrecarga"

#: src-en/data/blueprints.xml.append:11470
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"CURA_SURGES_DRONES\"]/desc"
