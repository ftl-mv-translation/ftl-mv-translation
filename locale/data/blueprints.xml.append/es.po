msgstr "Mod. Prec."

#: src-en/data/blueprints.xml.append:36439
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"MODULE_ACCURACY\"]/desc"
msgstr ""
"Modulo de Atributo de Precision de Hektar Industries(TM). Asegura que tus armas alcancen siempre su objetivo en el campo de batalla!\n"
"\tIncompatible con el Rayo Modular\n"
"\tEfectos para Laseres/Iones: +20% de precision\n"
"\tEfectos para Misiles: +100% de precision"

#: src-en/data/blueprints.xml.append:36461
msgid "data/blueprints.xml.append$//weaponBlueprint[@name=\"MODULE_FIRE\"]/title"
