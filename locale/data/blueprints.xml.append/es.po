#: src-en/data/blueprints.xml.append:13034
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SYSTEM_CASING\"]/title"
msgstr "Revestimiento de Titanio para Sistemas"

#: src-en/data/blueprints.xml.append:13035
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SYSTEM_CASING\"]/desc"
msgstr "Todos los sistemas de la nave tienen blindaje adicional que proporciona un 15% de probabilidad de anular daño al ser impactados (POR CIERTO, NUNCA DEBERIAS VER ESTO)"

#: src-en/data/blueprints.xml.append:13043
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"SYSTEM_CASING_NEW\"]/title"
msgstr "Rev. de Titanio Sistemas"

#: src-en/data/blueprints.xml.append:13044
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"SYSTEM_CASING_NEW\"]/desc"
msgstr "Con el Revestimiento de Titanio para Sistemas, los invasores enemigos sabotean tus sistemas al 40% de velocidad. Tambien proporciona un 15% de probabilidad de resistir daño a tus sistemas."

#: src-en/data/blueprints.xml.append:13052
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"LOCKED_SYSTEM_CASING\"]/title"
msgstr "Rev. de Titanio Sistemas"

#: src-en/data/blueprints.xml.append:13053
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"LOCKED_SYSTEM_CASING\"]/desc"
msgstr "Los invasores enemigos sabotean tus sistemas al 40% de velocidad. Tambien proporciona un 15% de probabilidad de resistir daño a tus sistemas."

#: src-en/data/blueprints.xml.append:13080
msgid ""
"data/blueprints.xml.append$/FTL/FTL[6]/FTL[5]/FTL[2]/augBlueprint[@name=\"ADV_SCANNERS\"]/title"
msgstr "Escaner Largo Alcance"

#: src-en/data/blueprints.xml.append:13081
msgid ""
"data/blueprints.xml.append$/FTL/FTL[6]/FTL[5]/FTL[2]/augBlueprint[@name=\"ADV_SCANNERS\"]/desc"
msgstr "Aporta información adicional sobre las balizas proximas del mapa estelar."

#: src-en/data/blueprints.xml.append:13089
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"RECYCLER\"]/title"
msgstr "Modulo Reciclador"

#: src-en/data/blueprints.xml.append:13090
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"RECYCLER\"]/desc"
msgstr "Un modulo reciclador similar al utilizado en las armas con tecnologia Recicladora. Puede usarse para convertir combustible, chatarra, piezas de dron o simplemente objetos aleatorios en misiles."

#: src-en/data/blueprints.xml.append:13097
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"RECYCLER_REVERSE\"]/title"
msgstr "Deconstructor"

#: src-en/data/blueprints.xml.append:13098
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"RECYCLER_REVERSE\"]/desc"
msgstr "Un componente especial que permite desmontar misiles o piezas de dron en chatarra, aunque con un rendimiento muy reducido."

#: src-en/data/blueprints.xml.append:13105
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"GHOST_DUPLICATOR\"]/title"
msgstr "Divisor Rapido TM"

#: src-en/data/blueprints.xml.append:13106
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"GHOST_DUPLICATOR\"]/desc"
msgstr "La tecnologia patentada de DUPLICACION GHOST te permite inflar rapidamente Ghosts de cualquier tipo y luego forzarlos a dividirse como si fueran un Alpha. Es indoloro, lo prometemos."

#: src-en/data/blueprints.xml.append:13113
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"STORE_BEACON\"]/title"
msgstr "Baliza del Mercader"

#: src-en/data/blueprints.xml.append:13114
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"STORE_BEACON\"]/desc"
msgstr "Puede invocar una tienda en cualquier baliza vacia a cambio de aumentar la flota en 1."

#: src-en/data/blueprints.xml.append:13121
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"DISTRACTION_BUOY\"]/title"
msgstr "Boyas de Señuelo"

#: src-en/data/blueprints.xml.append:13122
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"DISTRACTION_BUOY\"]/desc"
msgstr "Permite desplegar boyas durante la velocidad de salto. Puede otorgar 1 retraso de flota gratis o desplegar boyas adicionales usando piezas de dron."

#: src-en/data/blueprints.xml.append:13130
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"PRE_SCANNER\"]/title"
msgstr "Escaner de deriva"

#: src-en/data/blueprints.xml.append:13131
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"PRE_SCANNER\"]/desc"
msgstr "Puede usarse para cartografiar el siguiente sector mientras estas en velocidad de salto a cambio de 3 de combustible."

#: src-en/data/blueprints.xml.append:13139
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"FUEL_CONSERVER\"]/title"
msgstr "Conservador de Combustible"

#: src-en/data/blueprints.xml.append:13140
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"FUEL_CONSERVER\"]/desc"
msgstr "Dispositivo de conservacion de combustible hiper eficiente combinado con algo de jerga cientifica que genera hasta 5 unidades de combustible al entrar en un nuevo sector mediante velocidad de salto."

#: src-en/data/blueprints.xml.append:13148
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"PDS_DISABLE\"]/title"
msgstr "Diluidor de Señal"

#: src-en/data/blueprints.xml.append:13149
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"PDS_DISABLE\"]/desc"
msgstr ""
"Un modulo que inhibe las señales de socorro y otras transmisiones. Puede usarse para evitar que los guardias soliciten apoyo ASB o para desactivar satelites de ataque enemigos.\n"
"\t\n"
"\tProporciona utiles opciones azules durante eventos relevantes."

#: src-en/data/blueprints.xml.append:13158
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"ANTI_VIRUS\"]/title"
msgstr "Modulo Antivirus"

#: src-en/data/blueprints.xml.append:13159
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"ANTI_VIRUS\"]/desc"
msgstr ""
"Mejora de combate que puede neutralizar los sistemas de Hackeo enemigos. Tambien funciona bien contra virus maliciosos de satelites enemigos u otras fuentes.\n"
"\t[Usa 2 de energia, dura 30 segundos]\n"
"\t\n"
"\tProporciona utiles opciones azules durante eventos relevantes."

#: src-en/data/blueprints.xml.append:13169
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FLARE_DISTRACTION\"]/title"
msgstr "Bengalas de Distraccion"

#: src-en/data/blueprints.xml.append:13170
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"FLARE_DISTRACTION\"]/desc"
msgstr ""
"Un suministro autoregenerable de bengalas holograficas que sirven como excelentes distracciones en situaciones donde enemigos o satelites estan cerca pero aun no han fijado objetivo en tu nave. Util para infiltrarse en lugares o escapar de enemigos.\n"
"\t\n"
"\tProporciona utiles opciones azules durante eventos relevantes."

#: src-en/data/blueprints.xml.append:13179
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CREW_FIREARMS\"]/title"
msgstr "Armerias Mejoradas"

#: src-en/data/blueprints.xml.append:13180
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CREW_FIREARMS\"]/desc"
msgstr "Equipa a tu tripulacion con armas de fuego superiores, aumentando en un 30% el daño en combate a distancia entre tripulantes."

#: src-en/data/blueprints.xml.append:13187
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SPEED_SUITS\"]/title"
msgstr "Exotrajes"

#: src-en/data/blueprints.xml.append:13188
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"SPEED_SUITS\"]/desc"
msgstr "Aumenta la Salud Maxima de tu tripulacion en un 10%, y su velocidad de movimiento y curacion en un 20%."

#: src-en/data/blueprints.xml.append:13196
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CREW_OXYGEN\"]/title"
msgstr "Ventilacion Avanzada"

#: src-en/data/blueprints.xml.append:13197
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CREW_OXYGEN\"]/desc"
msgstr "El Soporte Vital ahora prioriza a tu tripulacion, reponiendo oxigeno un 65% mas rapido en habitaciones donde haya tripulantes. Requiere que el sistema tenga energia y mejora con mas energia."

#: src-en/data/blueprints.xml.append:13211
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CRATE_SCRAP\"]/title"
msgstr "Caja de Chatarra"

#: src-en/data/blueprints.xml.append:13212
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CRATE_SCRAP\"]/desc"
msgstr "Puede abrirse en el almacenamiento. Puede contener entre 30 y 45 de chatarra."

#: src-en/data/blueprints.xml.append:13218
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"CRATE_SCRAP_HUGE\"]/title"
msgstr "Caja Grande de Chatarra"

#: src-en/data/blueprints.xml.append:13219
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CRATE_SCRAP_HUGE\"]/desc"
msgstr "Puede abrirse en el almacenamiento. Contiene 175 chatarra."

#: src-en/data/blueprints.xml.append:13225
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CRATE_FUEL\"]/title"
msgstr "Caja de Combustible"

#: src-en/data/blueprints.xml.append:13226
msgid "data/blueprints.xml.append$//augBlueprint[@name=\"CRATE_FUEL\"]/desc"
msgstr "Puede abrirse en el almacenamiento. Puede contener entre 5 y 10 de combustible."

#: src-en/data/blueprints.xml.append:13232
