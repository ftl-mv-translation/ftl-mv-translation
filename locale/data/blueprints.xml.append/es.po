"data/blueprints.xml.append$//augBlueprint[@name=\"ANCIENT_COMBAT_EQUALIZER\"]/desc"
msgstr "Mejora de combate ancestral que limita un sistema tanto en la nave enemiga como en la del jugador a 0 o 1 barra, dependiendo del sistema. El jugador debe tener el sistema que sera afectado."

#: src-en/data/blueprints.xml.append:12751
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"ANCIENT_COMBAT_ASB\"]/title"
msgstr "Plataforma ASB Antiguo"

#: src-en/data/blueprints.xml.append:12752
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"ANCIENT_COMBAT_ASB\"]/desc"
