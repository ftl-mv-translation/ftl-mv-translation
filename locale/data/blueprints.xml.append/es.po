#: src-en/data/blueprints.xml.append:12743
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"ANCIENT_COMBAT_EQUALIZER\"]/title"
msgstr "Ecualizador Ancestral"

#: src-en/data/blueprints.xml.append:12744
