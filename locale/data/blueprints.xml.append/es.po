#: src-en/data/blueprints.xml.append:13025
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"LOCKED_NANOBOT_DEFENSE_SYSTEM\"]/title"
msgstr "Dispersion de Bots Asesinos"

#: src-en/data/blueprints.xml.append:13026
msgid ""
"data/blueprints.xml.append$//augBlueprint[@name=\"LOCKED_NANOBOT_DEFENSE_SYSTEM\"]/desc"
