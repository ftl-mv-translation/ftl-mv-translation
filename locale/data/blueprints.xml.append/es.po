msgid "data/blueprints.xml.append$//systemBlueprint[@name=\"pilot\"]/title"
msgstr "Pilotaje"

#: src-en/data/blueprints.xml.append:7654
msgid "data/blueprints.xml.append$//systemBlueprint[@name=\"pilot\"]/desc"
msgstr "Permite que la nave realice saltos FTL y esquive cuando esta pilotada. Mejorarlo añade piloto automatico, lo que permite cierta evasion incluso sin piloto."

