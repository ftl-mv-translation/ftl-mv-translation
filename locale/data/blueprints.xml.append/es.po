#: src-en/data/blueprints.xml.append:36337
msgid ""
"data/blueprints.xml.append$//weaponBlueprint[@name=\"MODULE_COOLDOWN\"]/desc"
msgstr ""
"Modulo de Estado de Recarga de Hektar Industries(TM). Convierte tus armas modulares en armamento de asalto eficiente y de disparo rapido!\n"
"\tSin incompatibilidades.\n"
"\tEfectos para todas las armas: Reduce el tiempo de recarga en un 25%"

