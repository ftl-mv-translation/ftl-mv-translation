#: src-en/data/events_sector_kleptocracy.xml:2901
msgid ""
"data/events_sector_kleptocracy.xml$//event[@name=\"NEBULA_LIGHT_DISTRESS_SLOCKNOG_START\"]/choice[@req=\"pilot\"]/event/text"
msgstr "Sabes que es mejor no caer en una posible trampa en el espacio Slug."

#: src-en/data/events_sector_kleptocracy.xml:2903
