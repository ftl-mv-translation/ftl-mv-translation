msgid ""
"data/events_sector_kleptocracy.xml$//textList[@name=\"NEBULA_SLUG_FIGHT\"]/text[5]"
msgstr "A los Slugs no les gustan los ataques directos, pero, de las tres naves que ves en esta baliza, una de ellas maniobra hacia tu posición!"

#: src-en/data/events_sector_kleptocracy.xml:2593
msgid ""
"data/events_sector_kleptocracy.xml$/FTL/event[@name=\"NEBULA_ENCOUNTER_SLUG_STORM\"]/choice/text"
