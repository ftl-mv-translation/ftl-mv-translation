msgid ""
"data/events_sector_kleptocracy.xml$//event[@name=\"DISTRESS_REFUGEE_SLUG_MV\"]/text"
msgstr "Has encontrado una nave de refugiados vagando por el espacio. Parece como si estuviese huyendo de los rebeles y se hubiese quedado sin combustible. La baliza de socorro está activa, pero dudas que haya alguien a bordo."

#: src-en/data/events_sector_kleptocracy.xml:116
msgid ""
"data/events_sector_kleptocracy.xml$//event[@name=\"DISTRESS_REFUGEE_SLUG_MV\"]/choice[1]/text"
