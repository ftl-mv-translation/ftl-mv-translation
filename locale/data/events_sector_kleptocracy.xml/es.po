#: src-en/data/events_sector_kleptocracy.xml:61
msgid ""
"data/events_sector_kleptocracy.xml$//event[@name=\"ENCOUNTER_SLUG_CLEARING\"]/text"
msgstr "Es raro que los Slugs se pasen mucho tiempo expuestas en espacio abierto. Puede que la nave se haya perdido o que tan solo pase por aquí. En cualquier caso, ¡se dispone a atacarte!"

#: src-en/data/events_sector_kleptocracy.xml:64
msgid ""
"data/events_sector_kleptocracy.xml$//event[@name=\"ENCOUNTER_SLUG_CLEARING\"]/choice/text"
