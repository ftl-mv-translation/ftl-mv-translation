msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE\"]/choice/event/choice[2]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_sector_knight.xml:1783
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_SLOCKNOG\"]/text"
msgstr "Cuando la Black Raven se estrella en el lago, la lucha parece detenerse repentinamente. Aterrizas tu nave junto al Crucero Clairvoyant, donde Slocknog sonríe y estrecha tu mano. \"Por supuessto podría haberlo hecho yo ssolo, pero... graciass, capitán. Esta esss la segunda vez que haces un esfuerzo por ayudarme. Que las esstrellasss brillen más entre nosotrosss, eh amigo?\""

#: src-en/data/events_sector_knight.xml:1786
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_SLOCKNOG\"]/choice[1]/text"
