#: src-en/data/events_sector_knight.xml:1238
msgid ""
"data/events_sector_knight.xml$//eventList[@name=\"KNIGHT_SHAKESPEARE_GUESS\"]/event[2]/text"
msgstr "Aunque tu intento de replicar el habla del Slug es patético, no parecen particularmente ofendidos. Riendo enormemente de ti, te invitan a bordo de su nave y, sorprendentemente, ofrecen algunas reparaciones y suministros."

#: src-en/data/events_sector_knight.xml:1245
