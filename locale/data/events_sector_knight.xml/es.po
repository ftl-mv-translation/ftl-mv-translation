#: src-en/data/events_sector_knight.xml:2032
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_NIGHTS\"]/choice/event/choice/event/choice/event/choice[2]/event/choice[2]/text"
msgstr "Ejecutarlo."

#: src-en/data/events_sector_knight.xml:2034
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_NIGHTS\"]/choice/event/choice/event/choice/event/choice[2]/event/choice[2]/event/text"
msgstr "Nights abandona de inmediato cualquier muestra de valentía y grita aterrorizado, pero ya es demasiado tarde. La multitud no puede ser convencida de lo contrario, ahora que la idea ha sido reforzada por tu palabra. Mientras Nights es arrastrado hacia alguna prisión subterránea, los ciudadanos Slug te agradecen y te recompensan por la gran ayuda brindada."
