msgstr "Un Knigh Carcelero pasa volando, solo para lanzarte un insulto. \"Lárgate Federación, no te involucresss si no quieresss un agujero en el cráneo!\""

#: src-en/data/events_sector_knight.xml:1249
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_JAILER\"]/choice[1]/text"
