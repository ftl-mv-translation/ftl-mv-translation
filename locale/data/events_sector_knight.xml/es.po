msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_AMPERE_HOPEFUL\"]/choice[3]/text"
msgstr "Vas a necesitar una nave Slug si quieres pasar."

#: src-en/data/events_sector_knight.xml:557
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_AMPERE_HOPEFUL\"]/choice[3]/event/text"
msgstr "\"...Ups! No puedo creer que olvidara eso. Uhhh... Supongo que haré que mis chicos me dejen en algún lugar y viajaré como pueda. Gracias por el consejo.\" Te entrega amablemente una cantidad decente de chatarra."

