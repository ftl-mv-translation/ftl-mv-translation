#: src-en/data/events_sector_knight.xml:1903
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_THEFT\"]/choice/event/text"
msgstr "Tu tripulación sale tranquilamente de los restos, con la corona sobre su cabeza para que todos la vean. Te asombra ver cómo todos los Slugs alrededor, incluido Slocknog, se inclinan dispuestos a aceptar este giro de los acontecimientos..."

#: src-en/data/events_sector_knight.xml:1905
