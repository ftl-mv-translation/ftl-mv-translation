#: src-en/data/events_sector_knight.xml:1407
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_DISTRESS_KNIGHT_SHELLSPY\"]/choice[1]/event/text"
msgstr "\"Oh buen capitán de la Federación, por favor ayude! Estamos aquí en una misión para la Geniocracy para observar las operaciones Slug, pero nuestro comandante fue tomado como rehén! Podría rastrear la nave que se lo llevó y traerlo de vuelta?\""

#: src-en/data/events_sector_knight.xml:1409
msgid ""
