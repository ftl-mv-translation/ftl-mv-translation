"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_PROTESTERS\"]/choice[1]/event/text"
msgstr "El Saboteador te guía a una pequeña luna con una colonia Slug donde varios Slugs están protestando, liderados por una nave Clairvoyant rebelde. Elimina a su líder, y el resto probablemente se callará."

#: src-en/data/events_sector_knight.xml:1127
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_PROTESTERS\"]/choice[1]/event/choice[1]/text"
