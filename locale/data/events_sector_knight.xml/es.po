#: src-en/data/events_sector_knight.xml:1605
msgid "data/events_sector_knight.xml$//event[@name=\"KNIGHT_CLAN\"]/text"
msgstr "Una nave Clan ha hecho una parada cercana. No estás seguro de por qué están aquí tan lejos de las nebulosas donde las naves cazan la corona."

#: src-en/data/events_sector_knight.xml:1608
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_CLAN\"]/choice[1]/text"
