#: src-en/data/events_sector_knight.xml:1668
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_CLAN\"]/choice[2]/event/text"
msgstr "Aprovechas esta oportunidad para atacar a los Clansmen mientras están distraídos."

