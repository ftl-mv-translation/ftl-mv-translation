#: src-en/data/events_sector_knight.xml:550
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_AMPERE_HOPEFUL\"]/choice[2]/event/text"
msgstr "\"Lo tengo todo resuelto!\" Abre su disfraz y te muestra que la cabeza está aislada con papel de aluminio. \"...ya verás! Todo saldrá bien.\" Sacudes la cabeza. \"Ah, lo que sea. Toma esto y lárgate de aquí.\" Te entrega algo de combustible."

