#: src-en/data/events_sector_knight.xml:589
msgid "data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/text"
msgstr "No es muy común ver naves Clairvoyant por aquí, pero has visto muchas menos de las que esperabas en esta nebulosa llena de Slugs. Parece que finalmente te has encontrado con una, y aún no están disparando. En cambio, parece que quieren comunicarse."

#: src-en/data/events_sector_knight.xml:593
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/text"
msgstr "Responder."

#: src-en/data/events_sector_knight.xml:595
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/text"
msgstr "\"Si nuestros datoss son correctos, podría ser cierto que eres la nave de la que todos están hablando? La que nos ha devuelto a Ssslocknog, nuestro gran rey?\""

#: src-en/data/events_sector_knight.xml:597
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/text"
msgstr "Sí."

#: src-en/data/events_sector_knight.xml:599
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Fasssscinante. Ahora me pregunto, creesss que Sssslocknog es el mejor rey para la Kleptocracia? O prefieres a Nightsss y su... forma más radical de guiarnosss?\""

#: src-en/data/events_sector_knight.xml:601
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/choice[1]/text"
msgstr "Slocknog es el verdadero rey."

#: src-en/data/events_sector_knight.xml:603
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/choice[1]/event/text"
msgstr "\"Interesssante. Y qué te hace decir essso?\""

#: src-en/data/events_sector_knight.xml:605
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/choice[1]/event/choice[1]/text"
msgstr "Mantiene las cosas tradicionales. No hay necesidad de cambiar lo que funciona."

#: src-en/data/events_sector_knight.xml:607
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/choice[1]/event/choice[1]/event/text"
msgstr "\"Sssi, no está roto, no lo arreglesss... Bien entoncesss, no puedo agradecerte lo ssuficiente por sssalvar a nuestro rey. Acepta esto como humilde pago.\""

#: src-en/data/events_sector_knight.xml:612
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/choice[1]/event/choice[2]/text"
msgstr "Su nombre tiene muchas S."

#: src-en/data/events_sector_knight.xml:614
msgid ""
"data/events_sector_knight.xml$//event[@name=\"NEBULA_KNIGHT_QUIZ\"]/choice[1]/event/choice[1]/event/choice[1]/event/choice[2]/event/text"
msgstr "\"No creo que entiendass lo que definesss un buen rasgo en un rey. Tal vez no sseass la mejor persssona para involucrarte en nuestra política...\" Asumes que ese es el final, pero de repente la nave Clarividente ataca! Los Slugs realmente no deben apreciar tu intervención..."

