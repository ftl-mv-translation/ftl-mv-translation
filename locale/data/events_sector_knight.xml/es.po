"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_SLOCKNOG\"]/choice[@req=\"loc_got_clancrown\"]/text"
msgstr "Ir tras la corona tú mismo."

#: src-en/data/events_sector_knight.xml:1792
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_SLOCKNOG\"]/choice[@req=\"loc_got_clancrown\"]/event/text"
msgstr "Mientras observas cómo sacan la nave del lago, recuerdas a los Clansmen de antes y sientes el impulso de recuperar la corona para ti, aunque no será fácil. Asumiendo que todavía estén contigo, claro."

#: src-en/data/events_sector_knight.xml:1794
msgid ""
"data/events_sector_knight.xml$//event[@name=\"KNIGHT_PALACE_RESOLUTION_SLOCKNOG\"]/choice[@req=\"loc_got_clancrown\"]/event/choice[@req=\"slug_ranger\"]/text"
msgstr "Tu Clansman está vivo, vamos por ella."

#: src-en/data/events_sector_knight.xml:1796
