msgstr "(Módulo de Reciclaje) Entrégales el aumento."

#: src-en/data/events_sector_lostsun.xml:193
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[@req=\"RECYCLER\"]/event/text"
msgstr "\"Tecnología interesante. He oído hablar de ella, sí, pero nuestro presupuesto es bajo. Esto nos ayudará considerablemente. Gracias, capitán.\""

#: src-en/data/events_sector_lostsun.xml:196
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[@req=\"RECYCLER\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_lostsun.xml:198
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[@req=\"RECYCLER\"]/event/choice/event/text"
msgstr "Los Lost Suns compensan tu tecnología con parte de la suya, además de algo de chatarra."

#: src-en/data/events_sector_lostsun.xml:206
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[4]/text"
