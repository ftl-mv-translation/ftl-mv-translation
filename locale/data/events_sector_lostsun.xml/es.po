#: src-en/data/events_sector_lostsun.xml:1025
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"QUEST_LOSTSUN_ESCORT\"]/text"
msgstr "Al llegar a la baliza, descubres que ya hay una nave aquí, un Lost Sun muy pobremente armado. Te contactan. \"Bien, por fin alguien llegó. Nuestra baliza de socorro falló y no estábamos seguros de que alguien 'amigable' llegara a tiempo. Nuestra nave se quedó sin municiones, y tuvimos que cambiar a armas más débiles. Lamentablemente, eso también significa que no podemos protegernos de los cazadores de la Theocracy y la Coalition. Te pedimos que nos escoltes hasta el puesto avanzado más cercano.\""

#: src-en/data/events_sector_lostsun.xml:1027
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"QUEST_LOSTSUN_ESCORT\"]/choice[1]/text"
msgstr "Aceptar escoltarlos."

#: src-en/data/events_sector_lostsun.xml:1029
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"QUEST_LOSTSUN_ESCORT\"]/choice[1]/event/text"
msgstr "\"Tu disposición para ayudarnos ha sido registrada. Te seguiremos hasta estas coordenadas.\""

#: src-en/data/events_sector_lostsun.xml:1034
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"QUEST_LOSTSUN_ESCORT\"]/choice[2]/text"
msgstr "Rechazar su solicitud."

#: src-en/data/events_sector_lostsun.xml:1036
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"QUEST_LOSTSUN_ESCORT\"]/choice[2]/event/text"
msgstr "\"Entonces, lo que he oído sobre la Federación es cierto? Debí haberlo esperado. Vete, abandona este lugar y espera no caer víctima de los mismos enemigos ante los que nosotros estamos indefensos.\""

#: src-en/data/events_sector_lostsun.xml:1038
msgid ""
