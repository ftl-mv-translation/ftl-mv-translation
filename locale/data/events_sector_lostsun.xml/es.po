#: src-en/data/events_sector_lostsun.xml:113
msgid "data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_CACHE\"]/text"
msgstr "Un pitido constante en tu radar indica un objeto extraño flotando en el espacio vacío. Parece ser… un depósito de armas Lost Sun?"

#: src-en/data/events_sector_lostsun.xml:115
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_CACHE\"]/choice[1]/text"
msgstr "Abrirlo."

#: src-en/data/events_sector_lostsun.xml:119
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_CACHE\"]/choice[2]/text"
msgstr "No arriesgarse."

#: src-en/data/events_sector_lostsun.xml:121
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_CACHE\"]/choice[2]/event/text"
msgstr "Robar suministros militares en territorio Lost Sun no parece buena idea. Lo dejas pasar."

#: src-en/data/events_sector_lostsun.xml:123
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_CACHE\"]/choice[2]/event/choice[1]/text"
