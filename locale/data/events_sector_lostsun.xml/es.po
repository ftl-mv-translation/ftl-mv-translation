#: src-en/data/events_sector_lostsun.xml:135
msgid ""
"data/events_sector_lostsun.xml$//eventList[@name=\"LOSTSUN_CACHE_OPEN\"]/event[1]/text"
msgstr "Haces un forcejeo a la apertura del depósito y encuentras filas y filas de municiones."

#: src-en/data/events_sector_lostsun.xml:139
msgid ""
"data/events_sector_lostsun.xml$//eventList[@name=\"LOSTSUN_CACHE_OPEN\"]/event[2]/text"
msgstr "El depósito está lleno principalmente de suministros médicos y raciones. Sin embargo, encuentras un arma de fuego, la oveja negra de los suministros."

#: src-en/data/events_sector_lostsun.xml:143
msgid ""
"data/events_sector_lostsun.xml$//eventList[@name=\"LOSTSUN_CACHE_OPEN\"]/event[3]/text"
msgstr "El depósito es más difícil de abrir de lo esperado. Pasas un tiempo intentando abrirlo cuando una nave de Lost Sun te detecta ¡y ataca! Abandonas el depósito y te preparas para pelear."

#: src-en/data/events_sector_lostsun.xml:146
msgid ""
"data/events_sector_lostsun.xml$//eventList[@name=\"LOSTSUN_CACHE_OPEN\"]/event[3]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_lostsun.xml:153
msgid "data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/text"
msgstr "Una flota Lost Sun parece proteger la luna cercana, que alberga una operación minera relativamente grande. Al inspeccionar más de cerca, parece que la flota está pobremente armada."

#: src-en/data/events_sector_lostsun.xml:155
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/text"
msgstr "Contactarlos."

#: src-en/data/events_sector_lostsun.xml:157
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/text"
msgstr "“Una nave de la Federación, en nuestro sector? Eres otro transportista de suministros?” Niegas con la cabeza. “Hmm. Normalmente no solicito ayuda a desconocidos que pueden o no ser bienvenidos, pero necesitamos municiones. Tienen alguno que puedan compartir?”"

#: src-en/data/events_sector_lostsun.xml:159
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[1]/text"
msgstr "Darles algunos misiles."

#: src-en/data/events_sector_lostsun.xml:161
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Veo que no estás siendo tacaño con tus suministros. Aun así, no era mi lugar de preguntar. Algo es mejor que nada...\""

#: src-en/data/events_sector_lostsun.xml:166
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_lostsun.xml:168
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[1]/event/choice/event/text"
msgstr "A regañadientes, el capitán Lost Sun te entrega algo de chatarra como pago."

#: src-en/data/events_sector_lostsun.xml:175
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[2]/text"
msgstr "Darles muchos misiles."

#: src-en/data/events_sector_lostsun.xml:177
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[2]/event/text"
msgstr "\"Este es un suministro considerable. Me sorprendes, capitán de la Federación. Supongo que ahora estoy en deuda contigo.\""

#: src-en/data/events_sector_lostsun.xml:182
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_lostsun.xml:184
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_DONATION\"]/choice[1]/event/choice[2]/event/choice/event/text"
msgstr "Agradecidos por tu gran donación, los Lost Suns te recompensan con abundante chatarra."

