#: src-en/data/events_sector_lostsun.xml:69
msgid "data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/text"
msgstr "Un grupo de naves Lost Sun parece estar demoliendo un santuario Crystalline cercano. Te envían una transmisión preguntando si puedes proporcionarles explosivos."

#: src-en/data/events_sector_lostsun.xml:71
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[1]/text"
msgstr "Préstales algunos misiles."

#: src-en/data/events_sector_lostsun.xml:73
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[1]/event/text"
msgstr "\"No esperábamos una nave de suministros tan pronto, y esto puede ayudar.\" Disparan un cohete directamente a los cimientos de la estructura, haciendo que todo se derrumbe. \"Sorprendente. Hace mucho tiempo que no tenemos acceso a municiones de calidad como estas. Podemos quedarnos con los repuestos?\""

#: src-en/data/events_sector_lostsun.xml:78
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[1]/event/choice[1]/text"
msgstr "Déjalos quedarse con los misiles."

#: src-en/data/events_sector_lostsun.xml:80
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Su buena voluntad ha sido registrada. Permítanos recompensarle, capitán.\""

#: src-en/data/events_sector_lostsun.xml:86
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[1]/event/choice[2]/text"
msgstr "Solicitar que devuelvan los repuestos."

#: src-en/data/events_sector_lostsun.xml:88
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[1]/event/choice[2]/event/text"
msgstr "\"Está bien, pero no piensen que olvidaremos esto. Podrán pensar que estos vienen con facilidad, pero no es así.\""

#: src-en/data/events_sector_lostsun.xml:97
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[2]/text"
msgstr "Disculparse y rechazar su oferta."

#: src-en/data/events_sector_lostsun.xml:99
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[2]/event/text"
msgstr "Los Lost Suns no intentan comunicarse contigo nuevamente. Te alejas un poco de ellos solo por precaución."

#: src-en/data/events_sector_lostsun.xml:101
msgid ""
"data/events_sector_lostsun.xml$//event[@name=\"LOSTSUN_SHRINE\"]/choice[2]/event/choice[1]/text"
