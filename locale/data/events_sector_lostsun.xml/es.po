"data/events_sector_lostsun.xml$//event[@name=\"QUEST_LOSTSUN_DISRUPTION_QUEST\"]/choice[@req=\"hacking\"]/text"
msgstr "(Hackeo) Apagar los sistemas de la estación."

#: src-en/data/events_sector_lostsun.xml:946
