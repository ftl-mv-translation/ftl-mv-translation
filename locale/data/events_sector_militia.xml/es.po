#: src-en/data/events_sector_militia.xml:142
msgid "data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/text"
msgstr "A lo lejos hay un planeta densamente poblado bajo control de la Milicia, con abundante tráfico de ida y vuelta. Probablemente puedas encontrar un mercado en la superficie."

#: src-en/data/events_sector_militia.xml:145
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/text"
msgstr "Aterrizar."

#: src-en/data/events_sector_militia.xml:147
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/text"
msgstr "A los pocos minutos de aterrizar en la superficie del planeta, te ves rodeado por Civiles, oficiales de la Federación y reclutas de la Milicia. Parece que te reconocen como un renegado del Multiverso y están deslumbrados por tu fama. Al parecer es raro ver naves como la tuya aquí."

#: src-en/data/events_sector_militia.xml:149
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/choice[1]/text"
msgstr "Ignorar a los admiradores y buscar una tienda."

#: src-en/data/events_sector_militia.xml:151
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/choice[1]/event/text"
msgstr "Te abres paso entre la multitud, disculpándote mientras avanzas, y finalmente encuentras un mercado donde comprar."

#: src-en/data/events_sector_militia.xml:156
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/choice[2]/text"
msgstr "Firmar algunos autógrafos, pero irte antes de que la flota te alcance."

#: src-en/data/events_sector_militia.xml:158
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/choice[2]/event/text"
msgstr "Decides quedarte un rato con la multitud, contando historias y firmando autógrafos. Incluso recibes algunos regalos, pero finalmente decides marcharte antes de que los Rebeldes puedan llegar."

#: src-en/data/events_sector_militia.xml:163
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/choice[3]/text"
msgstr "Quedarte un rato más con los admiradores."

#: src-en/data/events_sector_militia.xml:165
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[1]/event/choice[3]/event/text"
msgstr "Decides permanecer con la multitud, contando historias y firmando autógrafos. Cuanto más tiempo te quedas, más regalos recibes, pero eventualmente debes retirarte antes de que los Rebeldes logren alcanzarte."

#: src-en/data/events_sector_militia.xml:173
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[2]/text"
msgstr "No necesitamos ir de compras ahora mismo."

#: src-en/data/events_sector_militia.xml:175
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[2]/event/text"
msgstr "Pasas de largo el planeta."

#: src-en/data/events_sector_militia.xml:177
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOGRAPHS\"]/choice[2]/event/choice[1]/text"
