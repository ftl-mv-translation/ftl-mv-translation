msgid "data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/text"
msgstr "Notas dos naves de la Milicia cercanas discutiendo por algo. No estás seguro de qué sin escuchar más de cerca, pero parece estar relacionado con Auto-naves."

#: src-en/data/events_sector_militia.xml:805
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/text"
msgstr "Llamarlos."

#: src-en/data/events_sector_militia.xml:807
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/text"
msgstr "\"Eh? Oh, no me había dado cuenta de que había otra nave aquí. Estamos discutiendo la posibilidad de construir nuestra propia flota de Auto-naves de la Milicia para reducir el número de bajas en las líneas del frente. Pero antes de considerarlo, necesitamos capturar una de las Auto-naves Rebeldes para estudiarla. Podrías hacernos un favor y cazar una de ellas?\""

#: src-en/data/events_sector_militia.xml:809
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[1]/text"
msgstr "Aceptar."

#: src-en/data/events_sector_militia.xml:811
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Excelente. Hemos adjuntado las coordenadas de la nave que nos gustaría estudiar, pero está ubicada demasiado cerca de una ASB. Si pudieras atraerla lejos sin causar demasiado daño podremos enviar una nave para recogerla.\""

#: src-en/data/events_sector_militia.xml:816
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[@req=\"LIST_A55\"]/text"
msgstr "(A55) Hacer que A55 transfiera datos de Auto-nave."

#: src-en/data/events_sector_militia.xml:818
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[@req=\"LIST_A55\"]/event/text"
msgstr "\"¡Oh cielos, esto es maravilloso! Esto ayudará a acelerar mucho nuestro desarrollo.\""

#: src-en/data/events_sector_militia.xml:823
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[@req=\"LIST_CREW_ENGINEER\"]/text"
msgstr "(Tripulante Ingeniero) Hacer que tu ingeniero transfiera datos de Auto-nave."

#: src-en/data/events_sector_militia.xml:825
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[@req=\"LIST_CREW_ENGINEER\"]/event/text"
msgstr "\"¡Oh cielos, esto es maravilloso! Esto ayudará a acelerar mucho nuestro desarrollo.\""

#: src-en/data/events_sector_militia.xml:830
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[@req=\"LIST_CREW_COGNITIVE_ALL\"]/text"
msgstr "(Tripulante Cognitivo) Hacer que tu Cognitivo transfiera datos de Auto-nave."

#: src-en/data/events_sector_militia.xml:832
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[@req=\"LIST_CREW_COGNITIVE_ALL\"]/event/text"
msgstr "\"¡Oh cielos, esto es maravilloso! Esto ayudará a acelerar mucho nuestro desarrollo.\""

#: src-en/data/events_sector_militia.xml:837
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[5]/text"
msgstr "Declinar."

#: src-en/data/events_sector_militia.xml:839
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[1]/event/choice[5]/event/text"
msgstr "\"Comprensible. Buena suerte con cualquier misión en la que estés entonces.\""

#: src-en/data/events_sector_militia.xml:845
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[2]/text"
msgstr "Tenemos cosas más importantes que hacer que escuchar a escondidas."

#: src-en/data/events_sector_militia.xml:847
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[2]/event/text"
msgstr "Sea lo que sea de lo que estén hablando, no te importa. Ignoras a las naves de la Milicia."

#: src-en/data/events_sector_militia.xml:849
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_militia.xml:853
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH\"]/choice[2]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_sector_militia.xml:862
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/beaconType/unvisitedTooltip"
msgstr "Los milicianos te han pedido atraer una Auto-nave para estudiarla."

#: src-en/data/events_sector_militia.xml:864
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/text"
msgstr "Has descubierto la nave automatizada mencionada por los milicianos. A lo lejos puedes ver el satélite ASB girando hacia ti."

#: src-en/data/events_sector_militia.xml:867
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[@req=\"PDS_DISABLE\"]/text"
msgstr "(Diluidor de Señal) Desactivar los sistemas de apuntado del satélite."

#: src-en/data/events_sector_militia.xml:869
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[@req=\"PDS_DISABLE\"]/event/text"
msgstr "El satélite deja de girar inmediatamente, incapaz de detectar tu ubicación. Aún tendrás que atraer a la Auto-nave, pero ahora puedes hacerlo sin el riesgo adicional del ASB."

#: src-en/data/events_sector_militia.xml:871
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[@req=\"PDS_DISABLE\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:877
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[@req=\"FLARE_DISTRACTION\"]/text"
msgstr "(Bengalas) Confundir el sistema ASB."

#: src-en/data/events_sector_militia.xml:879
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[@req=\"FLARE_DISTRACTION\"]/event/text"
msgstr "Lanzas varias bengalas cerca del satélite, confundiendo su sistema de apuntado. Considerando lo pequeños que son los discos dudas que el satélite pueda destruirlos fácilmente, dándote suficiente tiempo para atraer a esta nave."

#: src-en/data/events_sector_militia.xml:881
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[@req=\"FLARE_DISTRACTION\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:887
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[3]/text"
msgstr "Prepárate para luchar."

#: src-en/data/events_sector_militia.xml:889
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[3]/event/text"
msgstr "Tal como advirtieron los milicianos, el ASB fija tu ubicación exacta y comienza a disparar inmediatamente. Esperemos no sufrir demasiado daño antes de que la Auto-nave huya."

#: src-en/data/events_sector_militia.xml:892
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST\"]/choice[3]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:899
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_LURE\"]/text"
msgstr "Has logrado atraer a la Auto-nave lejos de la baliza. Te preparas para seguir la nave hacia su próximo destino."

#: src-en/data/events_sector_militia.xml:905
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/beaconType/unvisitedTooltip"
msgstr "Coordenadas de la Auto-nave atraída."

#: src-en/data/events_sector_militia.xml:907
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/text"
msgstr "Has rastreado nuevamente la Auto-nave. Cerca están las naves de la Milicia de antes, ya inspeccionando la Auto-nave."

#: src-en/data/events_sector_militia.xml:910
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/text"
msgstr "Contactar a los milicianos."

#: src-en/data/events_sector_militia.xml:912
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/event/text"
msgstr "\"Ah, muy buen trabajo. ¡La nave aún está en condiciones de funcionar, maravilloso! Aquí tienes tu pago, por supuesto.\""

#: src-en/data/events_sector_militia.xml:915
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:917
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/event/choice/event/text"
msgstr "Mientras te preparas para irte, escuchas gritos de los milicianos. Te das la vuelta y ves que la Auto-nave se ha activado nuevamente, ¡y destruye una de las naves de la Milicia de un solo disparo! Luego se dirige a atacarte."

#: src-en/data/events_sector_militia.xml:920
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/event/choice/event/choice[1]/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:924
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/event/choice/event/choice[@req=\"hacking\"]/text"
msgstr "(Camuflaje Mejorado) Desactivar la Auto-nave antes de que cause más daño."

#: src-en/data/events_sector_militia.xml:926
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_AUTOSEARCH_QUEST_2\"]/choice/event/choice/event/choice[@req=\"hacking\"]/event/text"
msgstr "Apagas la Auto-nave inmediatamente. La tripulación de la nave destruida evacúa de inmediato y solo se pierden unas pocas vidas. Los milicianos te agradecen."

#: src-en/data/events_sector_militia.xml:959
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_MISTAKE\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:964
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_MILITIA_MISTAKE\"]/text[1]"
msgstr "Los restos de una nave civil flotan cerca, pero antes de que puedas siquiera pensar en recuperar algo, una nave de la Milicia te confunde con el atacante y se prepara para vengar a los civiles."

#: src-en/data/events_sector_militia.xml:965
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_MILITIA_MISTAKE\"]/text[2]"
msgstr "Te metes en problemas por tu identificación con la nave de la Milicia en esta baliza, ¡y poco después las cosas se calientan hasta llegar al conflicto!"

#: src-en/data/events_sector_militia.xml:966
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_MILITIA_MISTAKE\"]/text[3]"
msgstr "Los milicianos de esta baliza parecen confundir a uno de tus tripulantes con un infame pirata con una gran recompensa por su cabeza. No estás dispuesto a entregar a tu tripulación, así que te preparas para luchar."

#: src-en/data/events_sector_militia.xml:967
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_MILITIA_MISTAKE\"]/text[4]"
msgstr "Intentas no meterte en peleas con civiles, pero a veces los civiles se meten en peleas contigo. De alguna manera has enfurecido a la nave de la Milicia aquí, y ya se está moviendo para atacar."

#: src-en/data/events_sector_militia.xml:971
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/text"
msgstr "Te encuentras con una estación de la Milicia cerca de esta baliza, que se niega a dejarte pasar. Al parecer esta baliza requiere pagar un peaje para atravesarla."

#: src-en/data/events_sector_militia.xml:974
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[1]/text"
msgstr "Negarse a pagar."

#: src-en/data/events_sector_militia.xml:976
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[1]/event/text"
msgstr "La estación de la Milicia no pierde tiempo conversando: ¡en cuanto te niegas, sus armas se activan!"

#: src-en/data/events_sector_militia.xml:979
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:985
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[2]/text"
msgstr "Pagar el peaje."

#: src-en/data/events_sector_militia.xml:987
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[2]/event/text"
msgstr "La estación de la Milicia recoge el pago y te permite continuar."

#: src-en/data/events_sector_militia.xml:992
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_militia.xml:996
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_STATION_MISTAKE\"]/choice[2]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_sector_militia.xml:1004
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_ESCORT\"]/text"
msgstr "Los restos de lo que alguna vez fue un transporte de la Milicia flotan cerca. Una nave de escolta de la Milicia, con su tripulación confundida y asustada, te confunde con los atacantes y se prepara para defenderse. Intentas contactarlos, pero no responden, y parece que la única salida de esto es una pelea."

#: src-en/data/events_sector_militia.xml:1007
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_ESCORT\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:1016
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_PIRATE_MILITIA\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:1021
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA\"]/text[1]"
msgstr "Hace falta un capitán pirata muy audaz, o muy estúpido, para intentar invadir el espacio de la Milicia. Cuando notas que la nave hostil se aproxima, esperas que sea lo segundo mientras te preparas para el combate."

#: src-en/data/events_sector_militia.xml:1022
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA\"]/text[2]"
msgstr "Una nave pirata se aproxima, con las armas ya cargándose. Deben estar en una auténtica racha de asesinatos en este territorio, ¡y están listos para tomarse un descanso de las naves de la Milicia y luchar contra la tuya!"

#: src-en/data/events_sector_militia.xml:1023
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA\"]/text[3]"
msgstr "Es irónico el problema de piratas que sufre el territorio de la Milicia a pesar de la fuerte militarización aquí. Nadie echará de menos a esta nave una vez que la hayas destruido."

#: src-en/data/events_sector_militia.xml:1024
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA\"]/text[4]"
msgstr "\"Ja! ¡Apuesto a que esperabas una nave de la Milicia! Ahora seguro tiemblas en las rodillas al ver mi nave, verdad?\" Silencias sus comunicaciones a mitad de su monólogo y te preparas para luchar."

#: src-en/data/events_sector_militia.xml:1025
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA\"]/text[5]"
msgstr "Ves un destello púrpura pasar a toda velocidad. Poco después, una nave pirata aparece a la vista. \"¡Jaja! ¡He reclamado las vidas de muchos milicianos, y ahora reclamaré la tuya! ¡Prepárate para luchar!\""

#: src-en/data/events_sector_militia.xml:1032
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_PIRATE_MILITIA_ONLY\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:1037
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA_ONLY\"]/text[1]"
msgstr "La flota de la Milicia presume de una gran cantidad de naves, pero esto también las convierte en un objetivo ideal para piratas que necesitan una nueva nave. Una nave de la Milicia controlada por piratas se aproxima, con las armas disparando."

#: src-en/data/events_sector_militia.xml:1038
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA_ONLY\"]/text[2]"
msgstr "Una nave pirata, que busca probar el nuevo equipo que acaba de robar de la Milicia, fija su objetivo en tu nave y ataca!"

#: src-en/data/events_sector_militia.xml:1039
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_PIRATE_MILITIA_ONLY\"]/text[3]"
msgstr "Al principio asumes que la nave aquí es solo otra nave común de la Milicia, hasta que ves la pintura pirata decorando su casco. ¡Piratas acercándose!"

#: src-en/data/events_sector_militia.xml:1046
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_REBEL_MILITIA\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:1051
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_REBEL_MILITIA\"]/text[1]"
msgstr "\"¡La Rebelión nunca se detendrá! ¡Todos los que se alíen con la Federación serán asesinados!\" Dudas de la superioridad moral de asesinar civiles que solo intentan proteger sus sectores, pero si los Rebeldes quieren una pelea, una pelea tendrán."

#: src-en/data/events_sector_militia.xml:1052
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_REBEL_MILITIA\"]/text[2]"
msgstr "La Rebelión parece guardar rencor contra la Milicia, aunque no puedes imaginar por qué. La nave Rebelde aquí parece decidida a luchar, y como eres la única nave presente deciden que serás un oponente satisfactorio."

#: src-en/data/events_sector_militia.xml:1053
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_REBEL_MILITIA\"]/text[3]"
msgstr "Una nave Rebelde ha saqueado los restos de una estación de la Milicia. Apenas segundos después de que llegas te detectan y deciden convertirte en su próximo objetivo."

#: src-en/data/events_sector_militia.xml:1054
msgid ""
"data/events_sector_militia.xml$//textList[@name=\"TEXT_ENCOUNTER_REBEL_MILITIA\"]/text[4]"
msgstr "La Milicia intenta mantener este sector libre de fuerzas Rebeldes, pero sus defensas son incapaces de mantenerlas completamente fuera. Un explorador avanzado Rebelde que ha logrado infiltrarse en el sector te detecta y ataca."

#: src-en/data/events_sector_militia.xml:1065
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_ELITE\"]/text"
msgstr "Las naves del Elite Defense Cadre son algunas de las más mortales de la flota de la Milicia, y por una buena razón. Con tripulación altamente entrenada, estas naves no se andan con juegos en combate. Desafortunadamente para ti, ¡la nave aquí te considera una amenaza y ataca!"

#: src-en/data/events_sector_militia.xml:1068
msgid ""
"data/events_sector_militia.xml$//event[@name=\"ENCOUNTER_MILITIA_ELITE\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:1082
msgid "data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/text"
msgstr "Parece haber varias naves de la Milicia acopladas alrededor de una estación civil de reabastecimiento cercana."

#: src-en/data/events_sector_militia.xml:1086
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/text"
msgstr "Investigar la escena."

#: src-en/data/events_sector_militia.xml:1088
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/text"
msgstr "Uno de los milicianos intenta protestar mientras te acoplas a la estación, pero es interrumpido por un humano vestido con un atuendo verde que fuma de una pequeña pipa de madera de diseño de la Antigua Tierra. \"Ah, un renegado, eh? Soy Sherlock Haynes. Provengo de la Tierra, aunque desde entonces me he unido a la Milicia. Ahora trabajo como detective para la Milicia, pero se me ha presentado un caso bastante problemático. Tal vez podrías ayudar?\""

#: src-en/data/events_sector_militia.xml:1090
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/text"
msgstr "Ayudar con qué?"

#: src-en/data/events_sector_militia.xml:1092
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/text"
msgstr "\"¡Con el misterio, por supuesto! Anoche, en esta misma estación, un hombre llamado Henry Coleman fue abatido a tiros. Sospechamos que tenía información vital sobre un plan de los Rebeldes, pero no sabemos cuál. Solo había 4 personas trabajando en esta estación, y después de este crimen ahora solo quedan 3. Ninguna nave se acopló a esta estación durante 24 horas completas antes y después del asesinato, ¡lo que solo puede significar una cosa!\""

#: src-en/data/events_sector_militia.xml:1094
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/text"
msgstr "Y eso es?"

#: src-en/data/events_sector_militia.xml:1096
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/event/text"
msgstr "\"Pues es elemental, mi querido... eh, como sea que te llames. ¡Esto significa que uno de estos 3 sobrevivientes debe ser un espía Rebelde! La pregunta es, cuál de ellos podría ser? Me ayudarás, mi amigo que salta entre realidades, a resolver este caso?\""

#: src-en/data/events_sector_militia.xml:1098
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/event/choice[1]/text"
msgstr "Claro."

#: src-en/data/events_sector_militia.xml:1100
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/event/choice[1]/event/text"
msgstr "\"¡Ah, excelente! Aún no he investigado mucho, pero si necesitas ayuda solo ven a hablar conmigo. Aquí están los tres sospechosos: el Sr. Thom Nicholson, la Sra. Amy Sheppard y el Dr. Daniel Browne. ¡Espero con interés tu hipótesis!\""

#: src-en/data/events_sector_militia.xml:1102
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/event/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_militia.xml:1108
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/event/choice[2]/text"
msgstr "Declinar."

#: src-en/data/events_sector_militia.xml:1110
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[1]/event/choice/event/choice/event/choice[2]/event/text"
msgstr "\"Ah, qué pena. Entonces será mejor que me vaya, no puedo tener distracciones mientras investigo.\""

#: src-en/data/events_sector_militia.xml:1120
msgid ""
"data/events_sector_militia.xml$//event[@name=\"MILITIA_DETECTIVE\"]/choice[@req=\"unique_haynes\"]/text"
msgstr "(Haynes) Contactar a la estación."

#: src-en/data/events_sector_militia.xml:1122
msgid ""
