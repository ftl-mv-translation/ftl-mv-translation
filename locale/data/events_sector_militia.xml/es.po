#: src-en/data/events_sector_militia.xml:1216
msgid ""
"data/events_sector_militia.xml$//event[@name=\"DETECTIVE_EVIDENCE_MENU\"]/choice[4]/event/text"
msgstr ""
"Sherlock levanta una ceja. \"Entonces, has llegado a una conclusión? Quién disparó al viejo Henry?\"\n"
"\t\t\t[Solo podrás acusar a sospechosos con los que hayas hablado]"

#: src-en/data/events_sector_militia.xml:1219
msgid ""
"data/events_sector_militia.xml$//event[@name=\"DETECTIVE_EVIDENCE_MENU\"]/choice[4]/event/choice[@req=\"loc_evidence_dronekiller\"]/text"
msgstr "Ninguno de ellos mató personalmente a Henry. ¡Fue el dron quien disparó el tiro fatal!"

#: src-en/data/events_sector_militia.xml:1223
msgid ""
"data/events_sector_militia.xml$//event[@name=\"DETECTIVE_EVIDENCE_MENU\"]/choice[4]/event/choice[@req=\"loc_evidence_thom\"]/text"
