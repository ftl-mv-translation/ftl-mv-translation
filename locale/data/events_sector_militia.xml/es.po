#: src-en/data/events_sector_militia.xml:129
msgid ""
"data/events_sector_militia.xml$//eventList[@name=\"MILITIA_CLANSMEN_REFUSE\"]/event[1]/text"
msgstr "\"Una lásstima. Sssiempre intento ssser educado primero, pero rara vez aceptan. En fin, ¡ahora esssto ssserá mucho más divertido!\""

#: src-en/data/events_sector_militia.xml:132
msgid ""
"data/events_sector_militia.xml$//eventList[@name=\"MILITIA_CLANSMEN_REFUSE\"]/event[1]/choice/text"
