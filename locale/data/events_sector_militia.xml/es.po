"data/events_sector_militia.xml$//event[@name=\"DISTRESS_MILITIA_OUTPOST\"]/choice[@req=\"weapons\"]/event/text"
msgstr "\"Oye, quién demonios crees que eres.. oh demonios. Está bien, está bien, ¡ganas tú, diviértete!\" El pirata salta lejos. La fatigada estación de la Milicia parece indefensa ante cualquier cosa que puedas intentar."

#: src-en/data/events_sector_militia.xml:744
msgid ""
"data/events_sector_militia.xml$//event[@name=\"DISTRESS_MILITIA_OUTPOST\"]/choice[@req=\"weapons\"]/event/choice[1]/text"
