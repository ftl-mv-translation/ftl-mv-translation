"data/events_sector_militia.xml$//event[@name=\"DISTRESS_MILITIA_OUTPOST\"]/choice[@req=\"weapons\"]/event/choice[1]/event/text"
msgstr "\"Gracias, era poco probable que hubiéramos sobrevivido a ese ataque pirata de otra manera. No podemos ofrecer mucho más que algo de combustible que no necesitamos.\""

#: src-en/data/events_sector_militia.xml:751
