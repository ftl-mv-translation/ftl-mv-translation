#: src-en/data/events_sector_militia.xml:1564
msgid ""
"data/events_sector_militia.xml$//event[@name=\"DETECTIVE_TALK_AMY\"]/choice[1]/event/text"
msgstr "Amy no tiene mucho que contar sobre por qué se unió a la Milicia. Pensó que sería una buena forma de escapar de su planeta natal y tal vez matar algunos piratas."

#: src-en/data/events_sector_militia.xml:1566
msgid ""
"data/events_sector_militia.xml$//event[@name=\"DETECTIVE_TALK_AMY\"]/choice[1]/event/choice/text"
