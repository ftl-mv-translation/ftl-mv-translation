"data/events_sector_ministry.xml$//event[@name=\"NEBULA_ZOLTAN_STUDY\"]/choice[@req=\"medbay\"]/event/text"
msgstr "\"¡Gracias! No esperábamos recibir tanta información sobre la salud de tu tripulación durante los viajes hiperluz. Toma, acepta este detallito por las molestias causadas\"."

#: src-en/data/events_sector_ministry.xml:2094
