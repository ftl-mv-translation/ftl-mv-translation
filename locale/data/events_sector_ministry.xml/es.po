#: src-en/data/events_sector_ministry.xml:449
msgid ""
"data/events_sector_ministry.xml$//eventList[@name=\"ZOLTAN_CREW_SCAN_LIST_MV\"]/event[1]/text"
msgstr "El personal de seguridad zoltan sube a bordo de tu nave y escanea las caras de la tripulación con un ordenador. Tras unos tensos momentos de incertidumbre, dan permiso a tu nave para seguir adelante."

#: src-en/data/events_sector_ministry.xml:452
msgid ""
"data/events_sector_ministry.xml$//eventList[@name=\"ZOLTAN_CREW_SCAN_LIST_MV\"]/event[2]/text"
msgstr "El personal de seguridad Zoltan aborda tu nave y comienza a escanear los rostros de la tripulación en una computadora. De repente suenan alarmas y los Zoltan se abalanzan sobre uno de tus tripulantes. \"¡Esta persona es buscada por cinco cargos de Villanía Absoluta! ¡Entréguennoslo!\""

#: src-en/data/events_sector_ministry.xml:454
msgid ""
"data/events_sector_ministry.xml$//eventList[@name=\"ZOLTAN_CREW_SCAN_LIST_MV\"]/event[2]/choice[1]/text"
