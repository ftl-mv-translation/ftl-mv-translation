#: src-en/data/events_sector_ministry.xml:583
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[@req=\"zoltan_peacekeeper\"]/text"
msgstr "(Tripulante Peacekeeper) Exigir que los Zoltan se retiren."

#: src-en/data/events_sector_ministry.xml:585
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[@req=\"zoltan_peacekeeper\"]/event/text"
msgstr "Tu Peacekeeper cita la ley C-T-55 del códice del Ministry, afirmando que no tienen derecho a atacar naves civiles sin una razón suficiente o permiso de una autoridad superior. Como ningún Zoltan, vivo o muerto, se dice que tiene conocimiento completo de todo el códice, la otra nave no tiene fundamentos para negar la existencia de dicha ley. Se retiran y saltan lejos."

#: src-en/data/events_sector_ministry.xml:588
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[@req=\"zoltan_peacekeeper\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_ministry.xml:594
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[3]/text"
