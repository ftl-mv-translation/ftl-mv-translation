#: src-en/data/events_sector_ministry.xml:596
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[3]/event/text"
msgstr "Finalmente los civiles son perseguidos fuera de alcance, y quedas solo."

#: src-en/data/events_sector_ministry.xml:598
msgid ""
