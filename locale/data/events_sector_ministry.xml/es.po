#: src-en/data/events_sector_ministry.xml:574
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[1]/event/text"
msgstr "No le das a la nave Zoltan otra opción que luchar contra ti mientras vuelas hacia ella a toda velocidad."

#: src-en/data/events_sector_ministry.xml:577
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TOURIST\"]/choice[1]/event/choice/text"
