msgid ""
"data/events_sector_ministry.xml$//event[@name=\"OSMIA_RAID_ASSIST\"]/choice/event/choice[2]/text"
msgstr "Sí, bueno, diviértanse lidiando con esos sujetos. Nosotros nos vamos de aquí."

