#: src-en/data/events_sector_ministry.xml:456
msgid ""
"data/events_sector_ministry.xml$//eventList[@name=\"ZOLTAN_CREW_SCAN_LIST_MV\"]/event[2]/choice[1]/event/text"
msgstr "Es duro, pero aquí rige la ley zoltan. Además, siempre desconfiaste un poco de esa persona."

#: src-en/data/events_sector_ministry.xml:459
msgid ""
"data/events_sector_ministry.xml$//eventList[@name=\"ZOLTAN_CREW_SCAN_LIST_MV\"]/event[2]/choice[1]/event/removeCrew/text"
