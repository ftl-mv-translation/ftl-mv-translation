#: src-en/data/events_sector_ministry.xml:159
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_TRADE_HUB_MV\"]/choice[@req=\"LIST_CREW_ZOLTAN_CAPITAL\"]/event/text"
