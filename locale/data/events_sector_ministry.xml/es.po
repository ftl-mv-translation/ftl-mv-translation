msgid ""
"data/events_sector_ministry.xml$//textList[@name=\"TEXT_ENCOUNTER_ZOLTAN\"]/text[3]"
msgstr "Recibes un mensaje: \"Esta zona está restringida. Entrega la nave para que sea procesada\". Tan solo hay una nave de guardia en una baliza solitaria. Decides huir por la fuerza."

