msgstr "(Tripulante babosa) Pedirle a tu babosa que hable con ellos y los convenza para que os deje iros."

#: src-en/data/events_sector_ministry.xml:422
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_CREW_SCAN_MV\"]/choice[@req=\"LIST_CREW_SLUG\"]/event/text"
msgstr "Les das a los guardias permiso para acoplar la nave, pero, antes de que suban a bordo, se encuentran con tu tripulante. No te consta que intercambiasen ni una sola palabra, pero los guardias os ofrecen suministros y dicen que la nave está en orden. Será mejor que no hagas preguntas..."

#: src-en/data/events_sector_ministry.xml:427
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"ZOLTAN_CREW_SCAN_MV\"]/choice[@req=\"LIST_CREW_ZOLTAN_CAPITAL\"]/text"
