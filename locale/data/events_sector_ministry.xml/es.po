msgstr "(Alien Hibernante) Preguntar si saben qué hacer con esto."

#: src-en/data/events_sector_ministry.xml:2104
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"NEBULA_ZOLTAN_STUDY\"]/choice[@req=\"ANCIENT_CONSTRUCTOR\"]/event/text"
msgstr "\"Interesante... nunca he visto una criatura como esta. Me temo que no hay mucho que podamos hacer con ella; su estado actual no está relacionado con el sueño de estasis. Sin embargo, con un catalizador, como combustible cuántico, quizá puedas despertarla de nuevo?\""

#: src-en/data/events_sector_ministry.xml:2111
