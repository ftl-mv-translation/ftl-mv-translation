#: src-en/data/events_sector_ministry.xml:2211
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"CAPITAL_OSMIA_RAID\"]/choice[1]/event/text"
msgstr "En cuanto te aproximas, queda claro que algo inquietante ocurre. Apenas hay actividad en las calles cerca del enorme edificio del capitolio, y jurarías ver varias patrullas armadas apostadas afuera. Tu descenso es recibido con una advertencia; \"Nave extranjera no registrada - deténgase de inmediato y abandone esta zona. Este no es momento para la intervención imprudente de terceros irresponsables.\""

#: src-en/data/events_sector_ministry.xml:2213
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"CAPITAL_OSMIA_RAID\"]/choice[1]/event/choice[1]/text"
msgstr "No somos terceros irresponsables - somos la Federación."

#: src-en/data/events_sector_ministry.xml:2215
msgid ""
"data/events_sector_ministry.xml$//event[@name=\"CAPITAL_OSMIA_RAID\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Lo entiendo. Mi declaración se mantiene. Este es un asunto de importancia para el Ministry y solo para el Ministry. Ahora márchate.\""

#: src-en/data/events_sector_ministry.xml:2217
msgid ""
