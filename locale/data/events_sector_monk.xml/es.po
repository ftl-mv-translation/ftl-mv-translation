#: src-en/data/events_sector_monk.xml:646
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_HOSTAGES\"]/choice[5]/event/text"
msgstr "No puedes desperdiciar tu dinero aquí. Cuando los Hackers se den cuenta de que nadie va a pagar, dejarán a los Monks en paz de todos modos... probablemente..."

#: src-en/data/events_sector_monk.xml:648
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_HOSTAGES\"]/choice[5]/event/choice[1]/text"
