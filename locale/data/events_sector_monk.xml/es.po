msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[4]/text"
msgstr "Rocoides."

#: src-en/data/events_sector_monk.xml:975
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[4]/event/text"
msgstr "\"Un duro enemigo para una persona tan dura como tú\". Detectas que se abre un agujero de gusano. De él, sale una nave rocoide con las armas a pleno rendimiento. Parece que estaban en pleno combate cuando fueron arrastrados por el espacio-tiempo."

#: src-en/data/events_sector_monk.xml:978
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[4]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:984
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[5]/text"
msgstr "Lanius."

#: src-en/data/events_sector_monk.xml:986
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[5]/event/text"
msgstr "\"Una petición inusualmente masoquista, pero te la concederé.\" Detectas la apertura de un agujero de gusano, y una nave Lanius emerge. Hambrienta de chatarra, la nave ataca."

#: src-en/data/events_sector_monk.xml:989
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[5]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:995
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[6]/text"
msgstr "Orchids."

#: src-en/data/events_sector_monk.xml:997
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[6]/event/text"
msgstr "\"No juzgues un libro por su portada, algunos enemigos son más fuertes de lo que podrían parecer.\" Detectas la apertura de un agujero de gusano, y una nave Orchid emerge. Confundidos, te confunden con un enemigo y atacan!"

#: src-en/data/events_sector_monk.xml:1000
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[6]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1006
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[@req=\"LIST_CREW_ANCIENT\"]/text"
msgstr "Obelisks."

#: src-en/data/events_sector_monk.xml:1008
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[@req=\"LIST_CREW_ANCIENT\"]/event/text"
msgstr "El Zoltan permanece en silencio por un momento, y luego susurra: \"Estás seguro? Bueno, que así sea entonces.\" Un enorme agujero de gusano se abre, y desde su interior surge una nave Obelisk, preparada para la guerra."

#: src-en/data/events_sector_monk.xml:1011
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_RIFT_FIGHT\"]/choice[@req=\"LIST_CREW_ANCIENT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1018
msgid "data/events_sector_monk.xml$//event[@name=\"ZOLTAN_RIFT_SUCCESS\"]/text"
msgstr "El anciano zoltan se pone furioso al ver que te has alzado con la victoria. Unas grietas amenazan con desgarrar el espacio cuando, de repente, el zoltan implosiona. El resultado es una oleada de restos y recursos que han llegado hasta aquí desde mundos lejanos."

#: src-en/data/events_sector_monk.xml:1037
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/text"
msgstr "Una nave de monjes se encuentra aquí. \"Estábamos ordenando esta región y encontramos un terrible alijo que contenía un arma violenta! No tenemos necesidad de algo así, pero si haces una donación a nuestra causa, estaremos encantados de dejar que te la lleves.\""

#: src-en/data/events_sector_monk.xml:1040
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[1]/text"
msgstr "Ofrecer algo de chatarra por el arma."

#: src-en/data/events_sector_monk.xml:1042
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[1]/event/text"
msgstr "\"Maravilloso! Usaremos esta chatarra para un buen propósito. Ve en paz.\""

#: src-en/data/events_sector_monk.xml:1047
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[1]/event/choice/text"
msgstr "Tomar el arma."

#: src-en/data/events_sector_monk.xml:1055
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[@req=\"LIST_CREW_MONK\"]/text"
msgstr "(Tripulante Monk) Prometer usar el arma de forma responsable a cambio de un descuento."

#: src-en/data/events_sector_monk.xml:1057
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[@req=\"LIST_CREW_MONK\"]/event/text"
msgstr "\"Como eres de la fe, confiaremos en tu palabra. Ve en paz.\""

#: src-en/data/events_sector_monk.xml:1062
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[@req=\"LIST_CREW_MONK\"]/event/choice/text"
msgstr "Tomar el arma."

#: src-en/data/events_sector_monk.xml:1070
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[3]/text"
msgstr "Atacarlos, quizá puedas conseguirla gratis."

#: src-en/data/events_sector_monk.xml:1072
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[3]/event/text"
msgstr "Los monjes responden, con pesar en sus voces. \"Entonces es cierto... aquellos que usan medios violentos no pueden ser razonados...\""

#: src-en/data/events_sector_monk.xml:1075
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[3]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1081
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[4]/text"
msgstr "Decirles que tampoco la quieres."

#: src-en/data/events_sector_monk.xml:1083
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[4]/event/text"
msgstr "\"Entendemos cómo te sientes. Quizá la arrojemos a una estrella, o la presentemos al Gran Ojo.\""

#: src-en/data/events_sector_monk.xml:1085
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[4]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_monk.xml:1089
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_WEAPON\"]/choice[4]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_sector_monk.xml:1097
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/text"
msgstr "Una nave Orchid se encuentra en esta baliza, donde también residen varios monjes. Te contacta. \"Hola! Estábamos buscando Zoltans de la fe Illesctriana. Esperábamos que algunos pudieran acompañarnos a nuestro espacio, pero parecen dudar en aceptar. Crees que podrías convencerlos?\""

#: src-en/data/events_sector_monk.xml:1100
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"orchid_caretaker\"]/text"
msgstr "(Tripulante Caretaker) Hablar con los monjes."

#: src-en/data/events_sector_monk.xml:1102
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"orchid_caretaker\"]/event/text"
msgstr "Tu Caretaker Orchid comienza a hablar suavemente con los monjes sobre la vida de los Orchids, sus deberes y creencias. Los monjes parecen impresionados con los ideales de tu Caretaker y aceptan ir. \"Wow, eso realmente funcionó! Gracias por tu ayuda.\" Los Orchids te dan una modesta recompensa por ayudarlos."

#: src-en/data/events_sector_monk.xml:1107
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"LIST_CREW_FLORAL\"]/text"
msgstr "(Tripulante Floral) Convencer a los Orchids de buscar en otro lugar."

#: src-en/data/events_sector_monk.xml:1109
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"LIST_CREW_FLORAL\"]/event/text"
msgstr "Tu tripulante habla con los otros Orchids y los convence de que este tipo de viaje es difícil para estas personas y que seguramente encontrarán monjes más dispuestos si continúan buscando. Los Orchids se disculpan. Los monjes aprecian tu intervención y te dan un pequeño tributo por ayudarlos."

#: src-en/data/events_sector_monk.xml:1114
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"unique_mayeb\"]/text"
msgstr "(Mayeb) Hablar con los monjes."

#: src-en/data/events_sector_monk.xml:1116
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"unique_mayeb\"]/event/text"
msgstr ""
"Mayeb va a hablar con los monjes. \"Saludos, mi nombre es Mayeb. Esta es mi hermana, P'erpah.\" Señala a su otra cabeza, que se mueve un poco. \"P'erpah dice 'buen día para ustedes-' Ah, cómo digo esto... '-brillantes de la fe.'\"\n"
"\n"
"Los monjes se muestran intrigados y comienzan a preguntarle a Mayeb sobre su hermana. Mientras hablan, Mayeb los anima suavemente a aprender más sobre su gente. \"...y tal vez, solo tal vez... también tengan algunas cosas que aprender de ustedes, si eso es lo que les importa.\"\n"
"\n"
"Los monjes quedan convencidos.\n"
"\n"
"\"Eres... alguien extraña, Mayeb. Pero cumpliste por nosotros. Gracias.\" Los Orchids te dan una pequeña recompensa por ayudarlos."

#: src-en/data/events_sector_monk.xml:1127
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"LIST_CREW_MONK\"]/text"
msgstr "(Tripulante Monk) Convencer a los monjes."

#: src-en/data/events_sector_monk.xml:1129
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[@req=\"LIST_CREW_MONK\"]/event/text"
msgstr "Tu monje habla sobre la importancia de difundir ideales y sobre cómo esta es la manera en que el Gran Ojo les indica que es momento de tener un impacto más amplio. Ante esto, los monjes cambian de opinión y aceptan acompañar a los Orchids. \"Wow, eso realmente funcionó! Gracias por tu ayuda.\" Los Orchids te dan una pequeña recompensa por ayudarlos."

#: src-en/data/events_sector_monk.xml:1134
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[5]/text"
msgstr "Intentar mediar."

#: src-en/data/events_sector_monk.xml:1138
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[6]/text"
msgstr "Atacar la nave Orchid."

#: src-en/data/events_sector_monk.xml:1140
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[6]/event/text"
msgstr "Mientras preparas las armas, el Orchid corta rápidamente la comunicación y comienza a activar sus propias armas."

#: src-en/data/events_sector_monk.xml:1143
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[6]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1149
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[7]/text"
msgstr "Disculparte y desconectar."

#: src-en/data/events_sector_monk.xml:1151
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[7]/event/text"
msgstr "Decides no interactuar con los Orchids."

#: src-en/data/events_sector_monk.xml:1153
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[7]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_monk.xml:1157
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ORCHID\"]/choice[7]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_sector_monk.xml:1165
msgid ""
"data/events_sector_monk.xml$//eventList[@name=\"MONK_ORCHID_MEDIATE\"]/event[1]/text"
msgstr "Haces lo posible por ayudarlos a alcanzar un compromiso. Finalmente logras convencer a uno de los monjes de unirse a los Orchids, aunque solo sea para evitar que todos sigan en una conversación circular. \"Huh, no puedo creer que eso funcionara. Gracias por tu ayuda.\" Los Orchids te dan una pequeña recompensa por ayudarlos."

#: src-en/data/events_sector_monk.xml:1169
msgid ""
"data/events_sector_monk.xml$//eventList[@name=\"MONK_ORCHID_MEDIATE\"]/event[2]/text"
msgstr "Haces lo posible por ayudarlos a alcanzar un compromiso. Aun así, terminas sin aportar nada ya que no puedes relacionarte con ninguno de los dos lados. Al final, se disculpan por hacerte perder el tiempo. Parece que no hay nada más que hacer aquí."

#: src-en/data/events_sector_monk.xml:1175
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_SUN\"]/text"
msgstr "\"Bienvenido a tu prueba de fuego. El Gran Ojo exige que pongamos a prueba tu temple. Debes experimentar dificultades, al menos por un tiempo. Serás forjado en el crisol del sufrimiento para alcanzar la verdadera iluminación.\" Parece que planean retenerte aquí por un corto tiempo!"

#: src-en/data/events_sector_monk.xml:1179
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_SUN\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1184
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_SUN_TRIAL_WIN\"]/text"
msgstr "\"Tu prueba ha terminado, has pasado! Aquí está tu recompensa. Pero ten cuidado, el universo sin duda tendrá muchas más dificultades para ti. Siempre presta atención a las lecciones del universo.\""

#: src-en/data/events_sector_monk.xml:1190
msgid "data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/text"
msgstr "Es raro ver monasterios Zoltan fuera de la nebulosa. Este está posicionado en la zona gris de un planeta con rotación sincrónica, de modo que en ese lugar siempre parece estar amaneciendo."

#: src-en/data/events_sector_monk.xml:1192
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/text"
msgstr "Visitar el monasterio."

#: src-en/data/events_sector_monk.xml:1194
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/text"
msgstr "\"Bienvenido, viajero, a la luz. La Orden de Iluminación Illesctriana observa todo. Sin embargo, aunque miramos en tu alma, no te juzgamos. Solo a través de la iluminación uno puede expiar sus errores.\" El monje principal te observa a los ojos con una mirada inusualmente intensa y penetrante."

#: src-en/data/events_sector_monk.xml:1196
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"7\"]/text"
msgstr "Experimentar la iluminación."

#: src-en/data/events_sector_monk.xml:1198
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"7\"]/event/text"
msgstr "\"Oh, vaya. Tu alma está bastante manchada. Incluso con una mirada puedo decir que traes miseria a muchas personas. Quizá haya algunos pequeños actos de bondad que estoy pasando por alto... pero puedo ver que eres odiado por muchos. Estás en un camino oscuro.\""

#: src-en/data/events_sector_monk.xml:1200
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"7\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1206
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"5\"]/text"
msgstr "Experimentar la iluminación."

#: src-en/data/events_sector_monk.xml:1208
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"5\"]/event/text"
msgstr "\"No eres apreciado por muchos. Puedo ver que estás creando muchos enemigos en tu viaje por las estrellas. No conozco las circunstancias exactas, pero si deseas vivir en paz cuando tu pequeña guerra termine, tendrás que hacer las paces.\""

#: src-en/data/events_sector_monk.xml:1210
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"5\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1216
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"3\"]/text"
msgstr "Experimentar la iluminación."

#: src-en/data/events_sector_monk.xml:1218
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"3\"]/event/text"
msgstr "\"Eres una figura conflictiva. Tus acciones constantemente te presentan como poco diplomático e incluso bárbaro. Estoy seguro de que hay muchos lugares a los que ya no puedes ir y ser bienvenido, a menos que hagas un esfuerzo sincero por cambiar.\""

#: src-en/data/events_sector_monk.xml:1220
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"3\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1226
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"1\"]/text"
msgstr "Experimentar la iluminación."

#: src-en/data/events_sector_monk.xml:1228
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"1\"]/event/text"
msgstr "\"En general, parece que has dejado una mala impresión en esta galaxia. Quizá haya circunstancias atenuantes, pero parece que estás avanzando en la dirección equivocada. Sin embargo, parece que has mostrado al menos algo de moderación.\""

#: src-en/data/events_sector_monk.xml:1230
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"1\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1236
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"0\"]/text"
msgstr "Experimentar la iluminación."

#: src-en/data/events_sector_monk.xml:1238
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"0\"]/event/text"
msgstr "\"Cuando miro en tus ojos, puedo ver que estás en equilibrio. Si has cometido actos que dañaron a otros, han sido contrarrestados con actos de bondad o heroísmo. ...O quizá no has cometido ninguno de los dos?\""

#: src-en/data/events_sector_monk.xml:1240
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"0\"]/event/choice[@req=\"REPUTATION_IS_TOTALLY_FINE\" and "
"@lvl=\"1\"]/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1242
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"0\"]/event/choice[@req=\"REPUTATION_IS_TOTALLY_FINE\" and "
"@lvl=\"1\"]/event/text"
msgstr "\"Ah, sí, en efecto. Al observar con más atención, estás completamente en equilibrio. No eres ni famoso ni infame. Mi intuición me dice que no agitas las aguas. Pero eso también es sabio a su manera. Te ofrecemos un regalo. Ve en paz, y camina siempre en la luz.\""

#: src-en/data/events_sector_monk.xml:1247
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"0\"]/event/choice[@req=\"REPUTATION_IS_TOTALLY_FINE\" and "
"@lvl=\"0\"]/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1253
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"-4\"]/text"
msgstr "Experimentar la iluminación."

#: src-en/data/events_sector_monk.xml:1255
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"-4\"]/event/text"
msgstr "\"Tienes buen karma en general. Para los no combatientes, es más probable que traigas paz y seguridad que explotación o daño. La luz es donde perteneces.\""

#: src-en/data/events_sector_monk.xml:1257
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"-4\"]/event/choice[@req=\"REPUTATION_IS_TOTALLY_FINE\" and "
"@lvl=\"1\"]/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1261
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"-4\"]/event/choice[@req=\"REPUTATION_IS_TOTALLY_FINE\" and "
"@lvl=\"0\"]/text"
msgstr "Continuar..."

#: src-en/data/events_sector_monk.xml:1267
msgid ""
"data/events_sector_monk.xml$//event[@name=\"MONK_ATONEMENT\"]/choice[1]/event/choice[@req=\"rep_comb_all\""
" and @lvl=\"-999\"]/text"
