#: src-en/data/events_sector_monk.xml:624
msgid ""
"data/events_sector_monk.xml$//event[@name=\"NEBULA_MONK_HOSTAGES\"]/choice[@req=\"mind\"]/event/text"
msgstr "El control mental resulta completamente inútil, ya que los Hackers son Slugs. Peor aún, has revelado tu ubicación y la nave se acerca para atacar."

