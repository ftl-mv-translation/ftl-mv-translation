#: src-en/data/events_sector_morph.xml:546
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/text"
msgstr "Parece que la nave ingeniero cercana aún no te ataca. En cambio, te envía una transmisión. \"Sabes, debería atacarte. Pero francamente, ¡solo quiero presumir ante alguien de mi último logro!\""

#: src-en/data/events_sector_morph.xml:550
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[1]/text"
msgstr "Escuchar."

#: src-en/data/events_sector_morph.xml:552
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[1]/event/text"
msgstr "\"Probablemente ya hayas oído hablar o visto a los Technopaths. Son como los Morphs, ¡pero pueden adoptar la forma de entidades no basadas en carbono! Pues bien, pensé que sería una gran idea empezar a reemplazar mis drones con algunos. Es casi exactamente el mismo nivel de eficiencia, ¡pero sin ningún consumo de energía! ¡Es fantástico!\""

#: src-en/data/events_sector_morph.xml:554
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[1]/event/choice[1]/text"
msgstr "Compra un Technopath."

#: src-en/data/events_sector_morph.xml:563
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[1]/event/choice[2]/text"
msgstr "Reconoce su éxito y continúa."

#: src-en/data/events_sector_morph.xml:565
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[1]/event/choice[2]/event/text"
msgstr "Solo intentas continuar hacia la siguiente baliza, pero el Ingeniero está tan feliz de que lo hayas reconocido que incluso te ofrece algunas piezas de dron gratis."

#: src-en/data/events_sector_morph.xml:572
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[2]/text"
msgstr "No estamos aquí para escuchar historias. ¡Ataca a los ingenieros!"

#: src-en/data/events_sector_morph.xml:574
msgid ""
"data/events_sector_morph.xml$//event[@name=\"NEBULA_MORPH_ENGINEER_TECHNO\"]/choice[2]/event/text"
msgstr "¡No mostrarás misericordia a estos Rebeldes solo porque quieran hablar!"

