"data/events_sector_morph.xml$//eventList[@name=\"MORPH_SOLAR_SMART\"]/event[1]/text"
msgstr "Tu Shell sabe exactamente cómo funciona esta máquina y recupera las celdas de energía para instalarlas en tu reactor. ¡Esto le dará un buen impulso!"

#: src-en/data/events_sector_morph.xml:377
