#: src-en/data/events_sector_nexus.xml:291
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_DESTRUCTION_2_NEXUS\"]/text"
msgstr "Aunque una gruesa capa de sellador Slug mantiene la nave unida mientras comienza a romperse, finalmente cede bajo la tensión y la nave explota, dispersando contenedores de carga por todo el sistema."

#: src-en/data/events_sector_nexus.xml:295
