" and @lvl=\"1\"]/event/choice/event/text"
msgstr "Dylan solo sonríe más ampliamente, moviéndose ligeramente. \"¡YO CREER QUE TÚ SABER DE QUÉ SERVICIO HABLO! ¡YEEEEEE! ¡AHORA YO COMERCIAR CONTIGO! ¡TÚ TENER GRATITUD DE DYLAN PARA SIEMPRE!\""

#: src-en/data/events_sector_nexus.xml:1856
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"DYLAN\"]/choice[@req=\"prof_dylan_judgement\""
