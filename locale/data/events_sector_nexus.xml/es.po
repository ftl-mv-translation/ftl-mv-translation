#: src-en/data/events_sector_nexus.xml:2486
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_1D\"]/choice/event/choice/event/choice[2]/event/text"
msgstr "\"Lo que tú digas, desssconocido...\""

#: src-en/data/events_sector_nexus.xml:2488
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_1D\"]/choice/event/choice/event/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_nexus.xml:2492
