" and @lvl=\"1\"]/text"
msgstr "Responder con un saludo alegre."

#: src-en/data/events_sector_nexus.xml:1851
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"DYLAN\"]/choice[@req=\"prof_dylan_judgement\""
" and @lvl=\"1\"]/event/text"
msgstr "\"¡YY! ¡M GUSTAS! ¡DYLAN DAR GRACIAS POR GRAN SERVICIO A SU TIERRA!\""

#: src-en/data/events_sector_nexus.xml:1853
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"DYLAN\"]/choice[@req=\"prof_dylan_judgement\""
" and @lvl=\"1\"]/event/choice/text"
msgstr "Qué servicio?"

#: src-en/data/events_sector_nexus.xml:1855
