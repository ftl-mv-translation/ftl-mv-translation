" and @lvl=\"1\"]/event/eventButton[@name=\"UI_SYLVAN_BUTTON\"]/tooltip"
msgstr "Solicitar apoyo de fuego."

#: src-en/data/events_sector_nexus.xml:914
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_PRIME_QUESTIONS\"]/choice[@req=\"unique_anurak\"]/event/choice/event/choice[@req=\"PRIME_SUPPORT_CHECK\""
" and "
"@lvl=\"1\"]/event/eventButton[@name=\"UI_SYLVAN_BUTTON\"]/inactiveTooltip"
