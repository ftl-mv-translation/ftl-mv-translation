msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_BEANS\"]/choice[2]/event/text"
msgstr "No necesitas involucrarte en lo que sea que esté pasando aquí."

#: src-en/data/events_sector_nexus.xml:2615
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_BEANS\"]/choice[2]/event/choice[1]/text"
