"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_1D\"]/choice/event/choice/event/choice[1]/event/choice/event/text"
msgstr "\"¡Claro que lo soy, desssconocido! ¡Solo espera, el 4D será la sensación en los cinesss! En fin, se supone que soy el villano en este evento assí que mwahaha, ¡MUERE DESSSCONOCIDO!\""

#: src-en/data/events_sector_nexus.xml:2476
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_1D\"]/choice/event/choice/event/choice[1]/event/choice/event/choice/text"
