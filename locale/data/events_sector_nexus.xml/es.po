#: src-en/data/events_sector_nexus.xml:1768
msgid "data/events_sector_nexus.xml$//event[@name=\"SYLVAN_NARRATOR_END\"]/text"
msgstr "De acuerdo, de acuerdo, esto va a tardar demasiado. Podemos detenernos aquí. Pero oh, Renegado, ¡esto ha sido simplemente espléndido! Oh, me siento terrible por no haber preparado un regalo para ti. Te diré qué. Ven a visitarme otra vez, y tendré algo realmente maravilloso preparado, de acuerdo? ¡Adiós, Renegado! Espero volver a verte en el futuro."

#: src-en/data/events_sector_nexus.xml:1771
msgid ""
"data/events_sector_nexus.xml$//event[@name=\"SYLVAN_NARRATOR_END\"]/choice[@req=\"nar_pronouns_boy\"]/text"
