msgstr "No eres molestado mientras recuperas algunos suministros."

#: src-en/data/events_sector_obelisk.xml:1189
msgid ""
"data/events_sector_obelisk.xml$//eventList[@name=\"ROYAL_AUGMENTED_JOY_SALVAGE\"]/event[2]/text"
msgstr "Mientras recuperas algunos restos, una nave Augmented pasa volando, te ve y ataca!"

#: src-en/data/events_sector_obelisk.xml:1193
msgid ""
"data/events_sector_obelisk.xml$//eventList[@name=\"ROYAL_AUGMENTED_JOY_SALVAGE\"]/event[2]/choice/text"
