#: src-en/data/events_sector_obelisk.xml:668
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/text"
msgstr "Un Obelisk agitado te contacta. \"Tú, mortal. Tenemos un problema con este extraño dispositivo. Es una especie de arma, pero no logramos descubrir cómo operarlo.\""

#: src-en/data/events_sector_obelisk.xml:670
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/choice[1]/text"
