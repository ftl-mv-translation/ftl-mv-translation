#: src-en/data/events_sector_obelisk.xml:768
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_DESIRE\"]/choice[5]/event/text"
msgstr "\"La criatura insensata espera liberarse? No escuchaste mi advertencia? Estoy en control de tu nave. Responde mi pregunta o sufre las consecuencias. Qué es lo que más deseas?\""

