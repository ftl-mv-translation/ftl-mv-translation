#: src-en/data/events_sector_obelisk.xml:2028
msgid "data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[2]/text"
msgstr "No hay tiempo para mediar, ¡ayuda a los Obelisks!"

#: src-en/data/events_sector_obelisk.xml:2030
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[2]/event/text"
msgstr "No hay tiempo para discutir, tienes que ayudar al lado que ahora te resulte más útil, ¡y ese es la resistencia!"

#: src-en/data/events_sector_obelisk.xml:2033
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_obelisk.xml:2039
msgid "data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[3]/text"
