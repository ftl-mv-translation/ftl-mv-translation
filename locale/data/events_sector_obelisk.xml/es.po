msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_PALACE_ENTER\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_obelisk.xml:414
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_PALACE_ENTER\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "No queda otra opción. Debes perseguir a Vance mientras aún puedas y detenerlo antes de que cumpla sus planes. Configuras tu motor FTL en la misma trayectoria que él y te preparas para una batalla infernal."

