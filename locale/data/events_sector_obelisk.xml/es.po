#: src-en/data/events_sector_obelisk.xml:2015
msgid "data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/text"
msgstr "Dos naves cercanas están en medio de un tiroteo, una parece ser de los Rebeldes y la otra de los Obelisks. Sin embargo, los escaneos de ambas arrojan resultados interesantes: la nave Rebelde está tripulada por varios oficiales reconocibles de la Federación, y la nave Obelisk parece formar parte de la resistencia de Aenwithe... tal vez puedas convencerlos de que no luchen?"

#: src-en/data/events_sector_obelisk.xml:2017
msgid "data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[1]/text"
msgstr "No hay tiempo para mediar, ¡ayuda a la Federación!"

#: src-en/data/events_sector_obelisk.xml:2019
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[1]/event/text"
msgstr "No hay tiempo para discutir, ¡apoyarás a la Federación pase lo que pase!"

#: src-en/data/events_sector_obelisk.xml:2022
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_SPY\"]/choice[1]/event/choice/text"
