msgid "data/events_sector_obelisk.xml$//event[@name=\"ROYAL_FREEMANTIS\"]/text"
msgstr "Parece que la nave Rebel cercana ya te ha encontrado y se aproxima. Sin embargo, cuando recibes una transmisión, todo lo que escuchas del otro lado son extraños chasquidos y gorgoteos."

#: src-en/data/events_sector_obelisk.xml:1320
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_FREEMANTIS\"]/choice[1]/text"
msgstr "¡Atacarlos ahora antes de que puedan!"

#: src-en/data/events_sector_obelisk.xml:1322
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_FREEMANTIS\"]/choice[1]/event/text"
msgstr "Justo cuando comienzas a atacar, la cámara de la nave se enciende y un Free Mantis de aspecto amistoso te saluda. \"¡Hola! Traductor en nave no acostumbrado todavía. Felices de ver Federación— ¡espera qué haciendo? ¡No no detente!\" Parece que es demasiado tarde; ya te han visto como hostil y la pelea ahora es inevitable."

#: src-en/data/events_sector_obelisk.xml:1325
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_FREEMANTIS\"]/choice[1]/event/choice/text"
