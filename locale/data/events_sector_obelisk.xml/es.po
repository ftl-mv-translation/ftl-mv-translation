"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_CRYSTALS\"]/choice[3]/event/text"
msgstr "Vuelas junto al puesto avanzado, decidiendo no iniciar más conflicto en este sector ya de por sí hostil."

#: src-en/data/events_sector_obelisk.xml:2003
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ROYAL_CRYSTALS\"]/choice[3]/event/choice[1]/text"
