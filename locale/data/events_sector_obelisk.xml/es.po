#: src-en/data/events_sector_obelisk.xml:672
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/choice[1]/event/text"
msgstr "Intentas explicarles a los Obelisk cómo montar armas en su nave, pero te interrumpen. \"No, no, sabemos cómo hacer eso. La tecnología de esta cosa... es tan moderna y tan simple. No nos sirve para nada, puedes quedártela.\""

#: src-en/data/events_sector_obelisk.xml:677
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/choice[2]/text"
msgstr "No podemos ayudar."

#: src-en/data/events_sector_obelisk.xml:679
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/choice[2]/event/text"
msgstr "\"Bah, solo un ser de carne inútil. Nada significativo en ti.\""

#: src-en/data/events_sector_obelisk.xml:681
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_obelisk.xml:685
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_USELESS_WEAPON\"]/choice[2]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_sector_obelisk.xml:694
msgid "data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_LOST_DUDE\"]/text"
msgstr "Para tu sorpresa, un Obelisk en hibernación simplemente está flotando en el espacio."

#: src-en/data/events_sector_obelisk.xml:696
msgid ""
"data/events_sector_obelisk.xml$//event[@name=\"ANCIENT_LOST_DUDE\"]/choice[1]/text"
