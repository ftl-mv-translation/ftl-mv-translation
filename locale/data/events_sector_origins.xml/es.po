#: src-en/data/events_sector_origins.xml:426
msgid "data/events_sector_origins.xml$//event[@name=\"ORIGINS_FREECREW\"]/text"
msgstr "Te sorprende encontrar una nave civil quemada flotando cerca. Parece que eran turistas atacados por los cultistas, y pocos sobrevivieron. Das la bienvenida a uno de los tripulantes restantes a bordo."

#: src-en/data/events_sector_origins.xml:431
msgid "data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/text"
msgstr "Un grupo de naves sombrías se ha reunido en la superficie de un planeta cercano. Parece que están en medio de algún tipo de funeral."

#: src-en/data/events_sector_origins.xml:434
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/text"
msgstr "Escabúllete entre la multitud y mira si puedes robar algunas cosas."

#: src-en/data/events_sector_origins.xml:436
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/text"
msgstr "Aterrizas en el planeta y te deslizas entre las multitudes de cultistas. Sin embargo, un individuo te ve y te señala. \"Oye tú, dónde están tus túnicas? Se supone que debes estar aquí?\""

#: src-en/data/events_sector_origins.xml:438
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[1]/text"
msgstr "Sí, definitivamente."

#: src-en/data/events_sector_origins.xml:440
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Ah sí? Cuál es el nombre de nuestro amigo al que nos hemos reunido aquí para honrar?\""

#: src-en/data/events_sector_origins.xml:442
