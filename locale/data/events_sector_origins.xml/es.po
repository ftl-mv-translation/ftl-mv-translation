#: src-en/data/events_sector_origins.xml:522
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING_INCORRECT\"]/text"
msgstr "\"¡Ese no es su nombre! ¡Eres un impostor!\" Regresas corriendo a la nave, con varios cultistas enfurecidos y una nave hostil persiguiéndote."

#: src-en/data/events_sector_origins.xml:526
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING_INCORRECT\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_origins.xml:531
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING_CORRECT\"]/text"
msgstr "\"Oh... eh, sí, es correcto. Mis disculpas.\" Continúas y encuentras un lugar con varias naves cultistas desprotegidas, las cuales saqueas por suministros antes de regresar a la nave."

#: src-en/data/events_sector_origins.xml:536
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_BLESSED_WEAPON\"]/text"
msgstr "Un pequeño mercado cercano está siendo operado por cultistas. Afirman vender armas \"benditas\", aunque a ti solo te parecen armas Crystal normales."

#: src-en/data/events_sector_origins.xml:538
msgid ""
