msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[2]/event/text"
msgstr "Es mejor no adentrarse en las profundidades de un planeta plagado de tantos cultistas."

#: src-en/data/events_sector_origins.xml:503
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

