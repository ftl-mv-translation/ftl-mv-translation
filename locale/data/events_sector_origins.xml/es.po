#: src-en/data/events_sector_origins.xml:493
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[4]/event/text"
msgstr "Regresas corriendo a la nave y despegas antes de que los confundidos cultistas puedan hacer algo."

#: src-en/data/events_sector_origins.xml:499
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[2]/text"
