#: src-en/data/events_sector_origins.xml:548
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_BLESSED_WEAPON\"]/choice[3]/event/text"
msgstr "Benditas o no, decides que estas armas no serán útiles para tu misión."

#: src-en/data/events_sector_origins.xml:550
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_BLESSED_WEAPON\"]/choice[3]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

