#: src-en/data/events_sector_origins.xml:478
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[@req=\"rock_cultist\"]/event/text"
msgstr "\"Ah, hermano, ¡mi error! No te reconocí entre todos tus extraños amigos. ¡Que tengas un buen día!\" Continúas y encuentras un lugar con varias naves cultistas desprotegidas, las cuales saqueas por suministros antes de regresar a la nave."

#: src-en/data/events_sector_origins.xml:483
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[@req=\"unique_vortigon\"]/text"
msgstr "(Vortigon) \"Sí, troglodita.\""

#: src-en/data/events_sector_origins.xml:485
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[@req=\"unique_vortigon\"]/event/text"
msgstr "\"¡Oh cielos, Vortigon! ¡Mis-mis disculpas!\" Todos los cultistas cercanos dan un paso atrás, sorprendidos de ver a su líder contigo. Poco después comienzan a colmarte de regalos, alabando a Vortigon y a sus 'amigos.'"

#: src-en/data/events_sector_origins.xml:491
msgid ""
"data/events_sector_origins.xml$//event[@name=\"CULTIST_MOURNING\"]/choice[1]/event/choice[4]/text"
