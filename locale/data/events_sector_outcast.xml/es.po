msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_MAKESHIFT\"]/choice[@req=\"teleporter\""
" and @lvl=\"1\"]/text"
msgstr "(Teletransportador) Transporta a un tripulante para intentar liberar algunos esclavos."

#: src-en/data/events_sector_outcast.xml:936
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_MAKESHIFT\"]/choice[@req=\"teleporter\""
" and @lvl=\"2\"]/text"
msgstr "(Teletransportador Mejorado) Transporta a un tripulante para intentar liberar algunos esclavos."

#: src-en/data/events_sector_outcast.xml:938
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_MAKESHIFT\"]/choice[@req=\"teleporter\""
" and @lvl=\"2\"]/event/text"
msgstr "Tu tripulación se transporta al campamento y logra liberar a varios de los esclavos que estaban retenidos allí. Tu tripulación y los esclavos se transportan de vuelta inmediatamente antes de que los esclavistas puedan atraparlos y logras escapar sin ser detectado."

#: src-en/data/events_sector_outcast.xml:943
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_MAKESHIFT\"]/choice[4]/text"
msgstr "Ignorar el campamento de esclavos."

#: src-en/data/events_sector_outcast.xml:945
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_MAKESHIFT\"]/choice[4]/event/text"
msgstr "Se sabe que los esclavistas son peligrosos, especialmente cuando amenazas su 'carga'. Mejor no entrar en su espacio."

#: src-en/data/events_sector_outcast.xml:947
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_MAKESHIFT\"]/choice[4]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_sector_outcast.xml:951
