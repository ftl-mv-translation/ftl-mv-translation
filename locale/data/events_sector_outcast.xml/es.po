#: src-en/data/events_sector_outcast.xml:56
msgid "data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/text"
msgstr "En órbita del planeta cercano se encuentra una antigua colonia minera de la Teocracia, establecida para extraer materiales de los anillos del planeta. Ahora, parece haber sido convertida en un campamento de Outcast, donde se han reunido varios Rocks e incluso algunos agentes SSLG."

#: src-en/data/events_sector_outcast.xml:59
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/text"
msgstr "Visitar la colonia."

#: src-en/data/events_sector_outcast.xml:61
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/event/text"
msgstr "Nadie te presta mucha atención mientras atracas, por lo que es seguro asumir que están acostumbrados a los visitantes. Entras en la antesala, donde encuentras una pequeña fogata atmosférica encendida y a los residentes sentados en círculo alrededor de un Rockman alto con túnica, con franjas de pintura amarilla en los brazos, que parece estar contando historias."

#: src-en/data/events_sector_outcast.xml:63
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/event/choice[1]/text"
