#: src-en/data/events_sector_outcast.xml:65
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/event/choice[1]/event/text"
msgstr "L'esule con la veste si volta verso di te e fa un ampio sorriso. \"Stimati ospiti, perché non vi unite a noi! Siete appena in tempo per sentire le storie del Temibile Pirata Tuco! Ditemi, visto che non sembrate essere di qui, quale storia volete sentire?\" Presenta diverse opzioni."

