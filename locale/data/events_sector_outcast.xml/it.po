#: src-en/data/events_sector_outcast.xml:682
msgid "data/events_sector_outcast.xml$//event[@name=\"OUTCAST_SLAVERS_WIN\"]/text"
msgstr "\"Grazie capitano. Per un attimo, ho temuto che avresti davvero preso la parte degli schiavisti. Hai tutta la nostra gratitudine.\""

#: src-en/data/events_sector_outcast.xml:685
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_SLAVERS_WIN\"]/choice/text"
