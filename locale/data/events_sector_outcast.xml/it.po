msgid ""
"data/events_sector_outcast.xml$//eventList[@name=\"OUTCAST_PROPAGANDA_REQUEST\"]/event[1]/text"
msgstr "È difficile superare la natura testarda dei crystalline, ma riesci a convincerli a trasmettere periodicamente delle menzogne sulla tua posizione."

#: src-en/data/events_sector_outcast.xml:603
msgid ""
"data/events_sector_outcast.xml$//eventList[@name=\"OUTCAST_PROPAGANDA_REQUEST\"]/event[2]/text"
msgstr "I crystalline ti ridono in faccia. \"Questo sarà anche quello che vuoi TU, ma non è quello che vogliamo NOI. Noi vogliamo che i Ribelli se ne vadano da qui quanto prima, e più tempo passano a cercarti, più saranno una chiavica per noi.\""

#: src-en/data/events_sector_outcast.xml:605
msgid ""
"data/events_sector_outcast.xml$//eventList[@name=\"OUTCAST_PROPAGANDA_REQUEST\"]/event[2]/choice[1]/text"
