#: src-en/data/events_sector_outcast.xml:637
msgid "data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/text"
msgstr "Un piccolo villaggio di esuli sembra essere occupato da schiavisti, che hanno incatenato diversi rockman, ma stanno sparando a un gruppo di esuli che sembrano essere fuggiti."

#: src-en/data/events_sector_outcast.xml:639
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/text"
msgstr "Intervieni."

#: src-en/data/events_sector_outcast.xml:641
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/text"
msgstr "Atterri vicino e ti dirigi verso di loro, quando gli schiavisti improvvisamente lasciano cadere le armi e il loro leader si mette in ginocchio davanti a te e ti supplica. \"Ooooh, grande Capitano della Federazione, sei qui per salvarci da questi bruti crudeli! Hanno ucciso i miei uomini e non ho avuto altra scelta che massacrare le loro famiglie! È stata autodifesa! Li ho bloccati qui così che non possano uccidere nessun altro! Ti prego, ti supplico, ci aiuterai ad arrestare questi uomini e donne malvagi?\" Guardi gli esuli dall'altra parte della città, che fanno solo spallucce."

#: src-en/data/events_sector_outcast.xml:643
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/choice[1]/text"
msgstr "Aiuta gli esuli."

#: src-en/data/events_sector_outcast.xml:645
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/choice[1]/event/text"
msgstr "Questi qui non ingannano nessuno. Quando gli schiavisti vedono il loro \"trucchetto geniale\" è fallito, corrono a recuperare le armi e si preparano a combattere."

#: src-en/data/events_sector_outcast.xml:648
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/choice[1]/event/choice/text"
msgstr "Continua..."

#: src-en/data/events_sector_outcast.xml:654
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/choice[2]/text"
msgstr "Aiuta gli schiavisti."

#: src-en/data/events_sector_outcast.xml:656
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/choice[2]/event/text"
msgstr "È palese che gli schiavisti stanno mentendo, ma ciò non vuol dire che non puoi sfruttare la situazione a tuo vantaggio. Ti prepari ad affrontare i superstiti esuli."

#: src-en/data/events_sector_outcast.xml:659
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_VICTIM\"]/choice[1]/event/choice[2]/event/choice/text"
