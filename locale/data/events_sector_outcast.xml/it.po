#: src-en/data/events_sector_outcast.xml:1256
msgid "data/events_sector_outcast.xml$//event[@name=\"QUEST_SSLG_MISTAKE\"]/text"
msgstr "\"Rinnegato! Di solito non perderei tempo a contattare qualcuno come te, ma ho fatto un errore gravissimo! Avevo ricevuto delle informazioni sulla posizione di una colonia rockman. Ho detto alla nostra nave di andare a liberarla dalla Teocrazia, ma pare che sia saltato alle conclusioni. In realtà era una colonia di esuli, non della Teocrazia. Ti scongiuro, devi contattare la mia gente prima che sia troppo tardi! Devi dirgli di proteggere la colonia, non attaccarla.\""

#: src-en/data/events_sector_outcast.xml:1259
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"QUEST_SSLG_MISTAKE\"]/choice[1]/text"
msgstr "Accetta."

