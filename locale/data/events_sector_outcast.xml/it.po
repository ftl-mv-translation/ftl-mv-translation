#: src-en/data/events_sector_outcast.xml:1292
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"QUEST_SSLG_DESTINATION\"]/choice[1]/event/text"
msgstr "\"Devi pensare che siamo davvero stupidi se credevi che non lo sapessimo già. Perché credi che siamo venuti qui? Ora lasciaci in pace. Dobbiamo spezzare il giogo della Teocrazia su questo settore.\""

#: src-en/data/events_sector_outcast.xml:1294
