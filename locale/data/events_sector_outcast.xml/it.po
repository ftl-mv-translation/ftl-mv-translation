#: src-en/data/events_sector_outcast.xml:56
msgid "data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/text"
msgstr "Una vecchia colonia mineraria della Teocrazia è in orbita attorno al pianeta vicino, stabilita per estrarre materiali dai suoi anelli. Ora sembra essere stata convertita in un accampamento esule, in cui si sono radunati svariati rockman e anche alcuni agenti del GLSS."

#: src-en/data/events_sector_outcast.xml:59
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/text"
msgstr "Visita la colonia."

#: src-en/data/events_sector_outcast.xml:61
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/event/text"
msgstr "Nessuno presta attenzione alla tua nave quando attracchi, quindi presumi che siano abituati ad avere visite. Tu e la squadra entrate nell'anticamera, dove trovi un piccolo falò per fare atmosfera acceso e i residenti ci sono seduti in cerchio attorno a un rockman alto che indossa una veste e ha lance gialle dipinte sulle braccia. Sembra che stia raccontando delle storie."

#: src-en/data/events_sector_outcast.xml:63
msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_STORIES\"]/choice[1]/event/choice[1]/text"
