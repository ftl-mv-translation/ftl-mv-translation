msgid ""
"data/events_sector_outcast.xml$//event[@name=\"OUTCAST_LOSTCARGO_QUEST\"]/choice[@req=\"weapons\"]/event/choice[2]/event/choice/event/text"
msgstr "Ti ringraziano un'ultima volta e offrono un dono prima di effettuare il salto. Poco dopo, arriva il convoglio della Teocrazia, ma non appena consegni il carico, questo esplode! Ferisce mortalmente il capo dei Crociati e devasta i loro sistemi. Senza altra scelta, la Teocrazia fugge."

#: src-en/data/events_sector_outcast.xml:1219
msgid ""
