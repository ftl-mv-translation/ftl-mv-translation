#: src-en/data/events_sector_outcast.xml:607
msgid ""
"data/events_sector_outcast.xml$//eventList[@name=\"OUTCAST_PROPAGANDA_REQUEST\"]/event[2]/choice[1]/event/text"
msgstr "Il crystalline guarda i moduli e poi li prende d'istinto. \"Forse abbiamo degli interessi comuni, dopotutto...\""

#: src-en/data/events_sector_outcast.xml:615
msgid ""
"data/events_sector_outcast.xml$//eventList[@name=\"OUTCAST_PROPAGANDA_REQUEST\"]/event[2]/choice[2]/text"
