#: src-en/data/events_sector_pirate.xml:429
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/text"
msgstr "Ti sorprende vedere una nave della Federazione qui, o meglio, una non dipinta dai pirati."

#: src-en/data/events_sector_pirate.xml:432
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/text"
msgstr "Contattali."

#: src-en/data/events_sector_pirate.xml:434
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/text"
msgstr "Un capitano umano risponde alla tua trasmissione. È un po' più giovane del solito e sembra alquanto imbarazzato. \"Allora uh, anche tu stai con la Federazione? Eheh... un posticino un po' strano per incontrarci, no?\""

#: src-en/data/events_sector_pirate.xml:436
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/text"
msgstr "Accetta."

#: src-en/data/events_sector_pirate.xml:438
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Hah bene, quindi sei una persona ragionevole. Se il leader del mio squadrone mi vedesse qui... apriti cielo.\" Ridacchia nervosamente, grattandosi il collo. \"Di' un po', uh... non è che hai un po' di spazio sulla tua nave? Tipo, per un nuovo membro dell'equipaggio?\""

#: src-en/data/events_sector_pirate.xml:440
#, fuzzy
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/event/choice[1]/text"
msgstr "Ma certo."

#: src-en/data/events_sector_pirate.xml:442
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/event/choice[1]/event/text"
msgstr "Il suo volto s'illumina. \"Davvero? Cioè, posso venire con te?\" Annuisci e lui salta di gioia. \"Prendo subito le mie cose.\" Sale a bordo poco dopo, salutando il suo equipaggio. \"Mi stai facendo un favore grosso come una casa, se fossi rimasto sulla mia nave sarei stato ammonito severamente per essere qui.\""

#: src-en/data/events_sector_pirate.xml:443
#, fuzzy
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/event/choice[1]/event/crewMember"
msgstr "Calvin"

#: src-en/data/events_sector_pirate.xml:447
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/event/choice[2]/text"
msgstr "No."

#: src-en/data/events_sector_pirate.xml:449
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[1]/event/choice[2]/event/text"
msgstr "\"Oh, giusto. Dovevo immaginarlo, forse anche la tua missione dev'essere parecchio importante.\" Annuisci. \"Beh uh, allora farò meglio ad andare, devo comprare quelle provviste e andarmene da questo settore prima che mi becchino. Mi ha comunque fatto piacere vedere una faccia amica.\" Ti saluta con la mano e chiude la trasmissione."

#: src-en/data/events_sector_pirate.xml:455
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[2]/text"
msgstr "Chiedi cosa ci fanno qui."

#: src-en/data/events_sector_pirate.xml:457
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[2]/event/text"
msgstr "\"Ehi ehi, non dimentichiamo che sei qui anche tu. Stavamo uh, esaurendo le scorte e questo sembrava un buon posto per comprarne un po'.\""

#: src-en/data/events_sector_pirate.xml:459
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[2]/event/choice[1]/text"
msgstr "Accusali!"

#: src-en/data/events_sector_pirate.xml:461
msgid ""
"data/events_sector_pirate.xml$//event[@name=\"BLACKMARKET_SHEEPISH_FED\"]/choice[1]/event/choice[2]/event/choice[1]/event/text"
msgstr "\"Cosa?! Ehi, ma chi ti credi di essere?\" Menti, dicendo di essere qui per far rispettare la legge federale in questo settore. \"Ma davvero, forze dell'ordine? Stocazzo.\" Subito dopo, le loro armi si attivano e ti ritrovi in uno scontro!"

#: src-en/data/events_sector_pirate.xml:464
msgid ""
