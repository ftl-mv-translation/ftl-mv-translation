#: src-en/data/events_sector_rebel.xml:2752
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"JERRY_QUEST\"]/choice[@req=\"pilot\"]/text"
msgstr "Ignorar a los Rebeldes."

#: src-en/data/events_sector_rebel.xml:2754
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"JERRY_QUEST\"]/choice[@req=\"pilot\"]/event/text"
