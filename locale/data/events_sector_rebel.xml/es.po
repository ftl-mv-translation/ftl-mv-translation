#: src-en/data/events_sector_rebel.xml:56
msgid "data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/text"
msgstr ""
"Recibes un mensaje del único pasajero de un pequeño transbordador Rebelde. Luce desesperado, respirando con dificultad y sudando visiblemente.\n"
"“Ustedes son de la Federación, verdad? Por favor, escúchenme. Debo entregarme a su custodia. Ya no deseo estar asociado con la Rebelión. Pueden tomarme prisionero si quieren, no me importa. No estaré armado. Por favor, decidan rápido, no puedo darme el lujo de esperar.”"

#: src-en/data/events_sector_rebel.xml:58
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[1]/text"
msgstr "Acéptalo a bordo de tu nave."

#: src-en/data/events_sector_rebel.xml:60
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[1]/event/text"
msgstr "\"Gracias al cielo. No te decepcionaré.\" El Rebelde acopla rápidamente su lanzadera a tu bahía. Está completamente desarmado cuando sale de su nave. Haces desmantelar la lanzadera para obtener piezas después de que la abandona."

#: src-en/data/events_sector_rebel.xml:63
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_rebel.xml:69
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[2]/text"
msgstr "Acéptalo cautelosamente en tu nave, pero haz que lo encierren en el calabozo."

#: src-en/data/events_sector_rebel.xml:71
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[2]/event/text"
msgstr "\"Es suficiente para mí.\" El Rebelde acopla rápidamente su lanzadera a tu bahía. Sale con las manos en alto en completa rendición. Tu tripulación lo rodea y lo escolta hasta el calabozo. No opone resistencia. Haces desmantelar la lanzadera para obtener piezas después de que la abandona."

#: src-en/data/events_sector_rebel.xml:74
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[2]/event/choice/text"
