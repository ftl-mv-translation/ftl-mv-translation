#: src-en/data/events_sector_rebel.xml:106
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"MERCENARY_CHASING_REBEL_TURNCOAT\"]/text"
msgstr "Poco después de aceptar al ex-Rebelde en tu nave, una nave del Syndicate salta al sistema. Tras unos momentos, te envía un mensaje. \"No te quitaré mucho tiempo. Hay una recompensa por cierto Rebelde. Odias a los Rebeldes, verdad? Su recompensa es bastante lucrativa. Si tienes alguna información sobre su paradero, estaríamos dispuestos a darte una pequeña parte del pastel.\""

#: src-en/data/events_sector_rebel.xml:109
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"MERCENARY_CHASING_REBEL_TURNCOAT\"]/choice[1]/text"
msgstr "Entregar el Rebelde al Syndicate."

#: src-en/data/events_sector_rebel.xml:111
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"MERCENARY_CHASING_REBEL_TURNCOAT\"]/choice[1]/event/text"
msgstr "Le informas al Syndicate sobre tu prisionero Rebelde. El Syndicate teletransporta inmediatamente tropas a tu nave. El Rebelde grita e intenta huir, pero lo tienen rodeado. Tras una breve pelea, lo arrastran fuera de tu nave, dándote una pequeña cantidad de recursos por tu cooperación."

#: src-en/data/events_sector_rebel.xml:114
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"MERCENARY_CHASING_REBEL_TURNCOAT\"]/choice[1]/event/choice/text"
