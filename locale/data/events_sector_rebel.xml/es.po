"data/events_sector_rebel.xml$//event[@name=\"REBELHOLD_SPEECH\"]/choice[1]/event/text"
msgstr "Evitas todas las patrullas Rebeldes y encuentras una plataforma de aterrizaje cuyo personal no hace preguntas sobre quién eres, siempre y cuando apagues tus armas al salir. Dejas tus insignias de la Federación en la nave y sigues el tráfico hasta un gigantesco estadio."

#: src-en/data/events_sector_rebel.xml:1842
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBELHOLD_SPEECH\"]/choice[1]/event/choice/text"
