msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[@req=\"DRONE_CONTROL_BOARDING_DAMAGE\"]/text"
msgstr "(Dron de Abordaje) Haz que tu dron lo escolte al calabozo."

#: src-en/data/events_sector_rebel.xml:82
msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBEL_TURNCOAT\"]/choice[@req=\"DRONE_CONTROL_BOARDING_DAMAGE\"]/event/text"
msgstr "\"Es suficiente para mí.\" El Rebelde acopla rápidamente su lanzadera a tu bahía. Sale de la lanzadera con las manos en alto. No opone absolutamente ninguna resistencia mientras tu dron lo escolta al calabozo. Desmantelas su lanzadera para obtener piezas de repuesto."

#: src-en/data/events_sector_rebel.xml:85
msgid ""
