msgid ""
"data/events_sector_rebel.xml$//event[@name=\"REBELHOLD_SUPERFISH\"]/choice[1]/event/text"
msgstr "\"¡Oye! ¡Este era el diseño original, antes de que los idiotas del mando decidieran quedarse con el águila!\" Enfurecida, la nave ataca."

#: src-en/data/events_sector_rebel.xml:1729
msgid ""
