#: src-en/data/events_sector_republic.xml:1292
msgid ""
"data/events_sector_republic.xml$//ship[@name=\"SHIP_LEECH_FAKE_STORE\"]/deadCrew/choice[@req=\"FAKE_SHOP_TRIED_ALL\"]/event/text"
msgstr "Mientras investigas la bahía de carga de la nave del falso tendero, parece que casualmente sí tenía la primera arma que pediste. Por qué no pudo simplemente dártela?"

#: src-en/data/events_sector_republic.xml:1294
msgid ""
"data/events_sector_republic.xml$//ship[@name=\"SHIP_LEECH_FAKE_STORE\"]/deadCrew/choice[@req=\"FAKE_SHOP_TRIED_ALL\"]/event/choice/text"
