msgid ""
"data/events_sector_republic.xml$//ship[@name=\"SHIP_LEECH_FAKE_STORE\"]/destroyed/choice[@req=\"FAKE_SHOP_TRIED_ALL\"]/event/text"
msgstr "Flotando entre los restos de la nave se encuentra el arma que pediste la primera vez que estabas revisando la tienda. Por qué no pudo simplemente dártela?"

#: src-en/data/events_sector_republic.xml:1278
