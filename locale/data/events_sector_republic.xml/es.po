#: src-en/data/events_sector_republic.xml:473
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[3]/text"
msgstr "Silenciar la nave y marcharte."

#: src-en/data/events_sector_republic.xml:475
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[3]/event/text"
msgstr "Aparentemente el Slug está tan metido en su discurso que ni siquiera nota que te alejas volando."

#: src-en/data/events_sector_republic.xml:477
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[3]/event/choice[1]/text"
