"data/events_sector_republic.xml$//event[@name=\"LEECH_INQUISITIONER\"]/choice[3]/event/text"
msgstr "La nave parece demasiado lenta para seguirte incluso si te hubiera detectado, así que te escabulles rápidamente."

#: src-en/data/events_sector_republic.xml:2164
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_INQUISITIONER\"]/choice[3]/event/choice[1]/text"
