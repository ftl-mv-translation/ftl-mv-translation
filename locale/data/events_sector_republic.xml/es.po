#: src-en/data/events_sector_republic.xml:441
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/text"
msgstr "(Tripulante Leech) Tu Leech conoce la ubicación del orfanato más cercano que aún sigue en pie."

#: src-en/data/events_sector_republic.xml:443
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/event/text"
msgstr "Tu Leech te guía hasta la ubicación de uno de los últimos orfanatos en pie. Parece sorprendentemente de acuerdo con la idea de destruirlo, así que no dudas más en reducirlo a cenizas. El capitán de la Coalición estalla en una risa incontrolable."

#: src-en/data/events_sector_republic.xml:445
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_republic.xml:447
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/event/choice/event/text"
msgstr "\"De verdad lo hicissste? Ohhhh amigo, essso fue tan bueno de ver. Creo que me oriné un poco... o al menosss essspero que essso sea orina. No importa. ¡Eresss un sssuper asesino de Leechesss! Creo que iré contigo con la esssperanza de que podamos hacer esssto más a menudo...\""

#: src-en/data/events_sector_republic.xml:454
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[1]/event/choice[5]/text"
msgstr "No gracias."

#: src-en/data/events_sector_republic.xml:456
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[1]/event/choice[5]/event/text"
msgstr "\"Perdedor.\""

#: src-en/data/events_sector_republic.xml:462
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[2]/text"
msgstr "Espera, dijiste que estás matando niños?"

#: src-en/data/events_sector_republic.xml:464
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[2]/event/text"
msgstr "\"Oh demonios, olvidé que eras de la Federación. Bueno, supongo que puedo consolarme volándote en pedazos. Solo imagina que eresss un huérfano, de acuerdo?\""

#: src-en/data/events_sector_republic.xml:467
msgid ""
"data/events_sector_republic.xml$//event[@name=\"LEECH_COALITION_FEDUP\"]/choice[2]/event/choice/text"
