#: src-en/data/events_sector_separatist.xml:1417
msgid ""
"data/events_sector_separatist.xml$//event[@name=\"HARMONY_LINK_SEPARATIST\"]/text"
msgstr "Una nave Separatist está analizando el Enlace Harmony. No parecen notarte o simplemente no les importa tu presencia."

#: src-en/data/events_sector_separatist.xml:1420
msgid ""
"data/events_sector_separatist.xml$//event[@name=\"HARMONY_LINK_SEPARATIST\"]/choice[1]/text"
msgstr "Llamarlos."

#: src-en/data/events_sector_separatist.xml:1422
msgid ""
"data/events_sector_separatist.xml$//event[@name=\"HARMONY_LINK_SEPARATIST\"]/choice[1]/event/text"
msgstr "\"Sí, te -vemos-, Federación. Si deseas ser útil, tal vez podrías darnos algunos explosivos. Estamos intentando la [demolición] de los Enlaces Harmony.\""

#: src-en/data/events_sector_separatist.xml:1424
