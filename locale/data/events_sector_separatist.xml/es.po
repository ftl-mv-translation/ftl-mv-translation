msgid ""
"data/events_sector_separatist.xml$//event[@name=\"SEPARATIST_VIRUS_TRAP\"]/choice[@req=\"engi\""
" and @lvl=\"1\"]/event/text"
msgstr "Mientras abordas la nave para desguazarla, oyes un sonido proveniente de tu Engi, como si estuviera en peligro. Comienza a temblar y convulsionar, y tras un momento de confusión, tu Engi parece aceptar lo que le ha ocurrido: ¡un virus lo ha convertido en un Separatist!"

#: src-en/data/events_sector_separatist.xml:65
msgid ""
