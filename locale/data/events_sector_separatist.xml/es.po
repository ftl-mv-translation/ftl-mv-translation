#: src-en/data/events_sector_separatist.xml:99
msgid ""
"data/events_sector_separatist.xml$//eventList[@name=\"DEFUNCT_SEPARATIST_SALVAGE\"]/event[1]/text"
msgstr "La nave, en gran parte intacta, es un lucrativo botín de chatarra y recursos. Transportas el botín de regreso a tu nave sin absolutamente ninguna resistencia."

#: src-en/data/events_sector_separatist.xml:103
msgid ""
"data/events_sector_separatist.xml$//eventList[@name=\"DEFUNCT_SEPARATIST_SALVAGE\"]/event[2]/text"
msgstr "La nave, en gran parte intacta, es un lucrativo botín de chatarra y recursos. Mientras desmantelas la nave, descubres un esquema de dron funcional en la bahía de carga."

