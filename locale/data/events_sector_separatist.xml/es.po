msgid ""
"data/events_sector_separatist.xml$//event[@name=\"HARMONY_LINK_SEPARATIST\"]/choice[1]/event/choice[1]/event/choice/event/text"
msgstr "\"Vaya. Esto es bastante -inútil-. Ni siquiera podemos usar esto. Supongo que esto vale, aproximadamente, 5 de scrap.\""

#: src-en/data/events_sector_separatist.xml:1442
