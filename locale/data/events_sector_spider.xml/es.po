#: src-en/data/events_sector_spider.xml:432
msgid ""
"data/events_sector_spider.xml$//event[@name=\"INFESTATION_ORPHAN\"]/choice[1]/event/text"
msgstr "Te adentras en la cueva y no pasa mucho antes de escuchar el llanto de un niño."

#: src-en/data/events_sector_spider.xml:434
msgid ""
"data/events_sector_spider.xml$//event[@name=\"INFESTATION_ORPHAN\"]/choice[1]/event/choice[1]/text"
