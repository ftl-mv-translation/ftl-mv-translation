msgid ""
"data/events_sector_spider.xml$//event[@name=\"INFESTATION_SLAVERS\"]/choice[3]/event/text"
msgstr "Lo último que necesita la Militia es lidiar con esclavistas vendiendo arañas a otras naves. Te encargarás de estos piratas!"

#: src-en/data/events_sector_spider.xml:405
msgid ""
"data/events_sector_spider.xml$//event[@name=\"INFESTATION_SLAVERS\"]/choice[3]/event/choice/text"
msgstr "Continuar..."

