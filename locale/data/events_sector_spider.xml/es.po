msgid "data/events_sector_spider.xml$//event[@name=\"INFESTATION_ORPHAN\"]/text"
msgstr "Este sistema está vacío de naves. Por aburrimiento, realizas escaneos en el planeta cercano y descubres que tiene un extenso sistema de cuevas. Tal vez valga la pena explorarlo?"

#: src-en/data/events_sector_spider.xml:430
msgid ""
"data/events_sector_spider.xml$//event[@name=\"INFESTATION_ORPHAN\"]/choice[1]/text"
