"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[6]/event/text"
msgstr "Los Rock responden de la misma forma. \"Así sea. Si mueren, serán más muertes a manos de tu Federación!\""

#: src-en/data/events_sector_stargrove.xml:689
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[6]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_stargrove.xml:695
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[7]/text"
