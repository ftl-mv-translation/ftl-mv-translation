"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_ENGI_DEFENDER\"]/choice[@req=\"LIST_CREW_NOTHARMONY\"]/event/text"
msgstr "\"Renegado = agresor! Error, contacto fallando\" Te atacan, ¡su fuerza de combate aún parece estar al máximo!"

#: src-en/data/events_sector_stargrove.xml:1626
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_ENGI_DEFENDER\"]/choice[@req=\"LIST_CREW_NOTHARMONY\"]/event/choice/text"
