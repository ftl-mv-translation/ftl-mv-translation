#: src-en/data/events_sector_stargrove.xml:2489
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_SEPARATIST_STORE\"]/text"
msgstr "Las estrellas aquí son escasas, haciendo que esta baliza sea relativamente templada y tranquila. Una estación llena de Separatist Engi reside aquí. \"Bienvenido a p-p-p-paraíso, -forastero-. Por fin h-h-hemos encontrado un [lugar] donde ser libres de la -terrible- Harmony. Aquí, estás a salvo. Q-q-quedate aquí todo el tiempo que desees.\""

#: src-en/data/events_sector_stargrove.xml:2493
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_SEPARATIST_STORE\"]/choice[@req=\"engi_defender\"]/text"
msgstr "Tu Defender protesta contra este asentamiento de Separatists."

#: src-en/data/events_sector_stargrove.xml:2495
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_SEPARATIST_STORE\"]/choice[@req=\"engi_defender\"]/event/text"
msgstr "Al ver a tu Defender, los Separatists retroceden. \"¡Agente de l-l-la Harmony! ¡No dejaremos que [tú] pases!\""

#: src-en/data/events_sector_stargrove.xml:2498
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_SEPARATIST_STORE\"]/choice[@req=\"engi_defender\"]/event/choice/text"
