msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"DEFEAT_FED_ELITE_STARGROVE\"]/choice/event/text"
msgstr "Parece que la carga de la nave de élite de la Federación sobrevivió al combate. Dentro hay un arma funcional, que llevas a bordo."

