msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[2]/text"
msgstr "Atacar a los Rock."

#: src-en/data/events_sector_stargrove.xml:703
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[2]/event/text"
msgstr "Los Rock no dudan en defenderse. \"Insensata Federación! Aquí tenemos la ventaja!\""

#: src-en/data/events_sector_stargrove.xml:706
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_stargrove.xml:712
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[3]/text"
msgstr "Evitar la nave Rock y concentrarte en sobrevivir."

#: src-en/data/events_sector_stargrove.xml:719
msgid ""
"data/events_sector_stargrove.xml$//ship[@name=\"SHIP_ROCK_STARGROVE\"]/surrender/text"
msgstr "\"Suficiente! Solo queremos completar nuestra misión. Déjanos en paz y responderemos de la misma manera.\""

#: src-en/data/events_sector_stargrove.xml:721
msgid ""
