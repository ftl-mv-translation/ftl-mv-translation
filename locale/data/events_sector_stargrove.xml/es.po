msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[@req=\"sensors\""
" and @lvl=\"2\"]/text"
msgstr "(Sensores Mejorados) Ofrecer usar tus sensores para ayudar en su búsqueda."

#: src-en/data/events_sector_stargrove.xml:671
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[@req=\"sensors\""
" and @lvl=\"2\"]/event/text"
msgstr "Tus sensores logran reducir la cantidad de trabajo. Toma un tiempo moderado, pero finalmente guías a los Rock hacia su tripulación perdida. \"Renegado, no fuiste... inútil. Estamos dispuestos a compartir nuestras reservas contigo.\" Te envían tu recompensa."

#: src-en/data/events_sector_stargrove.xml:676
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[@req=\"sensors\""
" and @lvl=\"3\"]/text"
msgstr "(Sensores Avanzados) Ofrecer usar tus sensores para ayudar en su búsqueda."

#: src-en/data/events_sector_stargrove.xml:680
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[@req=\"ADV_SCANNERS\"]/text"
msgstr "(Escáneres de Largo Alcance) Ofrecer usar tu escáner para ayudar en su búsqueda."

#: src-en/data/events_sector_stargrove.xml:684
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"NEBULA_LIGHT_STARGROVE_THEOCRACY_RECOVERY\"]/choice[1]/event/choice[6]/text"
