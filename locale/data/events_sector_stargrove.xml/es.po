#: src-en/data/events_sector_stargrove.xml:166
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_EXIT_TUCO\"]/text"
msgstr ""
"Tuco se ríe. \"Bueno, Zirc, parece que sobreviviste a las consecuencias de ese atraco después de todo. Veo que te han ascendido.\"\n"
"\t\n"
"\t\"Oh, eres tú, 'Capitán'. Me sorprende que realmente hayas encontrado una tripulación dispuesta a soportarte.\"\n"
"\n"
"\t\"Cuál de nosotros se está pudriendo actualmente en el Infierno? ...Bueno, supongo que ambos, pero la diferencia es que yo no estoy atrapado aquí.\"\n"
"\n"
"\tEl salteador pone los ojos en blanco. \"Entiendo tu punto.\"\n"
"\n"
"\t\"Bien, qué dices? Por qué no nos dejas pasar, como un favor a tu antiguo capitán?\"\n"
"\n"
"\t\"Claro. Pero solo si me pagas todas esas bebidas que dejabas en mi cuenta. Simplemente lo añadiré al descuento que te habría dado.\""

#: src-en/data/events_sector_stargrove.xml:178
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_EXIT_TUCO\"]/choice[1]/text"
msgstr "Pagar."

#: src-en/data/events_sector_stargrove.xml:180
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_EXIT_TUCO\"]/choice[1]/event/text"
msgstr "El salteador parece sorprendido cuando le das lo que quiere. \"Bueno, Capitán, parece que la gente sí cambia. Me impresionas. No te causaré más problemas.\""

#: src-en/data/events_sector_stargrove.xml:187
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_EXIT_TUCO\"]/choice[2]/text"
msgstr "De ninguna manera."

#: src-en/data/events_sector_stargrove.xml:189
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_EXIT_TUCO\"]/choice[2]/event/text"
msgstr "\"Ja. Sabía que nunca pagarías tus deudas. Lo tomaré de tu cadáver.\""

