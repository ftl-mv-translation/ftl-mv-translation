#: src-en/data/events_sector_stargrove.xml:2504
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_SEPARATIST_STORE\"]/choice[@req=\"engi\"]/text"
msgstr "Mostrarles tu Engi."

#: src-en/data/events_sector_stargrove.xml:2506
msgid ""
"data/events_sector_stargrove.xml$//event[@name=\"STARGROVE_SEPARATIST_STORE\"]/choice[@req=\"engi\"]/event/text"
msgstr "\"A-a-al entrar en el Stargrove, d-d-debes ser -reciclado-. Podemos l-l-liberar a tu tripulación en su lugar. Dentro, o fuera?\" Apuntan sus armas hacia ti, esperando una respuesta."

#: src-en/data/events_sector_stargrove.xml:2508
