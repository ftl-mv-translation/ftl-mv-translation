#: src-en/data/events_sector_theocracy.xml:131
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_APOLOGY_INTERROGATE\"]/event[1]/text"
msgstr "\"¡HE PECADO! Yo... usé el baño... y no tenía papel higiénico... y tenía un texto sagrado cerca y... ¡OH DIOS! ¡Soy un MONSTRUO! Cómo pudiste hacerme revivir mis crímenes? ¡Eres cruel! ¡Demasiado cruel para este mundo! ¡Primero te mataré a ti, luego a mí mismo!\""

#: src-en/data/events_sector_theocracy.xml:134
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_APOLOGY_INTERROGATE\"]/event[1]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_theocracy.xml:139
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_APOLOGY_INTERROGATE\"]/event[2]/text"
msgstr "\"¡HE PECADO! Yo... usé el baño... y no tenía papel higiénico... y tenía un texto sagrado cerca y... ¡OH DIOS! ¡Soy un MONSTRUO! ¡Oh por favor, permíteme redimirme! ¡De cualquier forma que pueda, quizás haya favores que pueda cumplir para encontrar mi camino al cielo una vez más!\""

#: src-en/data/events_sector_theocracy.xml:145
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_APOLOGY_ATTACK\"]/event[1]/text"
msgstr "\"¡He cambiado de opinión! ¡Ya no deseo morir! ¡Me redimiré matándote en su lugar!\""

#: src-en/data/events_sector_theocracy.xml:148
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_APOLOGY_ATTACK\"]/event[1]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_theocracy.xml:153
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_APOLOGY_ATTACK\"]/event[2]/text"
msgstr "\"¡Oh gracias, buen capitán! ¡Solo en la muerte encontraré redención!\""

#: src-en/data/events_sector_theocracy.xml:161
msgid "data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/text"
msgstr "Un estoico Capitán Rock te contacta. \"Federación. Tengo una pregunta importante para ti. Por qué no puedes esperar perfección de los geólogos?\""

#: src-en/data/events_sector_theocracy.xml:163
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/text"
msgstr "Eh... no lo sabemos."

#: src-en/data/events_sector_theocracy.xml:165
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/text"
msgstr "\"¡Porque todos tienen FALLAS!\" Estalla en una risa intensa."

#: src-en/data/events_sector_theocracy.xml:167
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[1]/text"
msgstr "Reír en respuesta."

#: src-en/data/events_sector_theocracy.xml:169
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[1]/event/text"
msgstr "Tu risa se mezcla con la del Rockman. Después de un rato, ambos se calman. Tan agradecido de que hayas encontrado humor en su juego de palabras, el Rockman se siente obligado a regalarte algunos misiles!"

#: src-en/data/events_sector_theocracy.xml:174
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[2]/text"
msgstr "Acabar con su patética existencia."

#: src-en/data/events_sector_theocracy.xml:176
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[2]/event/text"
msgstr "\"Espera... espera, ¡detente! ¡Era solo una broma!\""

#: src-en/data/events_sector_theocracy.xml:179
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_theocracy.xml:185
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_ZOLTAN\"]/text"
msgstr "(Tripulante Zoltan) \"¡Qué sorpresa!\""

#: src-en/data/events_sector_theocracy.xml:187
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_ZOLTAN\"]/event/text"
msgstr "El Rockman queda tan impresionado por la respuesta a su propio juego de palabras que se somete, prometiendo dedicar el resto de su existencia a servirte. Siempre que pueda seguir haciendo juegos de palabras en el camino."

#: src-en/data/events_sector_theocracy.xml:188
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_ZOLTAN\"]/event/crewMember"
