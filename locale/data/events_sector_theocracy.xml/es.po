"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_ITEM_SONG_CONTEST_SEPARATIST_SONGS\"]/event[3]/text"
msgstr "Tu Separatista interpreta una pieza psicodélica altamente abstracta. El público no sabe bien qué sentir. Los jueces lo discuten animadamente, todos fingiendo entender de qué se trataba."

#: src-en/data/events_sector_theocracy.xml:761
msgid ""
"data/events_sector_theocracy.xml$//eventList[@name=\"ROCK_ITEM_SONG_CONTEST_SEPARATIST_SONGS\"]/event[3]/choice/text"
