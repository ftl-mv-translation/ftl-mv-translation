#: src-en/data/events_sector_theocracy.xml:811
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PROPHECY\"]/choice[1]/event/text"
msgstr "\"No has escuchado? La nave de un futuro mucho más brillante que el nuestro, que traerá un gran cambio! Un regalo de los altos cielos, otorgado a nosotros, hombres mortales, por los benevolentes Crystal!\""

