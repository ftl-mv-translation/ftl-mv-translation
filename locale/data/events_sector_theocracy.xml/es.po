msgstr "(Tripulante Crystal) \"Ahh, ¡qué ocurrencia!\""

#: src-en/data/events_sector_theocracy.xml:195
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_CRYSTAL\"]/event/text"
msgstr "El Rockman queda tan impresionado por la respuesta a su propio juego de palabras que se somete, prometiendo dedicar el resto de su existencia a servirte. Siempre que pueda seguir haciendo juegos de palabras en el camino."

#: src-en/data/events_sector_theocracy.xml:196
msgid ""
