#: src-en/data/events_sector_theocracy.xml:1066
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_WEAPON_MEASURING\"]/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/text"
msgstr "\"Mmm, nada mal. No muchas naves vienen aquí con tanto poder de fuego. Estoy seguro de que una nave como la tuya sabrá aprovechar un arma poderosa como esta!\""

#: src-en/data/events_sector_theocracy.xml:1069
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_WEAPON_MEASURING\"]/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/text"
msgstr "(Nivel 4 Artillería) Oh, podemos hacerlo mejor que eso."

#: src-en/data/events_sector_theocracy.xml:1071
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_WEAPON_MEASURING\"]/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/choice[@req=\"artillery\"]/event/text"
msgstr "\"Bueno, ahora solo estás presumiendo. Me gusta. Quiero probar tu arsenal. Me uniré a ti!\""

