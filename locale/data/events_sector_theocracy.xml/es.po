msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/text"
msgstr "(Tripulante Leech) \"Ese chiste apesta.\""

#: src-en/data/events_sector_theocracy.xml:203
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/event/text"
msgstr "\"Se supone que eso es un juego de palabras? No puedo decir si me estás insultando o haciendo un intento patético de unirte a mí. Odio a los Leech. ¡Fuera de mi vista!\""

#: src-en/data/events_sector_theocracy.xml:206
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[1]/event/choice[@req=\"LIST_CREW_LEECH\"]/event/choice/text"
