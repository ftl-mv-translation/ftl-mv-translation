msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_ITEM_SONG_CONTEST\"]/choice[@req=\"unique_guntput\"]/event/text"
msgstr "\"Tunt parra parra, kaethlu parra parra, spaekith parra parra, taklu parra parra! Parra maku!\" Tan pronto como la canción termina, la sala queda en silencio. Una sola roca se levanta y comienza a aplaudir, y toda la multitud se pone de pie y se une."

