#: src-en/data/events_sector_theocracy.xml:214
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[@req=\"LIST_CREW_SLUG\"]/text"
msgstr "(Tripulante Slug) Haz que tu Slug prediga la respuesta."

#: src-en/data/events_sector_theocracy.xml:216
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[@req=\"LIST_CREW_SLUG\"]/event/text"
msgstr "Tu Slug gruñe. \"Esss sssolo un esstúpido juego de palabrasss.\" Tu Slug repite la respuesta a los Rockmen. \"Porque todos tienen fallasss...\" El Rockman frunce el ceño al ver que lo predijiste y corta la transmisión."

#: src-en/data/events_sector_theocracy.xml:220
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[@req=\"BLUELIST_CREW_SNAIL\"]/text"
msgstr "(Telepático Shell) Haz que tu Shell prediga la respuesta."

#: src-en/data/events_sector_theocracy.xml:222
msgid ""
"data/events_sector_theocracy.xml$//event[@name=\"ROCK_PUNS\"]/choice[@req=\"BLUELIST_CREW_SNAIL\"]/event/text"
msgstr "Tu Shell se burla. \"Esto es un innntento increíblemente poco encantador de... comedia.\" Tu Shell repite la respuesta a los Rockmen. \"Porque todos tiennnen fallas...\" El Rockman se ríe al oírlo, sin darse cuenta de que tu Shell obtuvo la respuesta de su mente. Se siente obligado a regalarte algunos misiles por participar en sus ocurrencias."

