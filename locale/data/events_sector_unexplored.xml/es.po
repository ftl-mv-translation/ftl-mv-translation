#: src-en/data/events_sector_unexplored.xml:225
msgid ""
"data/events_sector_unexplored.xml$//event[@name=\"UNEXPLORED_FRONTIER_SLAVER\"]/text"
msgstr "Parece que hay un esclavista aquí. No es hostil de inmediato, pero si permanece en el área, los colonos serán capturados."

#: src-en/data/events_sector_unexplored.xml:228
msgid ""
"data/events_sector_unexplored.xml$//event[@name=\"UNEXPLORED_FRONTIER_SLAVER\"]/choice[1]/text"
