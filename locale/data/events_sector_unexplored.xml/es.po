#: src-en/data/events_sector_unexplored.xml:230
msgid ""
"data/events_sector_unexplored.xml$//event[@name=\"UNEXPLORED_FRONTIER_SLAVER\"]/choice[1]/event/text"
msgstr "Es probable que los colonos quieran verlo muerto, y tú estás dispuesto a ayudarlos."

#: src-en/data/events_sector_unexplored.xml:233
msgid ""
"data/events_sector_unexplored.xml$//event[@name=\"UNEXPLORED_FRONTIER_SLAVER\"]/choice[1]/event/choice/text"
