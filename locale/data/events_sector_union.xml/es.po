#: src-en/data/events_sector_union.xml:2232
msgid ""
"data/events_sector_union.xml$//event[@name=\"KESTREL_UNLOCK_QUEST_2\"]/text"
msgstr "\"No lo diré! Oh, espera. Puedes literalmente matarme ahora mismo... Esta bien, trato justo. Fuimos contratados por Hideo Tanaka, CEO de Hephaestus. Seguro has oído de él. Escuchó que Archive tenía esta gran nave elegante llamada 'Molotov' o... lo que sea. No quería que nadie más supiera que la estaba robando, así que nos contrató para hacerlo. Ya te dije todo, ahora déjanos ir!\""

#: src-en/data/events_sector_union.xml:2235
msgid ""
"data/events_sector_union.xml$//event[@name=\"KESTREL_UNLOCK_QUEST_2\"]/choice[1]/text"
msgstr "Una última cosa, dónde está la nave ahora?"

#: src-en/data/events_sector_union.xml:2237
msgid ""
"data/events_sector_union.xml$//event[@name=\"KESTREL_UNLOCK_QUEST_2\"]/choice[1]/event/text"
msgstr "\"No estabas escuchando? Está en los Astilleros de Hephaestus cercanos. Probablemente la desmantelen para transportarla o algo así.\" Logras convencer a los piratas de que te entreguen las coordenadas, y observas cómo saltan momentos después. Qué cobardes."

#: src-en/data/events_sector_union.xml:2243
msgid ""
"data/events_sector_union.xml$//event[@name=\"KESTREL_UNLOCK_QUEST_2\"]/choice[@req=\"FEDERATION_DATABASE\"]/text"
msgstr "[Base de Datos de la Federación] Quién es Hideo Tanaka?"

#: src-en/data/events_sector_union.xml:2247
