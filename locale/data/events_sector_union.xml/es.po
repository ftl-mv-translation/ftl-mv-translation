#: src-en/data/events_sector_union.xml:2455
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/beaconType/unvisitedTooltip"
msgstr "Esta es la ubicación del Cañón Gatling."

#: src-en/data/events_sector_union.xml:2457
msgid "data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/text"
msgstr "Has llegado a un activo campamento de guerra Mantis en una pequeña luna. Varias naves descansan en la superficie, siendo la más grande una Suzerain y sin duda donde se encuentra el cañón Gatling."

#: src-en/data/events_sector_union.xml:2460
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/text"
msgstr "Contactarlos e intentar negociar."

#: src-en/data/events_sector_union.xml:2462
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/text"
msgstr "Un Mantis con una larga cicatriz en el rostro responde. \"Sí? Por qué razón nave me llama?\""

#: src-en/data/events_sector_union.xml:2464
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[1]/text"
msgstr "Hemos venido por el Cañón Gatling."

#: src-en/data/events_sector_union.xml:2466
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Qué? Te refieres al palo giratorio? No atreverte a tomar palo giratorio! Preciosa reliquia heredada del abuelo, no juguete de estúpido capitán de la Federación!\""

#: src-en/data/events_sector_union.xml:2468
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[1]/event/choice/text"
msgstr "Entonces tendremos que tomarlo!"

#: src-en/data/events_sector_union.xml:2470
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[1]/event/choice/event/text"
msgstr "El Mantis chilla y corta la comunicación, y la nave Suzerain cobra vida. Se eleva para enfrentarte. Si tuvieras que adivinar, el \"palo giratorio\" está en esa nave y tendrás que eliminar a su tripulación para obtenerlo."

#: src-en/data/events_sector_union.xml:2473
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[1]/event/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:2481
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[@req=\"LIST_CREW_MANTIS\"]/text"
msgstr "(Tripulante Mantis) Negociar por el Cañón."

#: src-en/data/events_sector_union.xml:2483
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[@req=\"LIST_CREW_MANTIS\"]/event/text"
msgstr "\"No! No! No! No importa quién seas! Fuera! No bienvenido aquí.\" A pesar del berrinche del Mantis, la única opción que queda es arrebatárselo."

#: src-en/data/events_sector_union.xml:2485
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[@req=\"LIST_CREW_MANTIS\"]/event/choice/text"
msgstr "¡Atacar!"

