"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[2]/event/choice/text"
msgstr "Recoger el regalo que dejó el Lanius."

#: src-en/data/events_sector_union.xml:1675
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[3]/text"
msgstr "Darle algunos misiles."

#: src-en/data/events_sector_union.xml:1677
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[3]/event/text"
msgstr "La nave emite un mensaje que suena como un carrillón de viento. Deja un regalo y recoge los misiles que le diste. \"Entonces quería comerciar... supongo que no estábamos en peligro después de todo. Me alegra que esto se haya resuelto.\""

#: src-en/data/events_sector_union.xml:1682
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[3]/event/choice/text"
msgstr "Recoger el regalo que dejó el Lanius."

#: src-en/data/events_sector_union.xml:1690
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[4]/text"
