"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"LIST_CREW_LANIUS\"]/event/text"
msgstr "El oficial de comunicaciones de la estación parece aliviado. \"Entonces no estamos bajo ataque? Bien, salgamos a arreglarlo.\" En poco tiempo, la estación y el Lanius son separados y comienzan a comerciar, con tu Lanius actuando como intermediario. La estación paga generosamente por tu ayuda."

#: src-en/data/events_sector_union.xml:1611
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"LIST_CREW_LANIUS\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:1613
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"LIST_CREW_LANIUS\"]/event/choice/event/text"
msgstr "\"Gracias. Tener tesoro. Muy agradecido.\""

#: src-en/data/events_sector_union.xml:1620
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[4]/text"
msgstr "Atacar a la nave Lanius."

#: src-en/data/events_sector_union.xml:1622
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[4]/event/text"
msgstr "La nave continúa chillando, pero se defiende. Sin embargo, por alguna razón, no se separa, por lo que no tiene maniobrabilidad."

#: src-en/data/events_sector_union.xml:1626
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[4]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:1632
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[5]/text"
msgstr "Intentar comunicarte con el Lanius."

#: src-en/data/events_sector_union.xml:1636
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[6]/text"
