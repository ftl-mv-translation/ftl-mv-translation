#: src-en/data/events_sector_union.xml:2524
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BASE\"]/beaconType/unvisitedTooltip"
msgstr "Esta es la ubicación de la Base Gatling."

#: src-en/data/events_sector_union.xml:2526
msgid "data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BASE\"]/text"
msgstr "El cementerio en esta baliza no es exactamente lo que esperabas. En lugar de un lugar oscuro o un pantano tormentoso, parece ser un terreno plano y tranquilo cubierto de césped con tumbas de soldados caídos. No estás seguro de querer profanar estas tumbas."

#: src-en/data/events_sector_union.xml:2528
msgid ""
