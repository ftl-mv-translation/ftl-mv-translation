msgstr "Ceder a las demandas del Engi."

#: src-en/data/events_sector_union.xml:1526
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_CLINIC_HARMONY\"]/choice[1]/event/choice[8]/event/text"
msgstr "La Harmony es aliada de la Federación; decides confiar en que actúan de buena fe."

#: src-en/data/events_sector_union.xml:1528
msgid ""
