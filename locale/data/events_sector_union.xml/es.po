"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[6]/event/text"
msgstr "Tanto la nave como la estación continúan enviando señales, pero decides ignorarlas."

#: src-en/data/events_sector_union.xml:1640
