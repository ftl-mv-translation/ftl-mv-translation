msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[@req=\"LIST_CREW_MANTIS\"]/event/choice/event/text"
msgstr "El Mantis chilla y corta la comunicación, y la nave Suzerain cobra vida. Se eleva para enfrentarte. Si tuvieras que adivinar, el \"palo giratorio\" está en esa nave y tendrás que eliminar a su tripulación para obtenerlo."

#: src-en/data/events_sector_union.xml:2490
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[1]/event/choice[@req=\"LIST_CREW_MANTIS\"]/event/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:2500
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[2]/text"
msgstr "Esto es arriesgado, deberíamos irnos."

#: src-en/data/events_sector_union.xml:2502
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[2]/event/text"
msgstr "Decides no acercarte más al campamento y te mantienes lejos de la luna."

#: src-en/data/events_sector_union.xml:2504
msgid ""
"data/events_sector_union.xml$//event[@name=\"QUEST_GATLING_BARREL\"]/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

