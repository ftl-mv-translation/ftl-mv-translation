#: src-en/data/events_sector_union.xml:1651
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/text"
msgstr "El comandante de la estación contacta contigo en agradecimiento. \"Sin tu ayuda habríamos estado acabados. Por favor, acepta esto como muestra de nuestro agradecimiento. Aunque... la nave no ataca ni se va. Solo está transmitiendo un mensaje repetidamente. Qué crees que intenta decir?\""

#: src-en/data/events_sector_union.xml:1654
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[1]/text"
msgstr "Mejor dejarlo así."

#: src-en/data/events_sector_union.xml:1656
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[1]/event/text"
msgstr "La nave intenta en vano obtener una respuesta. Finalmente salta. \"Bueno, supongo que ya no tenemos que preocuparnos.\""

#: src-en/data/events_sector_union.xml:1660
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[2]/text"
msgstr "Darle algo de chatarra."

#: src-en/data/events_sector_union.xml:1662
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_LANIUS_SOLVED_NO_TRANSLATOR\"]/choice[2]/event/text"
msgstr "La nave emite un mensaje que suena como un carrillón de viento. Deja un regalo y recoge la chatarra que le diste. \"Entonces quería comerciar... supongo que no estábamos en peligro después de todo. Me alegra que esto se haya resuelto.\""

#: src-en/data/events_sector_union.xml:1667
