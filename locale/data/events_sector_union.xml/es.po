msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_OUTCAST_REFUGEES\"]/choice[@req=\"unique_tuco\"]/event/choice/event/text"
msgstr "\"¡El Temible Pirata Tuco nos ha salvado! ¡Salve a Tuco, nuestro salvador!\" Los outcasts vitorean tu nave y te colman con todo lo que pueden como tributo. Tuco se ríe mientras da un trago. \"Cuando eres así de bueno, tu reputación lo hace todo por ti.\""

#: src-en/data/events_sector_union.xml:731
