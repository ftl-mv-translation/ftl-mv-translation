msgstr "La ubicación del 'Kasparov' robado."

#: src-en/data/events_sector_union.xml:2282
msgid ""
"data/events_sector_union.xml$//event[@name=\"KESTREL_UNLOCK_RINGSHIP\"]/beaconType/visitedTooltip"
