#: src-en/data/events_sector_union.xml:1566
msgid ""
"data/events_sector_union.xml$//textList[@name=\"UNION_CLINIC_SAVED\"]/text[1]"
msgstr "\"Gracias por protegernos. Procuramos no rechazar la ayuda de quienes la ofrecen. Así es como debería practicarse la medicina.\" Uno de los médicos ofrece unirse."

#: src-en/data/events_sector_union.xml:1567
msgid ""
"data/events_sector_union.xml$//textList[@name=\"UNION_CLINIC_SAVED\"]/text[2]"
msgstr "\"Soy yo, o la Harmony se ha vuelto más... aterradora últimamente? Si no te molesta, me gustaría mostrar mi gratitud trabajando contigo.\""

#: src-en/data/events_sector_union.xml:1568
msgid ""
"data/events_sector_union.xml$//textList[@name=\"UNION_CLINIC_SAVED\"]/text[3]"
msgstr "\"De parte de todo el personal de la clínica, y en nombre de todos quienes nos visitan, muchas gracias. Por favor, llévame contigo y ayudaré en todo lo que pueda.\""

#: src-en/data/events_sector_union.xml:1574
msgid ""
"data/events_sector_union.xml$//event[@name=\"UNION_CLINIC_PROTECTED\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:1581
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/text"
msgstr "Una nave Lanius fuera de control está adherida a una estación de la Union. Tanto la nave como la estación están enviando una señal de socorro. La señal de la estación dice \"Mayday! Estamos siendo devorados por un Lanius! Por favor sálvennos!\" El Lanius, sin embargo, solo emite un chillido distorsionado."

#: src-en/data/events_sector_union.xml:1583
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"BLUELIST_BEAMS_DAMAGE\"]/text"
msgstr "(Arma de rayo dañina) Separa la nave de la estación."

#: src-en/data/events_sector_union.xml:1585
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"BLUELIST_BEAMS_DAMAGE\"]/event/text"
msgstr "Con un ataque rápido, el rayo logra separar las naves. El Lanius se desprende y se aleja de la estación sin saltar."

#: src-en/data/events_sector_union.xml:1587
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"BLUELIST_BEAMS_DAMAGE\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:1593
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"DRONE_CONTROL_BEAM_DRONE\"]/text"
msgstr "(Dron de rayo) Separa la nave de la estación."

#: src-en/data/events_sector_union.xml:1595
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"DRONE_CONTROL_BEAM_DRONE\"]/event/text"
msgstr "El drone separa con precisión la nave de la estación. El Lanius se desprende y se aleja de la estación sin saltar."

#: src-en/data/events_sector_union.xml:1600
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"DRONE_CONTROL_BEAM_DRONE\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_union.xml:1606
msgid ""
"data/events_sector_union.xml$//event[@name=\"DISTRESS_UNION_LANIUS_MISTAKE\"]/choice[@req=\"LIST_CREW_LANIUS\"]/text"
msgstr "(Tripulante Lanius) \"Nave Lanius atascada. No quiere hacer daño. Quiere comerciar por chatarra. Tiene bienes. Traductor roto.\""

#: src-en/data/events_sector_union.xml:1608
