msgstr "Un casco abandonado, con las luces apagadas y aparentemente vacío, flota cerca. No responde a tus comunicaciones."

#: src-en/data/events_sector_vagabond.xml:1047
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"NEBULA_DRIFTER_CHOICE_GHOST\"]/choice[1]/text"
