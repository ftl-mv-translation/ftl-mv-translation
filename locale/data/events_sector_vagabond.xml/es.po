"data/events_sector_vagabond.xml$//event[@name=\"NEBULA_LIGHT_GHOST_GASGIANT\"]/choice/event/choice[3]/event/text"
msgstr "\"Bien... ¡Despídete del capitán de la Federación, querida!\" El gigante gaseoso permanece en silencio, girando en la distancia mientras parece juzgarte."

#: src-en/data/events_sector_vagabond.xml:892
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"NEBULA_LIGHT_GHOST_GASGIANT\"]/choice/event/choice[3]/event/choice[1]/text"
