msgstr "Eres contactado por la nave Rock en esta baliza en cuanto llegas. Su tripulación está acurrucada en el suelo, balanceándose hacia adelante y hacia atrás. El capitán sacude la cámara violentamente, gritándote. \"¡GHOOOOSTS, GHOOOOOOOSTS! ERES UN GHOST?\""

#: src-en/data/events_sector_vagabond.xml:1104
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"NEBULA_GHOST_INSANE_ROCKMEN\"]/choice[1]/text"
msgstr "Absolutamente."

#: src-en/data/events_sector_vagabond.xml:1108
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"NEBULA_GHOST_INSANE_ROCKMEN\"]/choice[2]/text"
