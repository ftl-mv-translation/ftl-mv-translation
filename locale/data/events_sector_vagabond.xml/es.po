#: src-en/data/events_sector_vagabond.xml:173
msgid "data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/text"
msgstr "Esta baliza contiene una enorme cantidad de contaminación, con varios fragmentos de escombros atrapados en su órbita. Incluso fuera del planeta hay una concentración preocupantemente grande de basura."

#: src-en/data/events_sector_vagabond.xml:176
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/text"
msgstr "Intentar recoger algunos de los escombros."

#: src-en/data/events_sector_vagabond.xml:178
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/text"
msgstr "Comienzas a recolectar chatarra cuando una nave Vagabond te detiene. \"¡Alto! Todo aquello que no está vivo y entra en los límites de esta órbita pertenece a nuestro señor, el rey de la basura!\""

#: src-en/data/events_sector_vagabond.xml:180
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/text"
msgstr "El rey de la basura?"

#: src-en/data/events_sector_vagabond.xml:182
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"¡No nos digas que no has oído sobre el dominio del rey de la basura!\" Cuando su exclamación se encuentra con tu mirada vacía, el Ghost parece desinflarse. \"Está bien. Sígueme.\" El Ghost te guía hacia un enorme castillo construido completamente de basura, y hacia una gran sala del trono."

#: src-en/data/events_sector_vagabond.xml:184
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_vagabond.xml:186
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/choice/event/text"
msgstr "Te recibe un gran Mare Alpha que lleva una corona de papel maché que apenas logra mantenerse sobre su 'cabeza' gaseosa. \"¡Yo soy el rey de la basura! ¡Inclínate ante mí, respirador!\""

#: src-en/data/events_sector_vagabond.xml:188
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/choice/event/choice[1]/text"
msgstr "Inclinarse."

#: src-en/data/events_sector_vagabond.xml:190
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/choice/event/choice[1]/event/text"
msgstr "\"Bien. Me agradas. Si deseas abandonar este lugar con las manos llenas de mi preciada basura, deberás demostrar tu valía en combate de gladiadores.\""

#: src-en/data/events_sector_vagabond.xml:192
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/choice/event/choice[1]/event/choice[1]/text"
msgstr "Luchar contra una de sus naves más fuertes."

#: src-en/data/events_sector_vagabond.xml:194
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_TRASHKING\"]/choice[1]/event/choice[1]/event/choice/event/choice[1]/event/choice[1]/event/text"
msgstr "\"¡Un desafío! ¡Que así sea! ¡Llamen a mis campeones!\" El rey de la basura ordena que una de sus naves más fuertes luche contra ti."

