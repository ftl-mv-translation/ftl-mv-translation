msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_SEPARATISTS_OUTLAWS\"]/choice[2]/event/choice[2]/event/choice[2]/text"
msgstr "El conflicto no estaba en mi mente hoy."

#: src-en/data/events_sector_vagabond.xml:149
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_SEPARATISTS_OUTLAWS\"]/choice[2]/event/choice[2]/event/choice[2]/event/text"
msgstr "\"Hmmm. Son un grupo de mercenarios bastante extraño...\""

#: src-en/data/events_sector_vagabond.xml:157
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_SEPARATISTS_OUTLAWS\"]/choice[3]/text"
msgstr "Nos han descubierto. Irse."

#: src-en/data/events_sector_vagabond.xml:159
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"VAGABOND_SEPARATISTS_OUTLAWS\"]/choice[3]/event/text"
msgstr "No es buena idea continuar con esto cuando ya te han señalado. Te escabulles hacia las nebulosas lejanas, lejos de la baliza."

#: src-en/data/events_sector_vagabond.xml:161
