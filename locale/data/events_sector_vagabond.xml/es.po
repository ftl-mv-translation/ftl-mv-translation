#: src-en/data/events_sector_vagabond.xml:994
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"GHOST_FEDMORALITY_FINISH\"]/text"
msgstr "\"¡Buen trabajo ahí! Les mostramos a esos fenómenos gaseosos quién manda-\" la nave de la Federación es interrumpida cuando un disparo de una nave Vagabond destroza su casco en dos. \"¡Lárgate, respirador!\" Rápidamente eliminas la segunda nave Ghost, pero la nave de la Federación no durará mucho más."

#: src-en/data/events_sector_vagabond.xml:996
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"GHOST_FEDMORALITY_FINISH\"]/choice[1]/text"
msgstr "Salvar al capitán."

#: src-en/data/events_sector_vagabond.xml:998
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"GHOST_FEDMORALITY_FINISH\"]/choice[1]/event/text"
msgstr "\"G-gracias. ¡Por eso debemos respaldarnos en la Federación, esta galaxia está llena de peligros inesperados!\""

#: src-en/data/events_sector_vagabond.xml:1003
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"GHOST_FEDMORALITY_FINISH\"]/choice[2]/text"
msgstr "Es lo mejor. Déjalos morir y desguaza su nave."

#: src-en/data/events_sector_vagabond.xml:1005
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"GHOST_FEDMORALITY_FINISH\"]/choice[2]/event/text"
msgstr "Te sientes algo culpable, pero ellos tampoco estaban libres de culpa. La sangre de las muertes de hoy ahora recae solo en ti, pero deberías poder seguir adelante."

#: src-en/data/events_sector_vagabond.xml:1012
