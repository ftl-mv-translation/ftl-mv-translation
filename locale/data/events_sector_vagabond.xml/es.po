#: src-en/data/events_sector_vagabond.xml:1018
msgid ""
"data/events_sector_vagabond.xml$//event[@name=\"NEBULA_GHOST_ANGERY_SLUG\"]/choice[1]/event/text"
msgstr "\"Debería haber sabido que intentaríasss esssto. Mejor destruyo tu nave antes de que los Ghossstsss la reclamen elloss mismosss.\""

#: src-en/data/events_sector_vagabond.xml:1021
