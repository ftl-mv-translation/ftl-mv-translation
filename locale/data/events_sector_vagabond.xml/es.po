#: src-en/data/events_sector_vagabond.xml:1073
msgid ""
"data/events_sector_vagabond.xml$//eventList[@name=\"NEBULA_DRIFTER_CHOICE_GHOST_SCRAP\"]/event[2]/text"
msgstr "La nave permanece sin vida mientras desmantelas el casco."

#: src-en/data/events_sector_vagabond.xml:1079
msgid ""
"data/events_sector_vagabond.xml$//eventList[@name=\"NEBULA_DRIFTER_CHOICE_GHOST_IGNORE\"]/event[1]/text"
msgstr "Intentas ignorar los restos, pero parece que los Ghosts a bordo tienen intención de luchar. La nave cobra vida y sus armas se activan, dejándote con una sola opción: luchar."

#: src-en/data/events_sector_vagabond.xml:1082
msgid ""
"data/events_sector_vagabond.xml$//eventList[@name=\"NEBULA_DRIFTER_CHOICE_GHOST_IGNORE\"]/event[1]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_sector_vagabond.xml:1087
