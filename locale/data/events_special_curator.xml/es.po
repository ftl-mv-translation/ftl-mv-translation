msgstr "15 por un inodoro usado? ¡Absurdo!"

#: src-en/data/events_special_curator.xml:808
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_TOILET\"]/choice/event/choice/event/choice/event/choice[2]/event/text"
msgstr "\"Ya veo, ya veo. Eresss un regateador... ¡pero déjame decirte que como Sssslug no me rendiré tan fácilmente! ¡Presenta a tu mejor negociador o ríndete y paga el precio! El precio del inodoro, claro. No voy a matarte, no te preocupesss.\""

