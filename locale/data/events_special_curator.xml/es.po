#: src-en/data/events_special_curator.xml:2640
msgid "data/events_special_curator.xml$//event[@name=\"CURA_CONTRACT\"]/text"
msgstr "Has localizado la estación. Para ser una corporación relativamente reciente, Arcadia ha ascendido hasta el estatus de gigacorporación con una rapidez impresionante, pero qué más puede esperarse de una empresa respaldada por la Harmony?"

#: src-en/data/events_special_curator.xml:2643
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CONTRACT\"]/choice[1]/text"
msgstr "Sigue el consejo de C.U.R.A. y ataca primero."

#: src-en/data/events_special_curator.xml:2645
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CONTRACT\"]/choice[1]/event/text"
msgstr "Las instrucciones de la I.A. eran claras, pero algo se siente extraño cuando, entre el sonido de tu primera andanada, notas un breve mensaje de los ingenieros de la estación dándote la bienvenida a la baliza."

#: src-en/data/events_special_curator.xml:2648
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CONTRACT\"]/choice[1]/event/choice/text"
