"\t\t\t[TAREA DIFICIL - NOMBRE DEL ARTEFACTO: CRUCERO]"

#: src-en/data/events_special_curator.xml:2268
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_SHIP\"]/beaconType/visitedTooltip"
