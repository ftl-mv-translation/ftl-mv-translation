#: src-en/data/events_special_curator.xml:2340
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_SHIP_WIN\"]/choice/event/choice[5]/text"
msgstr "¡No vamos a darte un tributo!"

#: src-en/data/events_special_curator.xml:2342
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_SHIP_WIN\"]/choice/event/choice[5]/event/text"
msgstr "\"Entonces supongo que no te irás con aquello que deseabas venir a buscar! Adiós por ahora, y que cada puerta que cierres a tu paso golpee tu trasero!\""

#: src-en/data/events_special_curator.xml:2344
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_SHIP_WIN\"]/choice/event/choice[5]/event/choice/text"
