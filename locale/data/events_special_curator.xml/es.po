#: src-en/data/events_special_curator.xml:2360
msgid ""
"data/events_special_curator.xml$/FTL/event[@name=\"CURA_SHIP_SUCCESS\"]/text"
msgstr "\"Ghosts, qué alimañas. Si pudiera, me estremecería ante la posibilidad de que algún día mi chasis pueda ser infestado por esos carroñeros. Al menos has recuperado el crucero, aunque esté en un estado lamentable. Informa a los Ghosts que pasaré a recoger la nave en breve. Permitirías que exprese mis pensamientos mientras reviso esto? O tienes otros asuntos que atender?\""

#: src-en/data/events_special_curator.xml:2362
msgid ""
"data/events_special_curator.xml$/FTL/event[@name=\"CURA_SHIP_SUCCESS\"]/choice[@req=\"LIST_CHECK_ANY_CREW\""
