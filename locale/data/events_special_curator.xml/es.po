#: src-en/data/events_special_curator.xml:2332
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_SHIP_WIN\"]/choice/event/choice[@req=\"BLUELIST_WEAPONS_MIND_CONTROL\"]/event/text"
msgstr "\"Siento un gran efecto mareante... un entumecimiento como nunca antes. Mi estado aturdido, no puedo resistir... la nave es tuya, amigo. Oh, qué tonto de mi parte ser tan poco generoso.\""

#: src-en/data/events_special_curator.xml:2334
