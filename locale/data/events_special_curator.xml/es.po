#: src-en/data/events_special_curator.xml:1405
msgid "data/events_special_curator.xml$//event[@name=\"CURA_SURVIVOR\"]/text"
msgstr "Has localizado al Mantis en cuestión, pero esta no es una nave Mantis común. Es un Suzerain, y eso significa que cualquier información que quieras obtener tendrás que sacarla por la fuerza."

#: src-en/data/events_special_curator.xml:1408
msgid ""
