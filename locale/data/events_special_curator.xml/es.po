msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CRUSH\"]/choice/event/choice[1]/event/choice/event/choice[2]/text"
msgstr "Negarse."

#: src-en/data/events_special_curator.xml:683
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CRUSH\"]/choice/event/choice[1]/event/choice/event/choice[2]/event/text"
msgstr "Perez sale por la puerta y salta a un caza atracado cerca, despegando y volando hacia la distancia. El resto del personal está desconcertado por su repentina desaparición y muy sospechoso de ti, así que decides que es mejor irte inmediatamente."

#: src-en/data/events_special_curator.xml:685
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CRUSH\"]/choice/event/choice[1]/event/choice/event/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_curator.xml:695
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CRUSH\"]/choice/event/choice[2]/text"
msgstr "Sí, necesitaremos esos informes de inmediato."

#: src-en/data/events_special_curator.xml:697
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_CRUSH\"]/choice/event/choice[2]/event/text"
msgstr "Perez gruñe. \"Bien, lo que sea. Transferiré los escaneos en breve. Pero quizá deberías informar al mando que contratar a un renegado para recolectar estas cosas no es la mejor idea.\" Mientras regresas a la nave te das cuenta rápidamente de que cometiste un error: estos no eran los datos que C.U.R.A. te envió a buscar."

#: src-en/data/events_special_curator.xml:700
msgid ""
