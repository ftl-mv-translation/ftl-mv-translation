"data/events_special_curator.xml$//event[@name=\"CURA_SURVIVOR\"]/choice[1]/event/text"
msgstr "\"Pleh, renegado cree ser desafío para Tarkipet? Tú eres ser tonto! Prepárate para morir!\""

#: src-en/data/events_special_curator.xml:1413
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_SURVIVOR\"]/choice[1]/event/choice/text"
