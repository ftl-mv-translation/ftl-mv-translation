#: src-en/data/events_special_curator.xml:988
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_PLUSHIE\"]/choice/event/choice/event/choice[1]/event/text"
msgstr "\"Quieres al Sr. Snuggle Buggles? ¡Está bien, pero solo si puedes adivinar cuál es!\" La niña se ríe y se da la vuelta, dejándote con la selección de juguetes para elegir."

#: src-en/data/events_special_curator.xml:990
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_PLUSHIE\"]/choice/event/choice/event/choice[1]/event/choice[1]/text"
msgstr "Es el águila."

#: src-en/data/events_special_curator.xml:992
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_PLUSHIE\"]/choice/event/choice/event/choice[1]/event/choice[1]/event/text"
msgstr "\"¡Jajaja! ¡No! ¡Tonto, ese no es el Sr. Snuggle Buggles!\" La niña cruza los brazos fingiendo enfado, se ríe y luego vuelve a dibujar otra vez. Los milicianos se encogen de hombros, pero la niña ya ha dado su veredicto. No tienes más opción que irte a menos que quieras que las cosas se pongan feas."

#: src-en/data/events_special_curator.xml:994
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_PLUSHIE\"]/choice/event/choice/event/choice[1]/event/choice[1]/event/choice/text"
