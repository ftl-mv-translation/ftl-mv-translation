#: src-en/data/events_special_curator.xml:2201
msgid "data/events_special_curator.xml$//event[@name=\"CURA_OUTPOST_LORE\"]/text"
msgstr "\"Se considera de mal gusto leer el diario privado de alguien, verdad? Afortunadamente, según la interpretación del Sr. Wentworth, no soy un 'alguien', sino un 'algo'. Por lo tanto, encuentro permiso para continuar. Al echarle un vistazo, parece que este diario se mantuvo desde algún tiempo después del primer compromiso del Sr. Wentworth con los Mantis hasta la evacuación del búnker debido a la invasión Mantis. Está lleno de... lenguaje colorido dirigido a xenoformas. No solo los Mantis, sino también la conducta negligente de sus compañeros Zoltan y Engi. Una 'caída' poco sorprendente. Añadiré estos hallazgos a mis bases de datos y profundizaré más adelante.\""

#: src-en/data/events_special_curator.xml:2203
msgid ""
"data/events_special_curator.xml$//event[@name=\"CURA_OUTPOST_LORE\"]/choice/text"
msgstr "Continuar..."

