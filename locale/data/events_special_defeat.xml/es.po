msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_BROOD\"]/text[3]"
msgstr "La Brood ha estado causando problemas a la Milicia en este sector al usar las arañas como armas. No será mucho, pero la destrucción de esta nave aún ayudará a recuperar este territorio."

