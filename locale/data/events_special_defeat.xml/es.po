#: src-en/data/events_special_defeat.xml:1702
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DEAD_CREW_SLAVERS\"]/event[3]/text"
msgstr "Parece que los esclavos no han sobrevivido al combate. Encuentras sus cuerpos abrasados en la bodega, pero, antes de desmontar la nave, oyes un débil ruido entre las paredes. Rompes una escotilla y un esclavo sale tosiendo de un compartimento oculto. Después de recuperarse, se ofrece para unirse a tu tripulación."

#: src-en/data/events_special_defeat.xml:1707
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DEAD_CREW_SLAVERS\"]/event[4]/text"
msgstr "Escaneas la nave y no detectas signos de vida. Parece que los esclavos murieron durante el combate. Desmontas la nave y te preparas para saltar."

