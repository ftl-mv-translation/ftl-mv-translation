#: src-en/data/events_special_defeat.xml:1693
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[9]"
msgstr "\"Está claro que nos has derrotado. Tan solo te pedimos que nos dejes con vida.\""

#: src-en/data/events_special_defeat.xml:1694
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[10]"
msgstr "\"Nos has convencido. Hemos perdido. Toma esto y déjanos sumidos en la vergüenza.\""

#: src-en/data/events_special_defeat.xml:1695
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[11]"
