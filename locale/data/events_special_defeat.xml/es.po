#: src-en/data/events_special_defeat.xml:1739
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SLAVER_CHOICE_1\"]/choice[3]/event/text"
msgstr "\"Verificar objetivo primario: Derrotar a los rebeldes y restablecer paz?\" Asientes y responde: \"Aceptable\". Desmontas la nave y dejas al resto en una estación cercana."

#: src-en/data/events_special_defeat.xml:1742
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SLAVER_CHOICE_1\"]/choice[3]/event/choice/text"
