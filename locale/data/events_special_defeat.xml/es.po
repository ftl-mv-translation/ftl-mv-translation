"data/events_special_defeat.xml$//event[@name=\"DESTROYED_ESTATE_DRONES\"]/choice/event/text"
msgstr "Las piezas extra siempre son útiles, y recoges todo lo que puedes."

#: src-en/data/events_special_defeat.xml:807
