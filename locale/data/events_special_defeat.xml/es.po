msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_AUTO\"]/text[2]"
msgstr "Destruir naves automáticas será una de las pocas cosas que extrañarás cuando la Rebelión desaparezca. Si es que alguna vez desaparece."

