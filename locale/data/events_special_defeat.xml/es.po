msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_AUTO\"]/text[1]"
msgstr "Lo mejor de destruir naves automáticas es que no hay culpa de por medio. Te recuestas en tu silla y das la orden de desguazar la nave."

