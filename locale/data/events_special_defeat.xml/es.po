#: src-en/data/events_special_defeat.xml:26
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[13]"
msgstr "Niega su solicitud de salvación."

#: src-en/data/events_special_defeat.xml:27
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[14]"
msgstr "No les prestes atención y vuelve a luchar."

#: src-en/data/events_special_defeat.xml:28
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[15]"
msgstr "Deja que sus gritos de terror sean en vano."

#: src-en/data/events_special_defeat.xml:29
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[16]"
msgstr "Continúa el asalto."

#: src-en/data/events_special_defeat.xml:30
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[17]"
msgstr "Rechaza perdonarlos."

#: src-en/data/events_special_defeat.xml:31
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[18]"
msgstr "Silencia sus gritos con tus armas."

#: src-en/data/events_special_defeat.xml:32
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[19]"
msgstr "Esta batalla solo puede terminar con su muerte."

#: src-en/data/events_special_defeat.xml:33
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[20]"
msgstr "Siléncialos y continúa luchando."

#: src-en/data/events_special_defeat.xml:34
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"GENERIC_SURRENDER_CHOICE_NOMERCY\"]/text[21]"
msgstr "No vivirán para ver otro día."

#: src-en/data/events_special_defeat.xml:45
msgid "data/events_special_defeat.xml$//event[@name=\"DESTROYED_TRAPPER\"]/text"
msgstr "Mientras desguazas los restos de la nave trampera, encuentras un lanzador de minas funcional flotando entre los escombros."

#: src-en/data/events_special_defeat.xml:51
msgid "data/events_special_defeat.xml$//event[@name=\"DEAD_CREW_TRAPPER\"]/text"
msgstr "El trampero ha quedado sin tripulación. Mientras la desguazas, encuentras un lanzador de minas en su almacén."

#: src-en/data/events_special_defeat.xml:64
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REINFORCEMENTS\"]/text"
msgstr "Recoges los restos de los refuerzos, aunque no puedes quedarte mucho tiempo debido al ASB."

#: src-en/data/events_special_defeat.xml:67
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REINFORCEMENTS\"]/choice[@req=\"MAGNET_ARM\"]/text"
msgstr "(Brazo Magnetico) Obtener todavía más del naufragio."

#: src-en/data/events_special_defeat.xml:73
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REINFORCEMENTS\"]/choice[2]/text"
msgstr "Continuar..."

#: src-en/data/events_special_defeat.xml:78
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DEADCREW_REINFORCEMENTS\"]/text"
msgstr "Recoges los restos de los refuerzos, aunque no puedes quedarte mucho tiempo debido al ASB."

#: src-en/data/events_special_defeat.xml:81
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DEADCREW_REINFORCEMENTS\"]/choice[@req=\"MAGNET_ARM\"]/text"
msgstr "(Brazo Magnetico) Obtener todavía más del naufragio."

#: src-en/data/events_special_defeat.xml:87
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DEADCREW_REINFORCEMENTS\"]/choice[2]/text"
msgstr "Continuar..."

#: src-en/data/events_special_defeat.xml:128
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_UNION\"]/text[1]"
msgstr "La Union es, a los ojos de muchos, el corazón de la Federación. Disparar contra sus naves probablemente no hará mucho para mejorar la percepción pública de los renegados."

#: src-en/data/events_special_defeat.xml:129
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_UNION\"]/text[2]"
msgstr "El capitán de la Union suelta una última maldición mientras la nave se hace pedasos."

#: src-en/data/events_special_defeat.xml:130
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_UNION\"]/text[3]"
msgstr "El brillante casco rojo de la nave de la Union se dispersa en el espacio. Te abalanzas para recuperar los restos."

#: src-en/data/events_special_defeat.xml:131
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_UNION\"]/text[4]"
msgstr "La nave de la Union explota, extinguiendo toda vida en su interior. Tu tripulación evita sus restos mientras desguaza las piezas de la nave."

#: src-en/data/events_special_defeat.xml:132
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_UNION\"]/text[5]"
msgstr "Escuchas un grito con interferencias a través de las comunicaciones. El capitán de la Union se aferra al casco desmoronándose de su nave mientras esta explota, arrojándolo a él y a su tripulación al vacío del espacio."

#: src-en/data/events_special_defeat.xml:140
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_UNION\"]/text[1]"
msgstr "\"Tu sed de sangre... será tu perdición algún día, renegado. Eres solo la prueba... de que la Federación... no es mejor que la Rebelión...\""

#: src-en/data/events_special_defeat.xml:141
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_UNION\"]/text[2]"
msgstr "El capitán de la Union te saluda mientras cae de rodillas. \"Incluso en la muerte, aún te saludo. Solo espero que tu misión haya valido esta masacre. Buena suerte, carnicero.\""

#: src-en/data/events_special_defeat.xml:142
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_UNION\"]/text[3]"
msgstr "\"¡El capitalismo me ha fallado! En mis últimos momentos, me convertiré en comunista...\" El moribundo capitán de la Union reflexiona sobre su repentino cambio de opinión. \"No, al diablo con eso. Sigo siendo capitalista. Que te jodan, idiota. ¡Agghh!\""

#: src-en/data/events_special_defeat.xml:143
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_UNION\"]/text[4]"
msgstr "Sin decir palabra, el capitán de la Union cae al suelo, jadeando por aire mientras la vida se apaga de sus ojos. Desguazas el casco de su nave."

#: src-en/data/events_special_defeat.xml:144
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_UNION\"]/text[5]"
msgstr "\"¡Te arrepentirás de esto! El karma siempre regresa a personas como tú. Malditos renegados... la Union habría estado mejor con la Rebelión...\""

#: src-en/data/events_special_defeat.xml:150
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_UNION\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:160
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_UNION\"]/text[1]"
msgstr "\"¡Por favor! La Union sigue siendo parte de la Federación, ¡la misma Federación que prometiste proteger! ¡No puedes matarnos!\""

#: src-en/data/events_special_defeat.xml:161
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_UNION\"]/text[2]"
msgstr "\"¿Cómo puedes pretender ser un agente de unidad o paz cuando masacras civiles? ¡Si tienes alguna esperanza de redención, nos perdonarás de inmediato!\""

#: src-en/data/events_special_defeat.xml:162
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_UNION\"]/text[3]"
msgstr "El capitán de la Union te suplica que lo dejes vivir. \"¡Por favor, mi familia! ¡Me necesitan, soy su única fuente de ingresos! ¡Te daré todo lo que pueda si me dejas vivir!\""

#: src-en/data/events_special_defeat.xml:163
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_UNION\"]/text[4]"
msgstr "Recibes una transmisión desde otra parte de la nave de la Union, donde otro tripulante, además del capitán, habla en voz baja. \"Por favor, si dejas de disparar te daré lo que quede en la carga. Nuestro capitán es obstinado, ¡pero el resto de la tripulación no quiere morir!\""

#: src-en/data/events_special_defeat.xml:164
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_UNION\"]/text[5]"
msgstr "\"¡Oh por favor, por favor, por favor no nos mates! No le diré a nadie sobre esto, te daré todo lo que tenemos, ¡solo déjanos vivir!\""

#: src-en/data/events_special_defeat.xml:179
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_MILITIA\"]/text[1]"
msgstr "Escuchas un gruñido amenazante del capitán de la Militia mientras el casco de su nave se rompe, silenciándolo para siempre."

#: src-en/data/events_special_defeat.xml:180
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_MILITIA\"]/text[2]"
msgstr "Mientras recoges los restos de la nave de la Militia, queda claro lo excelente que era la fabricación de su nave."

#: src-en/data/events_special_defeat.xml:181
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_MILITIA\"]/text[3]"
msgstr "En una furia de chispas y explosiones, el casco de la nave de la Militia colapsa. Rápidamente desguazas los restos, que aún parecen estar en buen estado."

#: src-en/data/events_special_defeat.xml:182
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_MILITIA\"]/text[4]"
msgstr "La Militia, aunque está compuesta por una fuerza civil, sigue siendo un recurso militar competente y capaz. Derribar una de sus naves es ciertamente una hazaña."

#: src-en/data/events_special_defeat.xml:190
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_MILITIA\"]/text[1]"
msgstr "\"Yo... pero...\" El capitán de la Militia se aferra a su cuerpo moribundo, intentando racionalizar esta traición. Sin palabras finales, cae al suelo."

#: src-en/data/events_special_defeat.xml:191
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_MILITIA\"]/text[2]"
msgstr "\"Cuando acepté este trabajo, conocía los riesgos. Sabía que probablemente moriría. Solo pensé que serían Rebeldes o Piratas, no un asesino de la Federación.\""

#: src-en/data/events_special_defeat.xml:192
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_MILITIA\"]/text[3]"
msgstr "\"Bueno, supongo que nos vemos en el infierno.\" El capitán de la Militia hace un saludo burlón en sus últimos momentos."

#: src-en/data/events_special_defeat.xml:193
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_MILITIA\"]/text[4]"
msgstr "\"Para ser justos... esto estaba muy por encima de mi... nivel de pago...\" El capitán de la Militia se agarra el pecho y colapsa."

#: src-en/data/events_special_defeat.xml:199
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_MILITIA\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:209
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_MILITIA\"]/text[1]"
msgstr "\"¡Proteger y servir, mis narices! ¡Se acabó! ¡Toma todo lo que tengo y solo déjame vivir!\""

#: src-en/data/events_special_defeat.xml:210
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_MILITIA\"]/text[2]"
msgstr "\"¡Tú eres la razón por la que la Militia siquiera existe! Escuché que los renegados odian la palabra mercenario, ¡y tienes razón! ¡Solo eres un pirata común! No puedo creer que esté ondeando la bandera blanca ante un pirata...\""

#: src-en/data/events_special_defeat.xml:211
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_MILITIA\"]/text[3]"
msgstr "A regañadientes, el capitán de la Militia te contacta y ofrece rendirse si dejas a su tripulación ilesa."

#: src-en/data/events_special_defeat.xml:212
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_MILITIA\"]/text[4]"
msgstr "\"¡Y yo que pensaba que los renegados debían proteger a inocentes como yo! Si tienes algo de buena voluntad en tu sangre, nos dejarás ir.\""

#: src-en/data/events_special_defeat.xml:213
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_MILITIA\"]/text[5]"
msgstr "Parece que las comunicaciones de la nave de la Militia están fallando, pero su capitán te hace señas desesperadamente para que te detengas y levanta una hoja de papel con el símbolo de chatarra."

#: src-en/data/events_special_defeat.xml:228
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION\"]/text[1]"
msgstr "\"¡ME DIERON! ¡ME DIERON! ¡ME DI...\" El desesperado grito de auxilio del capitán de la Federación es silenciado repentinamente por la destrucción de su nave."

#: src-en/data/events_special_defeat.xml:229
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION\"]/text[2]"
msgstr "Cuando futuras naves encuentren estos restos, es probable que asuman que fue obra de Rebeldes o Piratas. Pero el rastro eventualmente llevará hasta ti."

#: src-en/data/events_special_defeat.xml:230
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION\"]/text[3]"
msgstr "Es una pena ver los modelos nuevos de la Federación ser destruidos tan rápidamente. Cuando la Federación impulsó la fabricación de diseños actualizados, pensaban en el conflicto con los Rebeldes... pero no necesariamente en sus propios renegados contratados."

#: src-en/data/events_special_defeat.xml:231
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION\"]/text[4]"
msgstr "Te invade una sensación inquietante al ver una nave de la Federación reducida a escombros, pero al menos no era la tuya."

#: src-en/data/events_special_defeat.xml:232
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION\"]/text[5]"
msgstr "Una última explosión marca el destino del capitán de la Federación mientras su nave es destrozada."

#: src-en/data/events_special_defeat.xml:240
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_FEDERATION\"]/text[1]"
msgstr "Una tripulación de la Federación ha sido abatida. Mientras desguazas su casco, notas que sus radios siguen activos, con el mando llamándolos mientras intenta entender qué está pasando. Silencias la radio y continúas."

#: src-en/data/events_special_defeat.xml:241
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_FEDERATION\"]/text[2]"
msgstr "\"¡Hombre caído, hombre caído! ¡Agghh!\" Los gritos del tripulante no son escuchados mientras cae junto al resto de su tripulación."

#: src-en/data/events_special_defeat.xml:242
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_FEDERATION\"]/text[3]"
msgstr "\"Esta muerte mía significa la muerte de la Federación.\" El capitán moribundo hace una pausa mientras alguien en el fondo le grita. \"¡NO estoy exagerando! Maldición... tenían que arruinar mis últimos momentos...\""

#: src-en/data/events_special_defeat.xml:243
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_FEDERATION\"]/text[4]"
msgstr "\"Mi nombre será grabado en un memorial por mi servicio al Multiverso... el tuyo quedará inscrito para siempre en una lista de vigilancia de criminales dementes...\""

#: src-en/data/events_special_defeat.xml:244
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_FEDERATION\"]/text[5]"
msgstr "\"Ni siquiera... obtuve mi ascenso. ¡No estoy listo para morir!\" El capitán de la Federación llora entre sus manos mientras su tripulación cae uno a uno, terminando con él."

#: src-en/data/events_special_defeat.xml:250
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_FEDERATION\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:264
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_FEDERATION\"]/text[1]"
msgstr "\"Continuar con esto sería una locura... ¡estamos del mismo lado!\""

#: src-en/data/events_special_defeat.xml:265
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_FEDERATION\"]/text[2]"
msgstr "La nave de la Federación está hecha trizas. Probablemente podrías negociar su rendición en este punto."

#: src-en/data/events_special_defeat.xml:266
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_FEDERATION\"]/text[3]"
msgstr "\"¡Por favor, no tenemos que hacer esto! ¡Estamos dispuestos a darte lo que sea para que nos dejes ir!\""

#: src-en/data/events_special_defeat.xml:267
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_FEDERATION\"]/text[4]"
msgstr "\"¡No nos destruyas! ¡Somos la Federación! ¡Al menos déjanos rendirnos!\""

#: src-en/data/events_special_defeat.xml:268
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_FEDERATION\"]/text[5]"
msgstr "\"¡Toma todo lo que tenemos, solo vete, y no tiene que derramarse más sangre!\""

#: src-en/data/events_special_defeat.xml:269
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_FEDERATION\"]/text[6]"
msgstr "La nave te contacta repetidamente, suplicando que detengas tu asalto y los dejes ir."

#: src-en/data/events_special_defeat.xml:277
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_STATION\"]/text[1]"
msgstr "\"¡ME DIERON! ¡ME DIERON! ¡ME DI-\" El desesperado grito de auxilio del capitán de la Federación es silenciado repentinamente por la destrucción de la estación."

#: src-en/data/events_special_defeat.xml:278
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_STATION\"]/text[2]"
msgstr "Cuando futuras naves encuentren estos restos, es probable que asuman que fue obra de Rebeldes o Piratas. Pero el rastro eventualmente llevará hasta ti."

#: src-en/data/events_special_defeat.xml:279
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_STATION\"]/text[3]"
msgstr "Es una pena ver los modelos nuevos de la Federación ser destruidos tan rápidamente. Cuando la Federación impulsó la fabricación de diseños actualizados, pensaban en el conflicto con los Rebeldes... pero no necesariamente en sus propios renegados contratados."

#: src-en/data/events_special_defeat.xml:294
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_AUTO\"]/text[1]"
msgstr "\"E-error: Traición.\" La nave automática explota. Sientes mucho menos remordimiento que si fuera una nave de la Federación con tripulación, pero aun así sientes algo de culpa."

#: src-en/data/events_special_defeat.xml:295
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_AUTO\"]/text[2]"
msgstr "Es mucho menos satisfactorio destruir una de las creaciones de la Federación que una de la Rebelión, pero chatarra es chatarra."

#: src-en/data/events_special_defeat.xml:296
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_AUTO\"]/text[3]"
msgstr "Mientras destruyes la nave automática, envía un último mensaje: \"Lo siento...\""

#: src-en/data/events_special_defeat.xml:297
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_FEDERATION_AUTO\"]/text[4]"
msgstr "El dron se desintegra bajo el fuego de tus armas. Bueno, al menos no era una nave llena de tripulación real de la Federación."

#: src-en/data/events_special_defeat.xml:320
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[1]"
msgstr "El rojo ardiente de las explosiones complementa el casco naranja de la nave Rebelde. Satisfecho con tu trabajo, desguazas la nave."

#: src-en/data/events_special_defeat.xml:321
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[2]"
msgstr "La nave Rebelde queda envuelta en llamas, que se extinguen casi de inmediato cuando el casco se rompe y expone el interior al vacío del espacio. Una vez que los cadáveres han sido retirados de la nave, desguazas los restos."

#: src-en/data/events_special_defeat.xml:322
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[3]"
msgstr "La nave Rebelde explota, sus numerosos sistemas vitales reducidos a simple chatarra. Chatarra que ahora es tuya."

#: src-en/data/events_special_defeat.xml:323
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[4]"
msgstr "Cada nave llena de escoria Rebelde que destruyes hace que la galaxia sea un poco más segura. No es mucho, pero es un trabajo honesto."

#: src-en/data/events_special_defeat.xml:324
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[5]"
msgstr "Recibes una transmisión de la nave Rebelde justo cuando explota, pero es demasiado tarde. El rostro del capitán suplicando por su vida aparece brevemente antes de ser consumido por el fuego frente a tus ojos."

#: src-en/data/events_special_defeat.xml:325
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[6]"
msgstr "Sabes que los Rebeldes también deben tener familias, pero probablemente no sean las mejores. O al menos, eso esperas."

#: src-en/data/events_special_defeat.xml:326
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[7]"
msgstr "Un último disparo de tus armas ha dejado inutilizable el casco de la nave Rebelde. Hay una gran cantidad de chatarra que puedes recoger."

#: src-en/data/events_special_defeat.xml:327
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[8]"
msgstr "La muerte de tus oponentes rara vez es tan satisfactoria como cuando se trata de una nave Rebelde. Por fin, tu venganza por todo el infierno que han causado a la Federación."

#: src-en/data/events_special_defeat.xml:328
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_REBEL\"]/text[9]"
msgstr "La nave Rebelde explota, dejando atrás una considerable cantidad de chatarra útil."

#: src-en/data/events_special_defeat.xml:331
msgid "data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/text"
msgstr "Justo antes de que la nave Rebelde explote, una cápsula de escape es expulsada. Desafortunadamente, no llega lejos antes de que la recojas y la subas a bordo. La abres y sacas al oficial Rebelde que está dentro. Suplica que le dejes vivir."

#: src-en/data/events_special_defeat.xml:334
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[@req=\"LIST_CREW_JERRY\"]/text"
msgstr "(Jerry) Dales la bienvenida a bordo."

#: src-en/data/events_special_defeat.xml:336
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[@req=\"LIST_CREW_JERRY\"]/event/text"
msgstr "\"Jerry? Nunca habríamos luchado si hubiéramos sabido que estabas a bordo. Sea lo que sea que esté haciendo Jerry, estaría orgulloso de ayudar.\""

#: src-en/data/events_special_defeat.xml:341
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[@req=\"LIST_CHECK_ANY_CREW\""
" and @lvl=\"1\"]/text"
msgstr "Acéptalo en tu nave."

#: src-en/data/events_special_defeat.xml:345
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[@req=\"LIST_CHECK_ANY_CREW\""
" and @lvl=\"0\"]/text"
msgstr "Aceptar al Rebelde sin medios adicionales para asegurar su lealtad es demasiado arriesgado."

#: src-en/data/events_special_defeat.xml:349
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[@req=\"mind\"]/text"
msgstr "(Control Mental) Mantén el control mental activo por si hace algo indebido."

#: src-en/data/events_special_defeat.xml:357
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[5]/text"
msgstr "Libera al Rebelde y déjalo ir."

#: src-en/data/events_special_defeat.xml:361
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[6]/text"
msgstr "Expúlsalo al espacio."

#: src-en/data/events_special_defeat.xml:363
msgid ""
"data/events_special_defeat.xml$//event[@name=\"DESTROYED_REBEL_POD\"]/choice[6]/event/text"
msgstr "Mientras sujetas al Rebelde por los brazos y lo arrastras hacia la esclusa, apenas se resiste. Una lágrima rueda por su mejilla mientras se pone erguido y acepta su destino. Cierras la esclusa una vez más cuando su cadáver ha derivado a una distancia segura de la nave."

#: src-en/data/events_special_defeat.xml:369
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_ACCEPT\"]/event[1]/text"
msgstr "El Rebelde está agradecido por perdonarle la vida, aunque eso signifique traicionar su causa original."

#: src-en/data/events_special_defeat.xml:373
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_ACCEPT\"]/event[2]/text"
msgstr "El Rebelde muestra una fachada de gratitud, que se rompe rápidamente cuando saca un láser y dispara a uno de tus tripulantes. Grita \"¡La Rebelión por siempre!\" antes de ser abatido. Arrastras el cuerpo sin vida hasta la esclusa y lo lanzas al vacío infinito del espacio."

#: src-en/data/events_special_defeat.xml:376
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_ACCEPT\"]/event[2]/removeCrew/text"
msgstr "Afortunadamente, tu tripulante fallecido ya está en proceso de clonación."

#: src-en/data/events_special_defeat.xml:382
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_MIND\"]/event[1]/text"
msgstr "El Rebelde está agradecido por perdonarle la vida, aunque eso signifique traicionar su causa original. Parece que no necesitaremos el control mental después de todo."

#: src-en/data/events_special_defeat.xml:386
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_MIND\"]/event[2]/text"
msgstr "El Rebelde muestra una fachada de gratitud, que se rompe rápidamente cuando saca un láser e intenta disparar. Por suerte, el control mental lo detiene y cae al suelo. Te apresuras a arrastrarlo hacia la esclusa."

#: src-en/data/events_special_defeat.xml:391
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_SAVE\"]/event[1]/text"
msgstr "Al principio, inseguro de si es un engaño, una vez que el Rebelde se convence de que no vas a traicionarlo, te ofrece una pequeña parte de lo que él mismo recuperó como agradecimiento. Parece que no todos los Rebeldes tienen el corazón frío."

#: src-en/data/events_special_defeat.xml:395
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_SAVE\"]/event[2]/text"
msgstr "Al principio, inseguro de si es un engaño, una vez que el Rebelde se convence de que no vas a traicionarlo, te ofrece una pequeña parte de lo que él mismo recuperó como agradecimiento. Parece que no todos los Rebeldes tienen el corazón frío."

#: src-en/data/events_special_defeat.xml:399
msgid ""
"data/events_special_defeat.xml$//eventList[@name=\"DESTROYED_REBEL_POD_SAVE\"]/event[3]/text"
msgstr "El Rebelde no te lo pone fácil, ya que continúa insultándote desde la bahía de carga hasta que lo liberas. Es casi seguro que te traicionará, pero no vas a convertirte en un asesino cuando tienes elección."

#: src-en/data/events_special_defeat.xml:409
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_REBEL\"]/text[1]"
msgstr "Por cada Rebelde que matas, te gusta pensar en todos los oficiales de la Federación y civiles que has salvado indirectamente. Otra tripulación completa de Rebeldes muerta, otra tripulación de inocentes que has salvado."

#: src-en/data/events_special_defeat.xml:410
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_REBEL\"]/text[2]"
msgstr "Cuando el capitán de la nave Rebelde cae de rodillas, te hace una señal para que te acerques. Susurra, \"Maldito... seas...\", y cae sin vida al suelo."

#: src-en/data/events_special_defeat.xml:411
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_REBEL\"]/text[3]"
msgstr "Con la nave Rebelde ahora libre de tripulación, eres libre de desguazar los restos."

#: src-en/data/events_special_defeat.xml:412
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_REBEL\"]/text[4]"
msgstr "Los gritos de la tripulación Rebelde finalmente han sido silenciados. Casi te sientes mal. Casi."

#: src-en/data/events_special_defeat.xml:413
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_REBEL\"]/text[5]"
msgstr "Mientras te desplazas por el interior de la nave Rebelde, aún puedes ver los cuerpos de los soldados temblando. Es bastante macabro, pero no sientes culpa en absoluto."

#: src-en/data/events_special_defeat.xml:414
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DEAD_CREW_REBEL\"]/text[6]"
msgstr "No sientes piedad por la ahora fallecida tripulación Rebelde, y desguazas su nave con desprecio."

#: src-en/data/events_special_defeat.xml:421
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_ESCAPE_REBEL\"]/text[1]"
msgstr "Escuchas al capitán Rebelde dando órdenes a su tripulación. \"¡Maldita sea esto! Redirijan toda la energía necesaria a los motores. ¡Tenemos que salir de aquí!\""

#: src-en/data/events_special_defeat.xml:422
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_ESCAPE_REBEL\"]/text[2]"
msgstr "Notas que los motores de la nave Rebelde se encienden con fuerza. ¡Están intentando escapar!"

#: src-en/data/events_special_defeat.xml:423
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_ESCAPE_REBEL\"]/text[3]"
msgstr "Es raro que los Rebeldes intenten huir de una batalla, pero esta nave prioriza su supervivencia."

#: src-en/data/events_special_defeat.xml:424
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_ESCAPE_REBEL\"]/text[4]"
msgstr "Puedes notar por un gran aumento en la energía de los motores enemigos que la nave está intentando escapar."

#: src-en/data/events_special_defeat.xml:437
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_GOTAWAY_REBEL\"]/text[1]"
msgstr "El capitán Rebelde se ríe mientras salta, dejándote solo en la baliza."

#: src-en/data/events_special_defeat.xml:438
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_GOTAWAY_REBEL\"]/text[2]"
msgstr "\"¡Lamentarás este día!\" La nave Rebelde salta."

#: src-en/data/events_special_defeat.xml:439
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_GOTAWAY_REBEL\"]/text[3]"
msgstr "Maldices en voz baja mientras los motores de la nave Rebelde se encienden una última vez y salta."

#: src-en/data/events_special_defeat.xml:440
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_GOTAWAY_REBEL\"]/text[4]"
msgstr "La nave Rebelde escapa. Te concentras en las reparaciones necesarias tras ese combate sin beneficios."

#: src-en/data/events_special_defeat.xml:443
msgid ""
"data/events_special_defeat.xml$//event[@name=\"GOTAWAY_REBEL_REMAINS\"]/text"
msgstr "La nave Rebelde salta. Al principio te decepcionas, pero luego te das cuenta de que una parte de chatarra ha quedado atrás tras el combate. No es mucho, pero ayuda a suavizar el golpe de tu fracaso."

#: src-en/data/events_special_defeat.xml:459
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_REBEL_GENERIC\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:468
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[1]"
msgstr "El capitán Rebelde te contacta. De fondo, puedes ver el caos que han causado tus armas. \"Está bien, ganaste. Nos rendimos.\""

#: src-en/data/events_special_defeat.xml:469
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[2]"
msgstr "Es raro que una nave Rebelde ofrezca su rendición a una de la Federación, pero este parece ser uno de esos casos."

#: src-en/data/events_special_defeat.xml:470
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[3]"
msgstr "\"¡Está bien, nos rendimos! Si tus afirmaciones de que la Federación es una fuerza tan benevolente son ciertas, ¡entonces debes aceptar nuestra rendición!\""

#: src-en/data/events_special_defeat.xml:471
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[4]"
msgstr "\"Bah, está bien. Sabiendo lo corruptos que son los oficiales de la Federación, quizás un poco de chatarra pueda convencerte de dejarnos ir?\""

#: src-en/data/events_special_defeat.xml:472
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[5]"
msgstr "La nave Rebelde está funcionando al límite. Jadeando con dificultad, el capitán Rebelde te suplica que lo dejes vivir."

#: src-en/data/events_special_defeat.xml:473
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[6]"
msgstr "\"Está bien, has demostrado que eres superior en combate. Ahora demuestra que eres tan misericordioso como dices ser.\""

#: src-en/data/events_special_defeat.xml:474
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[7]"
msgstr "Por fin, la nave Rebelde parece ceder. Ofrecen rendirse."

#: src-en/data/events_special_defeat.xml:475
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[8]"
msgstr "\"Bah, no puedo creer que esté diciendo esto a una escoria de la Federación... si te damos lo que hay en nuestro almacén, nos dejarás vivir?\""

#: src-en/data/events_special_defeat.xml:476
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[9]"
msgstr "\"¡Está bien, está bien! Ganaste. El mando nunca nos perdonará por dejarte ir, pero al menos estaremos vivos para ver cómo nos destituyen. Aceptarás nuestra rendición?\""

#: src-en/data/events_special_defeat.xml:477
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[10]"
msgstr "La nave Rebelde ya no desea luchar. Te contacta desesperadamente."

#: src-en/data/events_special_defeat.xml:478
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_GENERIC\"]/text[11]"
msgstr "\"El mando no tiene por qué saber que te encontramos aquí. Solo déjanos ir y te daremos lo que tenemos.\""

#: src-en/data/events_special_defeat.xml:483
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_REBEL_DEMAND\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:492
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_DEMAND\"]/text[1]"
msgstr "\"Esto no es una broma. Has ido demasiado lejos. Sabes quién soy? Soy vital para la Rebelión. ¡Exijo que me dejes vivir!\""

#: src-en/data/events_special_defeat.xml:493
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_DEMAND\"]/text[2]"
msgstr "La nave Rebelde te contacta. \"Se acabaron los juegos. Nos dejarás vivir o sufrirás la ira de la Rebelión.\""

#: src-en/data/events_special_defeat.xml:494
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_DEMAND\"]/text[3]"
msgstr "\"¡La Rebelión nunca morirá! Cada nave Rebelde que destruyas solo hará que tu castigo sea mayor tras nuestra inevitable victoria. Déjanos ir.\""

#: src-en/data/events_special_defeat.xml:499
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_REBEL_FLEET\"]/choice[1]/text"
msgstr "Acepta su rendición. [Retrasa la flota 2 saltos]"

#: src-en/data/events_special_defeat.xml:501
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_REBEL_DELAY\"]/text"
msgstr "Los Rebeldes prometen retrasar la flota y saltan."

#: src-en/data/events_special_defeat.xml:512
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_FLEET\"]/text[1]"
msgstr "\"Mira, mira, tal vez ambos podamos sacar algo de esto. Sé que la flota es un problema para ti. Si nos dejas vivir, podemos mentirle a la flota sobre tu ubicación. No sabrán nada hasta que sea demasiado tarde.\""

#: src-en/data/events_special_defeat.xml:513
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_FLEET\"]/text[2]"
msgstr "La nave Rebelde se rinde y promete retrasar la flota si los dejas vivir."

#: src-en/data/events_special_defeat.xml:514
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_FLEET\"]/text[3]"
msgstr "\"Si nos matas, no ganarás nada más que algo de chatarra insignificante. Somos más útiles para ti vivos. Déjanos ir y podemos retrasar la flota por ti.\""

#: src-en/data/events_special_defeat.xml:528
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_REBEL_STATION_GENERIC\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:537
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[1]"
msgstr "El capitán Rebelde te contacta. De fondo, puedes ver el caos que han causado tus armas. \"Está bien, ganaste. Nos rendimos.\""

#: src-en/data/events_special_defeat.xml:538
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[2]"
msgstr "Es raro que los Rebeldes traguen su orgullo y ofrezcan su rendición a un oponente de la Federación, pero este parece ser uno de esos casos."

#: src-en/data/events_special_defeat.xml:539
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[3]"
msgstr "\"¡Está bien, nos rendimos! Si tus afirmaciones de que la Federación es una fuerza tan benevolente son ciertas, ¡entonces debes aceptar nuestra rendición!\""

#: src-en/data/events_special_defeat.xml:540
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[4]"
msgstr "\"Bah, está bien. Sabiendo lo corruptos que son los oficiales de la Federación, quizás un poco de chatarra pueda convencerte de dejarnos en paz?\""

#: src-en/data/events_special_defeat.xml:541
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[5]"
msgstr "La estación Rebelde ha sufrido niveles catastróficos de daño. Jadeando con dificultad, el capitán Rebelde te suplica que lo dejes vivir."

#: src-en/data/events_special_defeat.xml:542
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[6]"
msgstr "\"Está bien, has demostrado que eres superior en combate. Ahora demuestra que eres tan misericordioso como dices ser.\""

#: src-en/data/events_special_defeat.xml:543
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[7]"
msgstr "Por fin, la estación Rebelde parece ceder. Ofrecen rendirse."

#: src-en/data/events_special_defeat.xml:544
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[8]"
msgstr "\"Bah, no puedo creer que esté diciendo esto a una escoria de la Federación... si te damos lo que hay en nuestro almacén, nos dejarás vivir?\""

#: src-en/data/events_special_defeat.xml:545
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[9]"
msgstr "\"¡Está bien, está bien! Ganaste. El mando nunca nos perdonará por dejarte ir, pero al menos estaremos vivos para ver cómo nos destituyen. Aceptarás nuestra rendición?\""

#: src-en/data/events_special_defeat.xml:546
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[10]"
msgstr "La estación Rebelde ya no desea luchar. Te contacta desesperadamente."

#: src-en/data/events_special_defeat.xml:547
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_STATION_GENERIC\"]/text[11]"
msgstr "\"El mando no tiene por qué saber que viniste aquí. Solo... detén el fuego y te daremos lo que tenemos.\""

#: src-en/data/events_special_defeat.xml:552
msgid ""
"data/events_special_defeat.xml$//event[@name=\"SURRENDER_REBEL_DEMAND_STATION\"]/choice[1]/text"
msgstr "Aceptar su rendición."

#: src-en/data/events_special_defeat.xml:561
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_DEMAND_STATION\"]/text[1]"
msgstr "\"Esto no es una broma. Has ido demasiado lejos. Sabes quién soy? Soy vital para la Rebelión. ¡Exijo que me dejes vivir!\""

#: src-en/data/events_special_defeat.xml:562
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_DEMAND_STATION\"]/text[2]"
msgstr "La estación Rebelde te contacta. \"Se acabaron los juegos. Nos dejarás vivir o sufrirás la ira de la Rebelión.\""

#: src-en/data/events_special_defeat.xml:563
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_REBEL_DEMAND_STATION\"]/text[3]"
msgstr "\"¡La Rebelión nunca morirá! Cada propiedad Rebelde que destruyas solo hará que tu castigo sea mayor tras nuestra inevitable victoria. Márchate ahora.\""

