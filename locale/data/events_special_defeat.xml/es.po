msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_ESTATE_MISSILES\"]/text[2]"
msgstr "\"¡No sientas culpa, desconocido despiadado! ¡Todo el dolor que sienten las naves automáticas de Wentworth Innovation al morir es solo dolor simulado! ¡Es real para mí, pero no para ti! ¡Jajaja! ¡Ja! ¡Ja! ¡Ja!...\" La nave automática explota de inmediato. La nave automática parece tener un exceso de munición entre los restos."

