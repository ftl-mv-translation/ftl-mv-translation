msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[2]"
msgstr "La nave intenta ponerse en contacto una y otra vez. Parece que quieren rendirse."

#: src-en/data/events_special_defeat.xml:1687
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[3]"
msgstr "\"Tu nave está mucho mejor armada de lo que creía. Nos rendimos.\""

#: src-en/data/events_special_defeat.xml:1688
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[4]"
msgstr "Te envían un mensaje: \"¡Hay que ver lo bien equipada que está tu nave! Te rogamos que aceptes esto y nos perdones la vida.\""

#: src-en/data/events_special_defeat.xml:1689
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[5]"
msgstr "\"Por favor, no nos mates. ¡Te daremos todo lo que tenemos!\""

#: src-en/data/events_special_defeat.xml:1690
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[6]"
msgstr "Te ofrecen parte de su cargamento si les perdonas la vida."

#: src-en/data/events_special_defeat.xml:1691
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[7]"
msgstr "Te ofrecen parte de su mercancía si no destruyes su nave."

#: src-en/data/events_special_defeat.xml:1692
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_SURRENDER_PIRATE\"]/text[8]"
