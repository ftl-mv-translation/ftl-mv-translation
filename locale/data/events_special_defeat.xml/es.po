msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_AUTO\"]/text[5]"
msgstr "Cada vez que destruyes una nave automática piensas en cómo el duro trabajo de algún obrero Rebelde ha sido desperdiciado."

