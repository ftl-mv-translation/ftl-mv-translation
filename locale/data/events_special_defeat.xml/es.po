msgid "data/events_special_defeat.xml$//event[@name=\"DESTROYED_INFESTED\"]/text"
msgstr "Te has encargado de la nave infestada. La tripulación que alguna vez la habitó ya no está, así que dudas que les importe que la desguaces ahora."

#: src-en/data/events_special_defeat.xml:1821
