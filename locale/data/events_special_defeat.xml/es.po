#: src-en/data/events_special_defeat.xml:753
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_ESTATE\"]/text[1]"
msgstr "\"Gra-gra-gra-gra-gracias por comprar con Wentworth Innovations! ¡Esperamos-esperamos-esperamos hacer negocios nuevamente!\" El tono alegre de la nave automática se ve opacado por la ruptura de su línea de combustible mientras la nave estalla en llamas."

#: src-en/data/events_special_defeat.xml:754
msgid ""
"data/events_special_defeat.xml$//textList[@name=\"TEXT_DESTROYED_ESTATE\"]/text[2]"
msgstr "\"¡No sientas culpa, desconocido despiadado! ¡Todo el dolor que sienten las naves automáticas de Wentworth Innovation al morir es solo dolor simulado! ¡Es real para mí, pero no para ti! ¡Jajaja! ¡Ja! ¡Ja! ¡Ja!...\" La nave automática explota de inmediato."

