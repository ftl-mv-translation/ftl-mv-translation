#: src-en/data/events_special_guards.xml:4878
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_GHOST_SHIP\"]/choice/event/text"
msgstr "Parece que los clanes Vagabond lograron asignar una nave para vigilar, o quizás simplemente está aquí por coincidencia. De cualquier manera, un casco lleno de Ghosts está aquí y no tienen intención de dejarte pasar."

#: src-en/data/events_special_guards.xml:4880
