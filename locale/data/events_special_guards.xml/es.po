#: src-en/data/events_special_guards.xml:6960
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/text"
msgstr "\"¡Este territorio pertenece a la Theocracy! ¡No hay lugar para las codiciosas naves de la Federación aquí!\" Esta afirmación, por supuesto, es mentira. El Tratado de Excavación Libre impide que cualquier facción haga reclamos sobre el cinturón de asteroides, pero dudas que a esta nave le importe."

#: src-en/data/events_special_guards.xml:6962
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[1]/text"
msgstr "¡Prepararte para el combate!"

#: src-en/data/events_special_guards.xml:6964
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[1]/event/text"
msgstr "Te apresuras a tomar posiciones defensivas mientras el guardia se acerca amenazantemente."

#: src-en/data/events_special_guards.xml:6967
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[1]/event/choice/text"
