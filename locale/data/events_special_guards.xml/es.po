" and @lvl=\"-999\"]/event/choice[2]/event/choice[1]/event/text"
msgstr "El guardia se ríe con desdén. \"Aquí no hay regalos, renegado. Deja de hacerme perder el tiempo y sigue adelante.\""

#: src-en/data/events_special_guards.xml:7123
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
