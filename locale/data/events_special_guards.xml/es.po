msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"orchid_caretaker\"]/event/text"
msgstr "Tu Caretaker explica su posición dentro del Gathering y solicita que los Rock les permitan pasar. El Rock responde. \"Muy bien. La Theocracy puede confiar en que los Caretakers están menos contaminados por las mentiras de la Federación. Pueden pasar.\""

#: src-en/data/events_special_guards.xml:4239
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"orchid_praetor\"]/text"
msgstr "(Tripulante Praetor) Afirmar tu derecho de paso."

#: src-en/data/events_special_guards.xml:4241
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"orchid_praetor\"]/event/text"
msgstr "Tu Praetor defiende con firmeza el derecho de paso seguro de los Orchid en este sector. Los Rock se sorprenden momentáneamente, se disculpan y te dejan pasar."

#: src-en/data/events_special_guards.xml:4245
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"unique_mayeb\"]/text"
msgstr "(Mayeb) Solicitar paso."

#: src-en/data/events_special_guards.xml:4247
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"unique_mayeb\"]/event/text"
msgstr "\"Soy Mayeb, Guardiana de Rt'lak Et. Nunca he estado en el espacio de la Theocracy, agradecería un paso seguro.\" Los Rock la observan fijamente antes de ceder, sin ofrecer más objeciones."

#: src-en/data/events_special_guards.xml:4251
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"unique_tyerel\"]/text"
msgstr "(Ty E'rel) Citar tratado."

#: src-en/data/events_special_guards.xml:4253
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"unique_tyerel\"]/event/text"
msgstr "\"Soy Ty E'rel. Según el borrador más reciente del tratado Gathering-Theocracy, soy considerado personal gubernamental de clase 2 dentro del Gathering. Cualquier acción no provocada contra mí sería considerada un acto de guerra según el Artículo 3, un crimen por el cual la Theocracy estaría obligada a condenarte a muerte.\" Ante esto, el Rock retrocede de inmediato, permitiéndote pasar sin obstáculos."

#: src-en/data/events_special_guards.xml:4257
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"NOT_TRIED_MAFAN_AT_GUARD\"]/text"
msgstr "(Mafan) Intentar convencerlos de dejarte pasar."

