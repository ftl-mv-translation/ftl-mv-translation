#: src-en/data/events_special_guards.xml:8815
msgid ""
"data/events_special_guards.xml$//event[@name=\"REINFORCEMENTS_DUSKCAP\"]/text"
msgstr "\"Renegado, ¡no eres bienvenido aquí! Durante mucho tiempo la Federación ha interferido con el destino legítimo de los Zoltan, ¡y pronto tus días estarán contados! Has matado a los nuestros a bordo de la nave guardia, ¡y ahora devolveremos el favor!\""

#: src-en/data/events_special_guards.xml:8819
