#: src-en/data/events_special_guards.xml:4929
msgid "data/events_special_guards.xml$//event[@name=\"GUARD_GHOST_DESTROY\"]/text"
msgstr "Has derrotado a la nave Vagabond. Lo que fuera que estuviera en su carga sin duda ha sido destruido, pero al menos puedes recuperar algunos suministros de la nave."

#: src-en/data/events_special_guards.xml:4932
