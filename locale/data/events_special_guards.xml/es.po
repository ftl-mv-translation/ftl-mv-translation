" and @lvl=\"-999\"]/event/choice[1]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_special_guards.xml:7113
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
" and @lvl=\"-999\"]/event/choice[2]/text"
msgstr "Contactar al guardia."

#: src-en/data/events_special_guards.xml:7115
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
" and @lvl=\"-999\"]/event/choice[2]/event/text"
msgstr "El guardia parece confundido. \"Qué más quieres? Te dije que puedes pasar sin costo.\""

#: src-en/data/events_special_guards.xml:7117
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
