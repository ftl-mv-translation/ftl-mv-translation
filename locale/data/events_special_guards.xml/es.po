#: src-en/data/events_special_guards.xml:2796
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_OUTCAST_CRIMINAL\"]/text"
msgstr "Algo parece fuera de lugar aquí. Normalmente, los Outcasts no prestarían atención a naves como la tuya, pero ahora captas comunicaciones sospechosas en la nave guardia."

#: src-en/data/events_special_guards.xml:2798
msgid ""
