#: src-en/data/events_special_guards.xml:8431
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_HUNTGROUNDS\"]/choice[@req=\"LIST_CREW_ZOLTAN\""
" and "
"@lvl=\"1\"]/event/choice[@req=\"BLUELIST_WEAPONS_MIND_AFFECT\"]/event/text"
msgstr "Tu arma confunde a varios de los Mantis, que comienzan a discutir. \"¡Eso no es Zoltan!\" \"Qué? Tú eres tonto.\" \"¡No! ¡Tú eres tonto!\" Mientras los Mantis discuten entre ellos, te alejas silenciosamente."

#: src-en/data/events_special_guards.xml:8437
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_HUNTGROUNDS\"]/choice[@req=\"pilot\""
