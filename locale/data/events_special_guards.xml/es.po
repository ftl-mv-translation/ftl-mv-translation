#: src-en/data/events_special_guards.xml:6973
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[2]/text"
msgstr "Intenta sobornarlos."

#: src-en/data/events_special_guards.xml:6975
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[2]/event/text"
msgstr "Esperas que esto sea suficiente para satisfacerlos..."

#: src-en/data/events_special_guards.xml:6980
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:6982
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[2]/event/choice/event/text"
msgstr "\"¡No seremos corrompidos por tus pecados! ¡Inténtalo cuanto quieras, no quebrantarás nuestra fortaleza! Ooh... esto es mucha chatarra...\" Los Rockmen te hacen pasar brevemente y te instan a darte prisa antes de que alguien te vea."

#: src-en/data/events_special_guards.xml:6988
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"unique_symbiote\"]/text"
msgstr "(Tintan and Rig) Rig y Tintan se unen para convencer al guardia."

#: src-en/data/events_special_guards.xml:6990
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"unique_symbiote\"]/event/text"
msgstr "Tintan tiene suficiente experiencia como enviada y Rig tiene conexiones con Zulfiqar. Afortunadamente, no se necesita mucho para convencerlos de dejarte pasar."

#: src-en/data/events_special_guards.xml:6994
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"rock\"]/text"
msgstr "(Tripulante Rock) Intenta persuadirlos para que te dejen ir."

#: src-en/data/events_special_guards.xml:6998
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"rock_crusader\"]/text"
msgstr "(Tripulante Crusader) Persuádelos para que te dejen ir."

#: src-en/data/events_special_guards.xml:7000
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"rock_crusader\"]/event/text"
msgstr "Los Rockmen nunca cuestionarían la palabra de un Crusader. No dicen nada más y te permiten pasar."

#: src-en/data/events_special_guards.xml:7004
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"rock_paladin\"]/text"
msgstr "(Tripulante Paladín) Exige entrada de inmediato."

#: src-en/data/events_special_guards.xml:7006
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"rock_paladin\"]/event/text"
msgstr "Los Rockmen quedan inmediatamente en silencio cuando tu Paladin interviene. Proceden a transferir algunos suministros y te permiten pasar."

#: src-en/data/events_special_guards.xml:7011
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"LIST_CREW_CRYSTAL\"]/text"
msgstr "(Tripulante Crystal) Intenta persuadirlos para que te dejen ir."

#: src-en/data/events_special_guards.xml:7013
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"LIST_CREW_CRYSTAL\"]/event/text"
msgstr "Los Rockmen caen de rodillas temblando de miedo al ver a tu tripulación. Sabías que los Rockmen veneraban a los Crystals, pero no sabías que era tan extremo. Con ellos distraídos, continúas avanzando."

#: src-en/data/events_special_guards.xml:7017
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"LIST_CREW_ROCK_UNFAITHFUL\"]/text"
msgstr "(Tripulante Rock Desleal) Convence a los guardias de las fallas del Anciano."

#: src-en/data/events_special_guards.xml:7019
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"LIST_CREW_ROCK_UNFAITHFUL\"]/event/text"
msgstr "Como era de esperarse, tus palabras no tienen efecto en los Rockmen. Te ignoran y continúan su ataque."

#: src-en/data/events_special_guards.xml:7022
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"LIST_CREW_ROCK_UNFAITHFUL\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:7028
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"orchid\"]/text"
msgstr "(Tripulante Orchid) Solicitar paso."

#: src-en/data/events_special_guards.xml:7032
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"orchid_caretaker\"]/text"
msgstr "(Tripulante Caretaker) Solicitar paso."

#: src-en/data/events_special_guards.xml:7034
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"orchid_caretaker\"]/event/text"
msgstr "Tu Caretaker explica su posición dentro del Gathering y solicita que los Rocks los dejen pasar. El Rock responde. \"Muy bien. La Theocracy puede confiar en que los Caretakers están menos contaminados por las mentiras de la Federación. Puedes pasar.\""

#: src-en/data/events_special_guards.xml:7038
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"orchid_praetor\"]/text"
msgstr "(Tripulante Praetor) Afirma tu derecho de paso."

#: src-en/data/events_special_guards.xml:7040
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"orchid_praetor\"]/event/text"
msgstr "Tu Praetor defiende con firmeza el derecho de paso seguro para los Orchids en este sector. Los Rocks se sorprenden momentáneamente, se disculpan y te dejan pasar."

#: src-en/data/events_special_guards.xml:7044
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"unique_mayeb\"]/text"
msgstr "(Mayeb) Solicita paso."

#: src-en/data/events_special_guards.xml:7046
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"unique_mayeb\"]/event/text"
msgstr "\"Soy Mayeb, Caretaker de Rt'lak Et. Nunca he estado en el espacio de la Theocracy, agradecería un paso seguro.\" Los Rocks la observan fijamente antes de ceder, sin ofrecer más resistencia."

#: src-en/data/events_special_guards.xml:7050
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"unique_tyerel\"]/text"
msgstr "(Ty E'rel) Cita el tratado."

#: src-en/data/events_special_guards.xml:7052
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"unique_tyerel\"]/event/text"
msgstr "\"Soy Ty E'rel. Según el borrador más reciente del tratado Gathering-Theocracy, soy considerado personal gubernamental de clase 2 bajo el Gathering. Una acción no provocada contra mí sería considerada un acto de guerra según el Artículo 3, un crimen por el cual la Theocracy estaría obligada a condenarte a muerte.\" Ante esto, el Rock retrocede de inmediato, permitiéndote pasar sin obstáculos."

#: src-en/data/events_special_guards.xml:7056
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"mind\"]/text"
msgstr "(Control Mental) Convencer al guardia para dejarte solo."

#: src-en/data/events_special_guards.xml:7060
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"BLUELIST_WEAPONS_MIND_CONTROL\"]/text"
msgstr "(Control Mental) Convencer al guardia para dejarte solo."

#: src-en/data/events_special_guards.xml:7064
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"BLUELIST_WEAPONS_MIND_AFFECT\"]/text"
msgstr "(Arma de Alteración Mental) Induce caos en el guardia y escabúllete."

#: src-en/data/events_special_guards.xml:7068
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"cloaking\"]/text"
msgstr "(Ocultación) Ocultarse e intentar escapar."

#: src-en/data/events_special_guards.xml:7072
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"engines\"]/text"
msgstr "(Motores Avanzados) Intentar escapar del guardia."

#: src-en/data/events_special_guards.xml:7076
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_ROCK\"]/choice/event/choice[@req=\"pilot\"]/text"
msgstr "(Pilotaje Avanzado) Activar el piloto automático para intentar escapar."

#: src-en/data/events_special_guards.xml:7095
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
" and @lvl=\"-999\"]/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:7097
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
" and @lvl=\"-999\"]/event/text"
msgstr "La Confederacy tiene una nave asignada para vigilar este sector. \"Según el Tratado de Excavación Libre, cualquiera que lleve la marca de la Union, Ministry, Theocracy, Republic o Confederacy puede pasar.\" El guardia Vampweed te mira. \"Como eres una nave de la Federación, la Union y el Ministry te han dado libertad total para pasar. Solo asegúrate de no interferir con ninguna propiedad de la Confederacy, de acuerdo?\""

#: src-en/data/events_special_guards.xml:7099
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_ASTEROID_VAMPWEED\"]/choice[@req=\"rep_comb_vampweed\""
