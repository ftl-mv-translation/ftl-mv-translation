#: src-en/data/events_special_guards.xml:4281
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"pilot\"]/text"
msgstr "(Pilotaje Avanzado) Activar el piloto automático para intentar escapar."

#: src-en/data/events_special_guards.xml:4287
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_ROCK_TALK\"]/event[1]/text"
msgstr "\"¡No es nuestra culpa que te hayas alejado de las palabras de los Ancianos! ¡Tu muerte aquí es consecuencia de tus propios actos!\""

#: src-en/data/events_special_guards.xml:4290
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_ROCK_TALK\"]/event[1]/choice/text"
msgstr "Continuar..."

