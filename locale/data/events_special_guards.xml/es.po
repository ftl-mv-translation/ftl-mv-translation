"data/events_special_guards.xml$//event[@name=\"GUARD_DUSKBRINGER\"]/choice[@req=\"zoltan_martyr\"]/text"
msgstr "(Tripulante Martyr) Convencer a los Duskbringers de ayudarte."

#: src-en/data/events_special_guards.xml:4475
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_DUSKBRINGER\"]/choice[@req=\"zoltan_martyr\"]/event/text"
msgstr "Tu Martyr le miente a la guardia sobre tu nave y tu misión. Aunque funciona y te dejan pasar, te preguntas por qué tu Martyr te está ayudando."

#: src-en/data/events_special_guards.xml:4480
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_DUSKBRINGER\"]/choice[@req=\"unique_devorak\"]/text"
