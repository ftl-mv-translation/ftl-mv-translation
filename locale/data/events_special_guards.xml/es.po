#: src-en/data/events_special_guards.xml:8919
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_GARDEN_SUPPORT\"]/choice[@req=\"orchid\"]/event/text"
msgstr "\"Ah, un compañero Floral. Bienvenido a casa.\" Los Praetors rebuscan lo que pueden darte y te entregan una pequeña cantidad de recursos."

#: src-en/data/events_special_guards.xml:8924
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_GARDEN_SUPPORT\"]/choice[@req=\"orchid_caretaker\"]/text"
msgstr "(Tripulante Caretaker) Solicitar asistencia."

