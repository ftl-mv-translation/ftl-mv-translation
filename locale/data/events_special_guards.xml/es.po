msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_ROCK_TALK_MAFAN\"]/event[2]/text"
msgstr "La guardia entrecierra los ojos ante Mafan. \"No estás en mi lista. La Theocracy reconoce que tus conocimientos son valiosos... pero eso no es suficiente para permitir el paso a una nave alineada con herejes.\" Aunque la guardia rechazó la solicitud de Mafan, parece que aún no son agresivos."

#: src-en/data/events_special_guards.xml:4306
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_ROCK_TALK_MAFAN\"]/event[2]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:4315
