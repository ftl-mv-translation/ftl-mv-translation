#: src-en/data/events_special_guards.xml:4220
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"LIST_CREW_ROCK_UNFAITHFUL\"]/event/text"
msgstr "Como era de esperar, tus palabras no tienen efecto en los Rock. Te ignoran y continúan su ataque."

