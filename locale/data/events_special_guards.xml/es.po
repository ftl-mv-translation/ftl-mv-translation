msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"rock_crusader\"]/text"
msgstr "(Tripulante Crusader) Persuadirlos para que te dejen pasar."

#: src-en/data/events_special_guards.xml:4201
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"rock_crusader\"]/event/text"
msgstr "Los Rock nunca cuestionarían la palabra de un Crusader Rock. No dicen nada más y te permiten pasar."

#: src-en/data/events_special_guards.xml:4205
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"rock_paladin\"]/text"
msgstr "(Tripulante Paladin) Exigir entrada de inmediato."

#: src-en/data/events_special_guards.xml:4207
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"rock_paladin\"]/event/text"
msgstr "Los Rock quedan inmediatamente en silencio cuando tu Paladin interviene. Proceden a transferir algunos suministros y te permiten pasar."

#: src-en/data/events_special_guards.xml:4212
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"LIST_CREW_CRYSTAL\"]/text"
