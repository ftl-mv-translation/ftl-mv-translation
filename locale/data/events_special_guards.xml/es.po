msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"LIST_CREW_CRYSTAL\"]/event/text"
msgstr "Los Rock caen de rodillas temblando de miedo al ver a tu tripulación. Sabías que los Rock veneraban a los Crystals, pero no que fuera a este extremo. Con ellos distraídos, continúas."

#: src-en/data/events_special_guards.xml:4218
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"LIST_CREW_ROCK_UNFAITHFUL\"]/text"
