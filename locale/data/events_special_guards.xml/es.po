#: src-en/data/events_special_guards.xml:350
msgid ""
"data/events_special_guards.xml$//textList[@name=\"TEXT_START_UNION\"]/text[1]"
msgstr "Has llegado a un sector perteneciente a la Unión Galáctica. Las promesas de la Federación de mantener estos sectores seguros no se cumplieron, y ahora los civiles han optado por establecer su propia Militia. No deberíamos ver muchos problemas aquí."

#: src-en/data/events_special_guards.xml:351
msgid ""
"data/events_special_guards.xml$//textList[@name=\"TEXT_START_UNION\"]/text[2]"
msgstr "Has llegado al espacio de la Unión. La Militia dirigida por civiles aquí es lo suficientemente competente, pero son un poco desconfiados con los desconocidos. Mantén tu identificación de la Federación lista por si acaso."

#: src-en/data/events_special_guards.xml:364
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_UNION\"]/choice[@req=\"rep_comb_union\""
" and @lvl=\"-999\"]/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:368
msgid ""
"data/events_special_guards.xml$//event[@name=\"START_UNION\"]/choice[@req=\"rep_comb_union\""
" and @lvl=\"2\"]/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:374
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_UNION_CRIMINAL\"]/text"
msgstr "Algo no parece estar bien aquí. Normalmente, la Militia no prestaría atención a naves como la tuya, pero ahora captas comunicaciones sospechosas en la nave de guardia."

#: src-en/data/events_special_guards.xml:376
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_UNION_CRIMINAL\"]/choice/text"
