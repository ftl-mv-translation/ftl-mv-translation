msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_OUTCAST_INTERACT\"]/choice[7]/text"
msgstr "Cambiar de opinión y dejar al guardia en paz."

#: src-en/data/events_special_guards.xml:2865
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_OUTCAST_INTERACT\"]/choice[7]/event/text"
msgstr "Te disculpas y cortas comunicaciones. El guardia no hace ningún otro intento para comunicarse."

#: src-en/data/events_special_guards.xml:2867
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_OUTCAST_INTERACT\"]/choice[7]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_guards.xml:2871
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_OUTCAST_INTERACT\"]/choice[7]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_special_guards.xml:2880
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_OUTCAST_REQUEST\"]/event[1]/text"
msgstr "\"Preferiría que mantuviéramos nuestras relaciones con la Federación tal como estaban previamente establecidas. Considera el regalo de seguridad en nuestras tierras como una compensación justa.\""

#: src-en/data/events_special_guards.xml:2883
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_OUTCAST_REQUEST\"]/event[2]/text"
msgstr "\"Es inusual que la Federación venga aquí, y poco característico que solicite ayuda de un pueblo con poco que ofrecer en lo material. Sin embargo, creo que las buenas acciones forman un ciclo, y aunque mis hermanos y hermanas podrían no estar de acuerdo, aceptaré tu solicitud.\""

#: src-en/data/events_special_guards.xml:2889
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_OUTCAST_DEMAND\"]/event[1]/text"
msgstr "\"¡En todo el tiempo que hemos vivido en estas tierras, la Federación nunca ha hecho tales exigencias! Por qué este día debería ser diferente? Nos insultas con tus palabras, y no somos gente que deje tales insultos sin consecuencias.\""

#: src-en/data/events_special_guards.xml:2892
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_OUTCAST_DEMAND\"]/event[1]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:2897
msgid ""
"data/events_special_guards.xml$//eventList[@name=\"GUARD_OUTCAST_DEMAND\"]/event[2]/text"
msgstr "\"Cuida lo que vas a decir. Somos gente pacífica, sí, pero venimos de lugares de gran agitación. Elegiré ignorar tu tono y ofrecerte esto, pero llévate también este consejo. Tal agresividad no te servirá de nada entre mi gente, y quizás soy un tonto por dejarte pasar.\""

#: src-en/data/events_special_guards.xml:2900
