#: src-en/data/events_special_guards.xml:4183
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[2]/event/choice/event/text"
msgstr "\"¡No seremos corrompidos por tus pecados! ¡Intenta lo que quieras, pero no quebrarás nuestra fortaleza! Oh... esto es mucha chatarra...\" Los Rock te dejan pasar brevemente y te instan a darte prisa antes de que alguien te vea."

#: src-en/data/events_special_guards.xml:4189
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"unique_symbiote\"]/text"
