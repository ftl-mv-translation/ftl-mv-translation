#: src-en/data/events_special_guards.xml:4233
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"orchid_caretaker\"]/text"
msgstr "(Tripulante Caretaker) Solicitar paso."

