#: src-en/data/events_special_guards.xml:4191
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_ROCK\"]/choice[@req=\"unique_symbiote\"]/event/text"
msgstr "Tintan tiene experiencia como emisario y Rig tiene conexiones con Zulfiqar. Afortunadamente, no hace falta mucho para convencerlos de dejarte entrar."

#: src-en/data/events_special_guards.xml:4195
