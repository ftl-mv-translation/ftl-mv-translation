#: src-en/data/events_special_guards.xml:15
msgid ""
"data/events_special_guards.xml$//textList[@name=\"TEXT_GUARD_SIGNAL\"]/text[1]"
msgstr "¡Parece que la nave de guardia está enviando una señal de socorro a una plataforma ASB cercana! ¡Prepárate para el impacto!"

#: src-en/data/events_special_guards.xml:16
msgid ""
"data/events_special_guards.xml$//textList[@name=\"TEXT_GUARD_SIGNAL\"]/text[2]"
msgstr "Los escáneres muestran que la guardia ha enviado una solicitud de refuerzos desde un sistema de defensa ASB. Eso no pinta bien…"

#: src-en/data/events_special_guards.xml:17
msgid ""
"data/events_special_guards.xml$//textList[@name=\"TEXT_GUARD_SIGNAL\"]/text[3]"
msgstr "Captas comunicaciones en la otra nave, mencionando algo sobre una señal solicitando refuerzos del ASB. Parece que podríamos tener otro peligro del que preocuparnos."

#: src-en/data/events_special_guards.xml:22
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_SIGNAL\"]/choice[@req=\"PDS_DISABLE\"]/text"
msgstr "(Diluidor de Señal) Interferir su señal."

#: src-en/data/events_special_guards.xml:24
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_SIGNAL\"]/choice[@req=\"PDS_DISABLE\"]/event/text"
msgstr "Al no activarse ningún ASB, asumes que es una buena señal de que tu aumento ha funcionado correctamente, y continúas luchando."

#: src-en/data/events_special_guards.xml:28
