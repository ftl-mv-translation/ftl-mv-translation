msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:4937
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_GHOST_DEADCREW\"]/text"
msgstr "Has derrotado a la nave Vagabond. Sin tripulación a bordo para detenerte, puedes investigar su carga. Encuentras un arma para llevar de vuelta a la nave y continúas desmantelando su casco."

#: src-en/data/events_special_guards.xml:4941
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_GHOST_DEADCREW\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_guards.xml:4949
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_GHOST_FOLLOWUP\"]/text"
msgstr "Al matar a la improvisada guardia Vagabond, probablemente has enfurecido a los otros clanes aquí. Probablemente no estarán muy contentos contigo después de esto."

#: src-en/data/events_special_guards.xml:4952
msgid ""
"data/events_special_guards.xml$//event[@name=\"GUARD_GHOST_FOLLOWUP\"]/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

