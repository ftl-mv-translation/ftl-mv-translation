#: src-en/data/events_special_multiverse.xml:10
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_NEW\"]/text"
msgstr "Antes de subir a bordo, sin embargo, el Lizard comienza a entonar un canto, bailando en círculos. ‘Tunt parra parra, kaethlu parra parra, spaekith parra parra, taklu parra parra! Parra maku!’ Al terminar, hace una pausa y te mira."

#: src-en/data/events_special_multiverse.xml:12
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_NEW\"]/choice/text"
