msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"cloaking\"]/event/text"
msgstr "\"¡Camuflaje! Para las naves más sigilosas. ¡Carga tus armas - escóndete del peligro! Algunos te llamarían cobarde, ¡pero Corby n-n-no lo cree! ¡Corby cree que eres inteligente! Por esto, con gran orgullo te otorgo: Concesión de Camuflaje! ¡Concesión de Camuflaje! ¡Atesórala! Guárdala - para el futuro!\""

