"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_STANDARD\"]/choice[10]/event/text"
msgstr "\"Tal vez en otro momento, desssconocido! Estoy seguro de que esta no será la última vez que nos veamos, en esta realidad o en otra.\""

