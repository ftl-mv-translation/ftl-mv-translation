#: src-en/data/events_special_multiverse.xml:2976
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER_STORY\"]/choice[2]/event/text"
msgstr "\"Está bien, desssconocido. Al menos pareces confiar en tu nave!\""

#: src-en/data/events_special_multiverse.xml:2978
