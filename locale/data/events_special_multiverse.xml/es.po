#: src-en/data/events_special_multiverse.xml:84
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_GUNTPUT_NEW\"]/text"
msgstr "\"Federación. Has hecho un buen servicio para mi gente. No preveo... un buen futuro para ellos. Pero aun así es mejor que en el campo de trabajo de Hektar por el resto de sus días. No iré con ellos. Les he fallado. Te serviré en su lugar, en los esfuerzos por salvar la realidad y algún día liberar al resto de mi gente.\" Mientras Guntput sube a bordo de tu nave, levanta su lanza y la sacude dos veces, entonando una extraña canción mientras baila en círculos. \"Tunt parra parra, kaethlu parra parra, spaekith parra parra, taklu parra parra! ¡Parra maku!\" Al terminar, se detiene y te mira."

#: src-en/data/events_special_multiverse.xml:86
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_GUNTPUT_NEW\"]/choice/text"
msgstr "Que estas haciendo?"

#: src-en/data/events_special_multiverse.xml:88
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_GUNTPUT_NEW\"]/choice/event/text"
msgstr "\"Esta es la Canción de Abrir Puerta. La cultura de los lizards incluye muchas danzas y cantos. De la misma forma en que ustedes tocan una puerta para entrar, nosotros bailamos la Canción de Abrir Puerta. Es una canción tanto para solicitar una entrada fiel como para dar gracias por concederla. Muy sagrada, muy importante.\""

#: src-en/data/events_special_multiverse.xml:91
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_GUNTPUT_NEW\"]/choice/event/choice[1]/text"
msgstr "Permitir subir a bordo."

#: src-en/data/events_special_multiverse.xml:93
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_GUNTPUT_NEW\"]/choice/event/choice[1]/event/text"
msgstr "\"Muy bien. Seré un buen huésped. Pero no me decepciones, como yo he decepcionado a mi gente.\""

#: src-en/data/events_special_multiverse.xml:95
