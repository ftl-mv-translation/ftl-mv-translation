"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_A55\"]/choice/event/choice/event/text"
msgstr "\"¡Corby es p-p-p-perfectamente consciente de quién eres! Pero... pero... ¡no puedo explicarlo! El credo me lo prohíbe. ¡Me lo prohíbe! Oh bueno. Verte me ha dado esperanza. ¡Corby se disculpa por la i-i-i-interrupción! ¡Interrupción! Reanudando actividades previas: ahora.\""

#: src-en/data/events_special_multiverse.xml:1011
