"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_A55\"]/choice/event/text"
msgstr "Te giras hacia A55, esperando que sepa qué está pasando, pero él está igual de confundido. \"Lo siento, muchacha, pero no recuerdo haberte visto antes. Soy el Capitán A5540L3, IA y rey pirata, espadachín y ahora aparentemente un eh... héroe interdimensional.\""

#: src-en/data/events_special_multiverse.xml:1007
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_A55\"]/choice/event/choice/text"
