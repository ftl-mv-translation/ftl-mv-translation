#: src-en/data/events_special_multiverse.xml:4572
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"SYLVAN_STATUS\"]/text"
msgstr "\"Aaaaah. Desssconocido desssconocido, qué es un pequeño crimen de guerra durante una guerra, eh? Tengo mis tentáculoss sobre nueva tecnología, ven a echar un vistazo!\""

#: src-en/data/events_special_multiverse.xml:4582
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"SYLVAN_UTILITY\"]/text"
msgstr "\"Aaaaah. Desssconocido desssconocido, no todas las armass tienen que sser para matar. Ssé que probablemente no estésss de acuerdo, pero ohhh desssconocido, tengo algunass armas de apoyo que podrían interessarte.\""

#: src-en/data/events_special_multiverse.xml:4592
msgid "data/events_special_multiverse.xml$/FTL/event[@name=\"SYLVAN_RACE\"]/text"
msgstr "\"Aaaaah. Desssconocido desssconocido, estuve en varios sectores recientemente, recogí algunas armas raras que podrían interesarte.\""

#: src-en/data/events_special_multiverse.xml:4602
