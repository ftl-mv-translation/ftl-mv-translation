#: src-en/data/events_special_multiverse.xml:2999
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/text"
msgstr "Has llegado a las coordenadas que Sylvan te dio. A lo lejos puedes ver una enorme y extraña nave alienígena..."

#: src-en/data/events_special_multiverse.xml:3002
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/text"
msgstr "Acercarse."

#: src-en/data/events_special_multiverse.xml:3004
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/text"
msgstr "Mientras te acercas, un enorme pirata Rock pasa volando, su casco adornado con todo tipo de extrañas extremidades alienígenas. \"Tú. Tú eres amigo de Sylvan, creo yo. Quién más vendría a mi lugar, buscando tomar recompensa que pertenece a TREMOR EL TERRIBLE? NO TIENES MIEDO, PEQUEÑO HOMBRE?\""

#: src-en/data/events_special_multiverse.xml:3007
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[1]/text"
msgstr "No particularmente."

#: src-en/data/events_special_multiverse.xml:3009
