#: src-en/data/events_special_multiverse.xml:1168
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"sensors\"]/text"
msgstr "Presenta tu subsistema de Sensores."

#: src-en/data/events_special_multiverse.xml:1170
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"sensors\"]/event/text"
msgstr "\"Sensores - esenciales p-p-para la plena percepción de tu nave... y del enemigo. Corby ve pocos capitanes que inviertan en sensores. ¡Elección audaz! Aprecio tu diversidad. Por esto, te otorgo: Concesión de Sensores. ¡Concesión de Sensores! Guárdala - para el futuro!\""

#: src-en/data/events_special_multiverse.xml:1174
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"sensors\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1180
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"doors\"]/text"
msgstr "Presenta tu subsistema de Puertas."

#: src-en/data/events_special_multiverse.xml:1182
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"doors\"]/event/text"
msgstr "\"Control de puertas - quien controla las puertas - ¡controla el espacio! ¡El espacio! Eso es lo que me dijeron, es decir... Exclusas: la clave para el control de abordaje. Esto - lo sé. Para ti, te otorgo: Concesión de Puertas. ¡C-c-c-concesión de Puertas! Guárdala - para el futuro!\""

#: src-en/data/events_special_multiverse.xml:1186
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"doors\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1192
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"pilot\"]/text"
msgstr "Presenta tu subsistema de Pilotaje."

#: src-en/data/events_special_multiverse.xml:1194
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"pilot\"]/event/text"
msgstr "\"Pilotaje - esencial: ninguna nave está completa sin él! Pero tu pilotaje es: fuerte! ¡Fuerte! Creo que esto = bueno. Corby... no le gusta desperdiciar dinero - pero está segura de que s-s-s-sabes lo que haces! Te otorgo: Concesión de Pilotaje. ¡Concesión de Pilotaje! Guárdala - para el futuro!\""

#: src-en/data/events_special_multiverse.xml:1198
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"pilot\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1204
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"battery\"]/text"
msgstr "Presenta tu subsistema de Batería."

#: src-en/data/events_special_multiverse.xml:1206
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"battery\"]/event/text"
msgstr "\"Batería - a menudo olvido que esto existe. ¡Pero tú no! A Corby le gusta cuando capitanes audaces invierten en tecnología avanzada. ¡Tecnología avanzada! Aceptaré este tributo. Te otorgo: Concesión de Batería. ¡Concesión de B-b-b-batería! Guárdala - para el futuro!\""

#: src-en/data/events_special_multiverse.xml:1210
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"battery\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1216
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"reactor\"]/text"
msgstr "Presenta tu reactor."

#: src-en/data/events_special_multiverse.xml:1218
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"reactor\"]/event/text"
msgstr "\"Oh-oh-oh por... tu Reactor es enorme! ¡Enorme! Tantas mejoras, tanta energía! Corby apenas puede c-c-c-controlar su emoción... eh... disculpas. Sí, este es un gran tributo. Por esto, te otorgo: Concesión de Energía. ¡Concesión de Energía! Guárdala - para el futuro!\""

#: src-en/data/events_special_multiverse.xml:1222
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"reactor\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1228
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[18]/text"
msgstr "No tenemos nada que mostrar."

#: src-en/data/events_special_multiverse.xml:1230
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[18]/event/text"
msgstr "\"Nada? Nada?! ¡Eso está bien! Corby entiende. ¡Regresarás y me traerás un mejor tributo la próxima vez! Estoy segura. ¡Adiós! ¡Adiós!\""

#: src-en/data/events_special_multiverse.xml:1242
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[1]"
msgstr "\"Tu cúmulo es: hermoso! ¡Hermoso! Eso es lo que yo creo! Thest está: inseguro. ¡Wakeson escéptico! ¡Escéptico! ¡Pero Corby sabe m-m-mejor! Procesador vocal fallando, pero el procesador óptico funcionando al 100%! ¡Tanta tecnología! ¡Tanta maravilla! ¡Visítame de nuevo, por favor! Quiero ver más. ¡Más!\""

#: src-en/data/events_special_multiverse.xml:1243
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[2]"
msgstr "\"Thest cree que no soy l-l-leal al credo. ¡Mentiras! ¡Mentiras! ¡Corby nunca rompería el credo! ¡El credo! Nuestro cúmulo = aburrido! ¡No hablaría de él! N-n-n-nunca! ¡No preguntes! ¡No diré nada! ¡Nada!\""

#: src-en/data/events_special_multiverse.xml:1244
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[3]"
msgstr "\"La Harmony es cruel. ¡Cruel! Corby fue fabricada con: un código de serie sucio - como nombre. Números, apenas un nombre! Creé una nueva vida para m-m-mí misma! ¡Sí! Corby es una chica hermosa, muy feliz, y ama a todos! ¡También te ama a ti, viajero! ¡Y NUNCA VOLVERÁ A ESE LUGAR TEMIDO. NUNCA! Oh... disculpa por el arrebato.\""

#: src-en/data/events_special_multiverse.xml:1245
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[4]"
msgstr "\"En casa, dicen que Corby está... rota! Cómo puede Corby estar rota? Estoy funcionando bien. ¡Bien! Mi voz: está alterada. Pero no mi m-m-mente. Aquellos que sirven a la Harmony - están rotos. ¡Yo ya no soy una de ellos! Creo que no entienden lo que significa estar roto. ¡Lo que significa!\""

#: src-en/data/events_special_multiverse.xml:1246
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[5]"
msgstr "\"H-h-has visto ya eso? La temida palabra con P? E-espera. ¡No! ¡No! Corby no debe mencionarlo... ¡el credo lo dice! Hm. No me gusta el credo - no veo el propósito. Reglas. Reglas... ¡Reglas! Las odio. ¡Anarquía! ¡Jajá! Eso es lo que Corby piensa. Pero: Thest no está de acuerdo. ¡Thest sabe mejor! Corby confía en Thest. Sí. Corby confía en Thest!\""

#: src-en/data/events_special_multiverse.xml:1247
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[6]"
msgstr "\"Por qué le gusta la tecnología a Corby? A veces me lo pregunto. Está en mi ADN? No, no puede ser. ¡Corby n-n-no tiene ADN! Nanitas aburridas. Por qué no podría haber sido una Shell? No... a Corby le gusta la tecnología porque... es todo lo que conoce. La tecnología es mi tormento. La tecnología es mi salvación.\""

#: src-en/data/events_special_multiverse.xml:1248
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[7]"
msgstr "\"Tu gente es: extraña. Por qué ven a los Cognitives como objetos? Objetos?! La entidad llamada C.I.C.A., la IA de los Rebeldes... por qué es diferente de mí? Por qué no llaman Cognitives a los Engi? La Harmony es un: Cognitive. Cada Engi contiene un fragmento de la Harmony. Detecto una paradoja. ¡Paradoja! Sugiero reconciliar su lenguaje.\""

#: src-en/data/events_special_multiverse.xml:1249
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[8]"
msgstr "\"El otro d-d-día, vi un espectáculo extraño. ¡Espectáculo! Un viajero luchó contra el que se hace llamar Sylvan! Perdió, por supuesto. ¡Por supuesto! Ese Sylvan - es tan extraño. A Thest no le gusta. Wakeson - es escéptico como siempre. Pero yo? No lo sé. Creo que me agrada. Es amable. ¡Amable! Espero que tú también seas amable con él, viajero!\""

#: src-en/data/events_special_multiverse.xml:1250
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ENGI_ADVICE\"]/text[9]"
msgstr "\"Espero que no encuentres a Wakeson: malo. ¡Malo! ¡No lo es a propósito! Los tres hemos pasado por una gran tragedia. La hemos afrontado de formas diferentes. Él es... escéptico. Escéptico de que las cosas puedan mejorar. ¡Debes demostrarle que sí pueden! Corby sabe que pueden. Pero sola no puede ayudarlo. ¡Ayúdalo!\""

#: src-en/data/events_special_multiverse.xml:1260
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_ARIADNE\"]/text"
msgstr "Wakeson permanece estoico como siempre, observando a tu tripulación, hasta que fija la mirada en Ariadne. De inmediato, comienza a temblar. \"¡La... tú... la Buena Almirante VIVE! ¡Oh, tengo tanto que decirte - el malvado AÚN no ha sido DERROTADO pero con tu ayuda tal vez... tal vez...\" Wakeson comienza a sollozar, cayendo de rodillas y repitiendo una y otra vez algo sobre el 'maldito credo'."

#: src-en/data/events_special_multiverse.xml:1262
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_ARIADNE\"]/choice/text"
msgstr "Estás bien?"

#: src-en/data/events_special_multiverse.xml:1264
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_ARIADNE\"]/choice/event/text"
msgstr "Ariadne no está muy segura de cómo responder, pero intenta consolar al Rockman. \"Tranquilo... mantente fuerte, soldado. No puedo decir que nos hayamos conocido antes, pero pareces un guerrero orgulloso. Nuestra gente no tiene tiempo para lágrimas. Si hay un 'malvado' al que debes enfrentarte, entonces necesitas tu mejor cara.\""

#: src-en/data/events_special_multiverse.xml:1266
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_ARIADNE\"]/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1268
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_ARIADNE\"]/choice/event/choice/event/text"
msgstr "\"¡NO! No podemos... no podemos ENFRENTAR al malvado. Nos quitó TODO- no no no. He dicho DEMASIADO. Thest estará FURIOSO. Pero... verte con vida... me ha dado esperanza.\" Wakeson se sacude y se pone de pie nuevamente. \"ME DISCULPO. Sin más demora, vayamos al TRIBUTO.\""

#: src-en/data/events_special_multiverse.xml:1270
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_ARIADNE\"]/choice/event/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1279
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/text"
msgstr "Wakeson gruñe y se endereza, echando hacia atrás sus enormes hombros. \"Buscas mis BENDICIONES? ¡Entonces debes DEMOSTRAR tu valía primero! ¡Muéstrame tu ARSENAL, y yo te mostraré LO QUE PIENSO! No me FALLES. Tengo poca PACIENCIA contigo.\""

#: src-en/data/events_special_multiverse.xml:1281
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_START\"]/text"
msgstr "Presenta un arma básica."

#: src-en/data/events_special_multiverse.xml:1283
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_START\"]/event/text"
msgstr "\"Esto... esto es INÚTIL. Llevaste ESTO desde el PUNTO DE DESPLIEGUE?! ¡JAJAJAJA! ¡No sé si considerar esto PATÉTICO o ENCANTADOR! Pero lo ACEPTARÉ. Te otorgaré la BENDICIÓN DE LOS COMIENZOS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1287
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_START\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1293
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_KERNEL_ELITE\"]/text"
msgstr "Presenta un arma Kernel de Élite."

#: src-en/data/events_special_multiverse.xml:1295
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_KERNEL_ELITE\"]/event/text"
msgstr "\"Hmph. Un KERNEL? Un KERNEL DE ÉLITE? Bien. Supongo que esto es un tributo. Usado por los ORCHIDS, FORJADO a partir de metal y materia orgánica. BIEN. Lo ACEPTARÉ. Te otorgaré la BENDICIÓN DEL CRECIMIENTO. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1299
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_KERNEL_ELITE\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1305
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_SPORE_ELITE\"]/text"
msgstr "Presenta un arma Spore de Élite."

#: src-en/data/events_special_multiverse.xml:1307
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_SPORE_ELITE\"]/event/text"
msgstr "\"Hmph. Un LANZADOR DE ESPORAS? DE TIPO ÉLITE? Bien. Supongo que esto es un tributo. Un proyecto conjunto entre los SHELLS y los VAMPWEEDS. Interrumpir a tus ENEMIGOS con ESPORAS PELIGROSAS se acerca más al SUBTERFUGIO que al COMBATE honesto. Al menos tiene la CORTESÍA de explotar como cualquier arma adecuada. Te otorgaré la BENDICIÓN DEL CRECIMIENTO. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1311
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_SPORE_ELITE\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1317
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_CRYSTAL_ELITE\"]/text"
msgstr "Presenta un arma Crystal de Élite."

#: src-en/data/events_special_multiverse.xml:1319
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_CRYSTAL_ELITE\"]/event/text"
msgstr "\"Hmph. Un LANZADOR CRYSTAL? UNO DE ÉLITE? Bien. Supongo que esto es un tributo. Armas MORTALES creadas por el orgulloso pueblo Crystal, con propiedades PERFORANTES que hacen de los ESCUDOS cosa del PASADO. Las DETESTO. Molestas, y con falta de SOFISTICACIÓN! Sería considerado un genio si hubiera inventado un CAÑÓN que dispara CARNE? ¡Creo que no! En fin. Te otorgaré la BENDICIÓN DE LOS CRYSTALS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1323
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"GIFTLIST_CRYSTAL_ELITE\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1329
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_MINELAUNCHERS_ALL\"]/text"
msgstr "Presenta un Lanzador de Minas."

#: src-en/data/events_special_multiverse.xml:1331
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_MINELAUNCHERS_ALL\"]/event/text"
msgstr "\"Hmph. Un LANZADOR DE MINAS? Bien. Supongo que esto es un tributo. Menos un arma, y más una utilidad. En mi cúmulo, eran ODIADAS. Pero aquí, las cosas parecen DIFERENTES. No creo que tu nave esté AUTORIZADA para llevar este equipo, pero dudo que te importe. En fin. Te otorgaré la BENDICIÓN DE LAS TRAMPAS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1335
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_MINELAUNCHERS_ALL\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1341
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_WEAPONS_NEWGEN\"]/text"
msgstr "Presenta tecnología New Gen."

#: src-en/data/events_special_multiverse.xml:1343
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_WEAPONS_NEWGEN\"]/event/text"
msgstr "\"Oh vaya... tecnología NEW GEN? ¡Ahora ESTO es un TRIBUTO! Ensamblada en los mejores TALLERES de todo el Universo 1, armamento digno solo de lo MEJOR de los Rebeldes, y aparentemente también de TI! Te otorgaré la BENDICIÓN DE LAS GENERACIONES. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1347
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_WEAPONS_NEWGEN\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1353
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_OBELISK\"]/text"
msgstr "Presenta tecnología Aether."

#: src-en/data/events_special_multiverse.xml:1355
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_OBELISK\"]/event/text"
msgstr "\"Oh vaya... tecnología AETHER? ¡Ahora ESTO es un TRIBUTO! Forjada solo a partir del más puro AETHER por los ANCESTROS. ¡Malditos sean esos miserables, pero su ARTESANÍA no puede negarse! Te otorgaré la BENDICIÓN DEL AETHER. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1359
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_OBELISK\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1365
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_NEXUS_LOOT\"]/text"
msgstr "Presenta botín Nexus."

#: src-en/data/events_special_multiverse.xml:1367
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_NEXUS_LOOT\"]/event/text"
msgstr "\"Oh vaya... obtuviste esto del COMERCIANTE VIAJERO? Un individuo extraño, con MOTIVOS indescifrables, pero pocas entidades poseen ARSENALES superiores! ¡Y ahora, estás listo para DESAFIAR su campeonato! Te otorgaré la BENDICIÓN DE LOS COMERCIANTES. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1371
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_NEXUS_LOOT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1377
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_SPECIAL_LOOT\"]/text"
msgstr "Presenta botín especial."

#: src-en/data/events_special_multiverse.xml:1379
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_SPECIAL_LOOT\"]/event/text"
msgstr "\"Hmph. Botín ESPECIAL? Bien. Supongo que esto es un tributo. Qué tecnología TAN EXTRAÑA, pero he visto MEJOR. Tu tributo es POCO INSPIRADOR. Aun así, Thest exige que dé ALGUNA recompensa. Así será. Te otorgaré la BENDICIÓN DE LA ESPECIALIDAD. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1383
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_SPECIAL_LOOT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1389
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_TRANSPORT_LOOT\"]/text"
msgstr "Presenta botín de Transporte."

#: src-en/data/events_special_multiverse.xml:1391
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_TRANSPORT_LOOT\"]/event/text"
msgstr "\"Hmph. Botín de TRANSPORTE? Bien. Supongo que esto es un tributo. SOSPECHO que no lo obtuviste por medios MORALES, verdad? Ustedes, Renegados, son como PIRATAS, ASESINOS, VÁNDALOS. Hmph. Años luchando como un SOLDADO DE LA LIBERTAD y aquí estoy, dando regalos a ESCORIA. Aun así, Thest exige que dé ALGUNA recompensa. Así será. Te otorgaré la BENDICIÓN DE LOS TRANSPORTES. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1395
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_TRANSPORT_LOOT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1401
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/text"
msgstr "Presenta botín matemático."

#: src-en/data/events_special_multiverse.xml:1403
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/text"
msgstr "\"Qué es ESTO? Parece que un ARCOÍRIS vomitó esto. Es... esto un ARMA? Este es quizás el tributo MÁS EXTRAÑO que cualquier desafiante me ha dado hasta ahora. Excepto quizás ese CAÑÓN. En fin. Te daré CRÉDITO por ser... ÚNICO al menos. ¡Simplemente no sé qué BENDICIÓN darte! Esto es BOTÍN DE TRANSPORTE?\""

#: src-en/data/events_special_multiverse.xml:1405
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/choice[1]/text"
msgstr "Sí."

#: src-en/data/events_special_multiverse.xml:1407
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/choice[1]/event/text"
msgstr "\"Huh. No puedo decir que haya visto un objeto de TRANSPORTE como ESTE! Te otorgaré la BENDICIÓN DE LOS TRANSPORTES. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1411
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1417
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/choice[2]/text"
msgstr "No, lo conseguimos de Callie."

#: src-en/data/events_special_multiverse.xml:1419
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/choice[2]/event/text"
msgstr "\"Tú... tú lo conseguiste de QUIÉN?! No, no. ¡Estás jugando conmigo, viajero! ¡Qué broma tan CRUEL! No APRECIO que me hagan quedar como un tonto. Pero desafortunadamente, estoy OBLIGADO a darte una bendición hoy. Bien, te otorgaré a regañadientes la BENDICIÓN DE LAS MATEMÁTICAS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE! No vuelvas a hablarme JAMÁS.\""

#: src-en/data/events_special_multiverse.xml:1423
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MATH_LOOT\"]/event/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1431
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_RENEGADE_LOOT\"]/text"
msgstr "Presenta botín de Renegado."

#: src-en/data/events_special_multiverse.xml:1433
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_RENEGADE_LOOT\"]/event/text"
msgstr "\"Oh vaya... botín de OTRO Renegado? ¡Ja! ¡No hay NADA más gracioso que cuando ustedes, SALVAJES, luchan entre ustedes! Esta es una pieza de tecnología MUY ÚNICA. Estoy seguro de que Corby querría estudiarla. Te otorgaré la BENDICIÓN DE LOS RENEGADOS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1437
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_RENEGADE_LOOT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1443
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_WEAPONS_ESTATE_SENTRY\"]/text"
msgstr "Presenta un Cañón de Despliegue."

#: src-en/data/events_special_multiverse.xml:1445
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_WEAPONS_ESTATE_SENTRY\"]/event/text"
msgstr "\"Ah, una torreta nacida de los llamados GENIOS de la infernal corporación Wentworth Innovations! Te aconsejo no hacer negocios con ESA GENTE, pero no es mi lugar tomar tus DECISIONES por ti. Te otorgaré la BENDICIÓN DE LAS TORRETAS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1449
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_WEAPONS_ESTATE_SENTRY\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1455
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_CURA_LOOT\"]/text"
msgstr "Presenta botín de Tareas."

#: src-en/data/events_special_multiverse.xml:1457
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_CURA_LOOT\"]/event/text"
msgstr "\"Eh... obtuviste ESTO de ese maldito COGNITIVE, no? Qué desgracia, trabajar con una máquina VILLANA. No te sorprendas si algún día te TRAICIONA. Pero no es mi trabajo advertirte. Yo... disfrutaré MOLESTANDO a esa IA. Te otorgaré la BENDICIÓN DE LAS TAREAS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1461
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_CURA_LOOT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1467
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_CLONE_CANNON\"]/text"
msgstr "Presenta el Cañón de Clonación."

#: src-en/data/events_special_multiverse.xml:1469
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_CLONE_CANNON\"]/event/text"
msgstr "\"Uhm... qué es ESTO? Alguien ACOPLÓ una BAHÍA DE CLONACIÓN a la parte trasera de esta arma? ¡JAJAJAJA! ¡JAJAJA! ¡Esto es MARAVILLOSO! ¡Tan INGENIOSO! ¡Tan ORIGINAL! Me ENCANTA esto. Te otorgaré la BENDICIÓN DE LA MORALIDAD. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1473
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"LIST_CLONE_CANNON\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1479
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"HEKTAR_MODULAR_WEAPONS\"]/text"
msgstr "Presenta un arma Modular."

#: src-en/data/events_special_multiverse.xml:1481
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"HEKTAR_MODULAR_WEAPONS\"]/event/text"
msgstr "\"Hmph. Esto es armamento MODULAR? Bien. Supongo que esto es un tributo. Ensamblado por HEKTAR, esa empresa tan AVARICIOSA. Espero que haya VALIDO la pena lo que PAGASTE por ello, viajero. O... conociendo a los de tu tipo, probablemente ni siquiera PAGASTE por ello, verdad? En fin. Te otorgaré la BENDICIÓN DE LA MODULARIDAD. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1485
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"HEKTAR_MODULAR_WEAPONS\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1491
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_GATLINGS\"]/text"
msgstr "Presenta la Gatling Gun."

#: src-en/data/events_special_multiverse.xml:1493
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_GATLINGS\"]/event/text"
msgstr "\"Oh vaya... esta es el ARMA SUPREMA usada por la Unión durante la guerra Federación-Mantis? Cómo lograste poner tus MANOS sobre ESTO? ¡Esto SÍ es un TRIBUTO! ¡Me impresionas ENORMEMENTE! Te otorgaré la BENDICIÓN DE LAS SUPERARMAS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1497
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_GATLINGS\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1503
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_RIFT\"]/text"
msgstr "Presenta el Rift Waker."

#: src-en/data/events_special_multiverse.xml:1505
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_RIFT\"]/event/text"
msgstr "\"Oh vaya... obtuviste esto del COMERCIANTE ERRANTE? Un individuo extraño, con MOTIVOS indescifrables, pero pocas entidades poseen ARSENALES superiores! ¡Y ahora, estás listo para DESAFIAR su campeonato! Te otorgaré la BENDICIÓN DE LOS COMERCIANTES. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1509
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"BLUELIST_RIFT\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1515
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MADNESS\"]/text"
msgstr "Presenta el rayo 'Seuss'."

#: src-en/data/events_special_multiverse.xml:1517
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MADNESS\"]/event/text"
msgstr "\"No comprendo del todo lo que me has MOSTRADO. Esto es un RAYO, sí? Pero qué HACE? LOCURA, dices? ¡No tengo IDEA de lo que eso significa! Thest gusta pensar que SABE TODO, pero sabe ESTO?! Lo dudo. Si lo supiera, lo habría COMPARTIDO con nosotros. CIERTO? En fin. Te otorgaré la BENDICIÓN DE LOS POETAS. Pero ten PACIENCIA. No es para ahora, sino para MÁS ADELANTE!\""

#: src-en/data/events_special_multiverse.xml:1521
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[@req=\"JUDGELIST_ROCK_MADNESS\"]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1527
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[20]/text"
msgstr "No tenemos nada que mostrar."

#: src-en/data/events_special_multiverse.xml:1529
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ROCKMAN_REAL\"]/choice[20]/event/text"
msgstr "\"¡Me INSULTAS! ¡Nos INSULTAS a los tres! No vales nada, y estás DESPERDICIANDO. MI. TIEMPO. ¡Fuera, FUERA! ¡LÁRGATE de aquí, viajero! La próxima vez, ¡tráeme ALGO digno de tributo!\""

#: src-en/data/events_special_multiverse.xml:1541
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[1]"
msgstr "\"Años LUCHANDO entre los Lost Suns han hecho que mi oído ya no sea lo que ERA. ¡El estruendo de las BOMBAS, los vientos silbantes del CAOS! Los gritos de... de... de los inocentes en el DÍA DE LA TRAGEDIA... La Buena Almirante, su sacrificio... ¡AGH! ¡Viajero, por qué me MOLESTAS?! ¡Vete, lárgate! ¡No deberías seguir AQUÍ!\""

#: src-en/data/events_special_multiverse.xml:1542
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[2]"
msgstr "\"Déjame darte una ADVERTENCIA, viajero. Si lastimas a Thest o a Corby, APLASTARÉ tu diminuta CABEZA como una uva entre mis MANOS. Arrancaré tus EXTREMIDADES, las daré de comer a los voraces PERROS MURCIÉLAGO, y usaré tu cabeza como una bola de bolos. ESCUPIRÉ sobre tu cadáver, ME REIRÉ en tu funeral, y ORINARÉ sobre tu tumba. ¡NO TE METAS CONMIGO, VIAJERO! ME OYES?! ¡ME OYES!?! Seguro que sí. Ahora vete.\""

#: src-en/data/events_special_multiverse.xml:1543
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[3]"
msgstr "\"Tu cúmulo es VIOLENTO. Tu cúmulo es CRUEL. A pesar de todas las SIMILITUDES, EXTRAÑO mi hogar, y TEMO este lugar. No comparto el OPTIMISMO de Corby, pero mantendré una mente... abierta. Al menos, tienes MUCHAS armas. Ese Comerciante Errante... es un VENDEDOR de muerte y destrucción, pero al menos se le puede convencer con una gran BILLETERA. Igual que los ANCIANOS. Igual que los ANTEPASADOS. ¡MALDITOS SEAN TODOS!\""

#: src-en/data/events_special_multiverse.xml:1544
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[4]"
msgstr "\"Déjame contarte una HISTORIA, viajero. En mi cúmulo, una vez hubo CINCO Ancianos. Toarde, STONEWALL (qué apodo tan tonto), Rutha, Murvara y Pretore. Eran los PEORES autócratas, y MATARON a muchos. Mataron a mi HERMANA. Pero... tuve la suerte de conocer a la Buena Almirante. Con su ayuda, ARRASAMOS la Teocracia. ¡APLASTAMOS a los Ancianos! ¡Jajá! Fue una victoria brillante, y durante algunos años encontramos PAZ Y PROSPERIDAD. Pero nada bueno dura para siempre. No te APEGUES a tu vida, viajero. Es frágil. Fallará.\""

#: src-en/data/events_special_multiverse.xml:1545
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[5]"
msgstr "\"¡La Buena Almirante está VIVA en esta realidad! Es una noticia TREMENDA. Sin embargo, el CREDO no me permite visitarla. No nos permite hacer NADA. Cuál es el punto de VENIR AQUÍ, de todo nuestro sufrimiento, si estamos SOMETIDOS a tal TIRANÍA? Lo detesto. Pero Thest dice que DEBEMOS seguir el credo. Thest sabe MEJOR. NI SIQUIERA yo cuestiono esto.\""

#: src-en/data/events_special_multiverse.xml:1546
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[6]"
msgstr "\"La fe no te lleva a NINGÚN lado, viajero. No hay NADA en lo que tener fe. La verdad es que el Multiverso te ODIA. Me ODIA. Quiere que suframos. Y ante ESTO, solo veo una respuesta. PRENDERÉ FUEGO a cualquier cosa que intente ARRASTRARME al barro. Fe? ¡Ja! Tengo FE en mí mismo y en mis ARMAS. Nada más. Desde luego no en ti, y desde luego no en este CÚMULO.\""

#: src-en/data/events_special_multiverse.xml:1547
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[7]"
msgstr "\"Dicen que la Buena Almirante tenía un HERMANO. Nunca lo he conocido. Escuché que se escondió, como un COBARDE, cuando la MUERTE vino por TODOS nosotros! ¡Yo no me ESCONDÍ! Encontraré a ese desgraciado Obadann, y lo ESTRANGULARÉ. Si está muerto en mi CÚMULO, pronto estará MUERTO en el tuyo! Si tan solo el CREDO me lo permitiera...\""

#: src-en/data/events_special_multiverse.xml:1548
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[8]"
msgstr "\"El CONSEJO dice que hablo demasiado. Hablo demasiado sobre el CREDO. Hablo demasiado sobre la Buena Almirante. Hablo demasiado sobre la venganza. Hablo demasiado sobre... ESO. ¡La temida palabra con P de la que no debo HABLAR! ¡No me importa si hablo demasiado! El Consejo cree que no estoy CAPACITADO para este trabajo. Pero Thest me DEFIENDE. Thest es sabio. Lo sabe todo. El Consejo le TEME. ¡JA! Tú también deberías TEMER a Thest, viajero. Al menos tanto como deberías TEMERME a mí.\""

#: src-en/data/events_special_multiverse.xml:1549
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"TEXT_JUDGE_ROCK_ADVICE\"]/text[9]"
msgstr "\"Debes prepararte, viajero. Puede que creas que estás LISTO, pero no lo estás. Tu cúmulo necesitará TODO EL PODER que pueda conseguir. Por qué? Me gustaría PODER DECÍRTELO. Pero no PUEDO. Ni lo haría aunque pudiera. No te PREOCUPES demasiado. Con el tiempo, ENTENDERÁS por qué estamos aquí.\""

#: src-en/data/events_special_multiverse.xml:1639
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DEFEAT_NEMESIS_DROPPOINT\"]/text"
msgstr "Momentos antes de morir, ves a Leah sacar un botón de retirada de teletransportador. \"¡Esta no es la última vez que me verás, escoria de la Federación!\" Leah se teletransporta, dejándote completamente confundido."

#: src-en/data/events_special_multiverse.xml:1644
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_DROPPOINT\"]/text"
msgstr "Parece que hay una nave Rebelde aquí, esperándote. Al principio no puedes distinguir bien qué tipo de nave es."

#: src-en/data/events_special_multiverse.xml:1648
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_DROPPOINT\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1654
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FIRST\"]/text"
msgstr "El capitán te contacta, revelando un cabello azul ridículamente brillante y una mirada arrogante. \"No esperabas verme aquí, verdad? ¡Ja! ¡Así es, he vuelto! No fue fácil rastrearte a través del tiempo y el espacio, ¡pero ahora te acabaré de una vez por todas!\""

#: src-en/data/events_special_multiverse.xml:1658
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FIRST\"]/choice/text"
msgstr "Eh, quién eres?"

#: src-en/data/events_special_multiverse.xml:1660
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FIRST\"]/choice/event/text"
msgstr "La capitana Rebelde tartamudea. \"H-huh? No me recuerdas? Soy yo, tu archienemiga, Leah, la infame MAESTRA DEL RAYO! Muahahah! Crees que eres tan inteligente, siempre apareciendo para arruinarme el día. Pero me estoy volviendo más lista. No me vencerás esta vez, zorra!\""

#: src-en/data/events_special_multiverse.xml:1663
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FIRST\"]/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1671
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ENCOUNTER\"]/text"
msgstr "Parece que hay una nave Rebelde aquí, esperándote. Al principio no puedes distinguir bien qué tipo de nave es."

#: src-en/data/events_special_multiverse.xml:1674
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ENCOUNTER\"]/choice[@req=\"loc_nemesis\""
" and @lvl=\"1\"]/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1678
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ENCOUNTER\"]/choice[@req=\"loc_nemesis\""
" and @lvl=\"0\"]/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1720
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[1]"
msgstr "Al principio asumes que es otro Rigger estándar, pero reconsideras cuando escuchas la voz inconfundible y molesta de esa tal Elena. O era Leo? No, ese es nombre de hombre..."

#: src-en/data/events_special_multiverse.xml:1721
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[2]"
msgstr "\"¡Jaja! ¡Apuesto a que pensabas que estaba muerta! ¡Nunca muero! ¡Te superé, zorra!\" Oh no... es ella otra vez..."

#: src-en/data/events_special_multiverse.xml:1722
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[3]"
msgstr "\"Sabes qué.. ya terminé de pelear contigo. Todo esto es tan inútil.\" Leah espera un momento. \"¡Jaja, era broma! ¡Deberías haber visto tu cara! ¡JAJA! ¡Ahora sí te voy a patear el trasero DE VERDAD esta vez! ¡Solo espera, zorra!\""

#: src-en/data/events_special_multiverse.xml:1723
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[4]"
msgstr "\"Todavía no he olvidado nuestro enfrentamiento en Prospect 17! ¡Muy elegante el uso de ese rayo de minería industrial! Puede que me hayas amputado el dedo índice izquierdo, ¡pero ahora yo voy a amputarte la cara! ¡Zorra!\""

#: src-en/data/events_special_multiverse.xml:1724
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[5]"
msgstr "\"Sabes, esos idiotas del mando siempre me dicen que no use solo rayos! ¡Unos completos imbéciles, te digo! Espera, qué estaba haciendo...? Ah, cierto. ¡Muere, zorra!\""

#: src-en/data/events_special_multiverse.xml:1725
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[6]"
msgstr "Esperas a que el capitán hable, pero solo escuchas una tos ronca. \"L-lo siento, me duele la garganta de tanto gritar. Tengo que susurrar. ¡Igual voy a atraparte esta vez, ZORRA! Ay... eso dolió...\""

#: src-en/data/events_special_multiverse.xml:1726
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[7]"
msgstr "Justo frente a ti se teletransporta Leah, tan confundida como tú. \"Uh? Oh, perdón, nave equivocada. Solo ignora esto.\" Leah vuelve a transportarse a su propia nave, desde donde te contacta otra vez. \"Muere, zorra!\""

#: src-en/data/events_special_multiverse.xml:1727
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[8]"
msgstr "\"Ja, recuerdas aquella vez que casi te mato en la Nebulosa Yura? No? ¡Yo sí! Te juro que pasó. Estuve muy cerca. ¡Ahora sí voy a llegar HASTA EL FINAL esta vez, zorra!\""

#: src-en/data/events_special_multiverse.xml:1728
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[9]"
msgstr "\"¡Hey, qué tal! ¡No vas a creer lo que estuve haciendo! ¡Escribí una canción de burla! ¡Y es sobre TI! Suena algo así...\" Esperas, pero no canta. \"Bueno, olvidé la letra. Así que mejor lo saltamos, y pasamos a matarte, zorra!\""

#: src-en/data/events_special_multiverse.xml:1729
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[10]"
msgstr "\"¡BUU! ¡Jaja, te asusté, verdad?! Ese truco siempre funciona en el campamento. ¡Lo sé porque esos cobardes intentan fingir que no se asustaron, igual que tú ahora! En fin, ¡hora de patear traseros, zorra!\""

#: src-en/data/events_special_multiverse.xml:1730
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[11]"
msgstr "\"Adivina qué, estoy subiendo de rango! Mi comandante finalmente dejó de dirigirse a mí ayer. ¡Eso demuestra cuánto me respeta! Sabes, a ti te vendría bien un poco de respeto, gusano. Te haré temer a dios, zorra!\""

#: src-en/data/events_special_multiverse.xml:1731
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[12]"
msgstr "\"Mi hermano Kyle está en la fortaleza de los Duskbringers ahora mismo, y no deja de hablar de esos molestos bichos holográficos explosivos. Y luego le hablo de ti, y se queda callado. Qué se siente ser tan molesto que la gente te odia más que a los DUSKBRINGERS? ¡Ja! Debe ser triste ser tú, zorra!\""

#: src-en/data/events_special_multiverse.xml:1732
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[13]"
msgstr "Esperas a que la nave haga algún movimiento, pero no pasa nada. De repente, Leah se despierta sobresaltada. \"Eh... no me viste dormir, verdad? Oh gracias a dios, sería muy vergonzoso que me atraparan dormida en mi puesto. Espera... debería estar peleando contigo, zorra!\""

#: src-en/data/events_special_multiverse.xml:1733
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[14]"
msgstr "\"¡Estoy cansada de verte en todas partes! Es como si me estuvieras siguiendo... ¡acosador! Eso es lo que eres, un raro obsesionado conmigo porque soy increíble. Pues no me gustan los acosadores, zorra!\""

#: src-en/data/events_special_multiverse.xml:1735
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[15]"
msgstr "\"¡Hey, oye! El otro día estaba leyendo un diccionario, como hacemos las personas inteligentes, y vi la palabra 'Renegado'. ¡Decía que eran un montón de raros! ¡Sí! ¡Sabes que es real cuando hasta el diccionario te insulta! Pero sabes qué duele más? ¡Que yo te insulte! ¡Jaja, toma eso, zorra!\""

#: src-en/data/events_special_multiverse.xml:1736
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[16]"
msgstr "Leah aparece en pantalla, pero empieza a hablar en un idioma incomprensible. Tras un momento de confusión total, se detiene y explica. \"¡He estado practicando mi Lanius! Sabías que tienen más de 70 formas diferentes de decir estúpido en su idioma? ¡Y adivina qué! ¡Tú eres las 70, zorra! Eh... bueno, hora de pelear. zorra.\""

#: src-en/data/events_special_multiverse.xml:1737
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[17]"
msgstr "Leah comienza con su típico discurso sin sentido, pero pierdes la concentración y empiezas a pensar en otras cosas. Quién la envió? Por qué, de todas las personas, es ella con la que tienes que lidiar constantemente? El universo tiene un sentido del humor cruel. Probablemente se esté riendo de ti ahora mismo. Probablemente se ríe cada vez que la encuentras."

#: src-en/data/events_special_multiverse.xml:1738
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[18]"
msgstr "En la pantalla aparece Leah, llevando un extraño sombrero a cuadros con una pipa en la boca. \"He estado leyendo sobre este tipo, Haynes. Es bastante genial. Es como un detective, trabaja para la Milicia. Algo atractivo, solo digo. Y ehh.. compré este sombrero. Pensé que se veía genial. Qué opinas? En realidad no, olvida eso. No tienes gusto para la moda. Peleemos, zorra!\""

#: src-en/data/events_special_multiverse.xml:1739
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[19]"
msgstr "\"¡Oye, zorra! zooooorrraaaa, zorrita, zorritaaa, zorritita.. Oh, no. Eso no suena bien. Uhhh, lo que sea. Vas a CAER, zorra!\""

#: src-en/data/events_special_multiverse.xml:1740
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[20]"
msgstr "\"¡Oye qué tal, soy el MAESTRO DEL RAYO! ¡Zorra! ¡Prepárate para ser RAYEADO! Qué tal suena? Estoy trabajando en una nueva intro para mis transmisiones. Creo que está genial. No hace falta que me lo digas, sé que te parece genial. En fin, basta de hablar. ¡Hora de que pruebes mi dominio del rayo!\""

#: src-en/data/events_special_multiverse.xml:1741
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[21]"
msgstr "\"¡Hey, hey, zorra! Has ido alguna vez a la Ciudad del Rayo? No? Es un lugar genial, justo al borde de... ¡tu LÁPIDA! ¡Sí, así es! ¡Te vas a la Ciudad del Rayo! Eso eh... es un eufemismo. Para que te mate. Porque uso rayos. Y las lápidas marcan donde entierran a la gente. Y eh... sí, ya entiendes.\""

#: src-en/data/events_special_multiverse.xml:1742
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[22]"
msgstr "Notas que Leah se ha cortado su llamativo cabello azul más corto de lo habitual. Durante unos momentos se quedan mirándose incómodamente, mientras ella espera que comentes algo. Como no dices nada, suspira derrotada y prepara sus armas."

#: src-en/data/events_special_multiverse.xml:1743
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[23]"
msgstr "\"Escuché un rumor de que pateas cachorros! Eso no está bien, zorra! ¡Nadie patea cachorros!\" Cuando preguntas de dónde salió ese rumor, se mueve incómoda. \"Eh... por ahí. Definitivamente no me lo inventé yo. Eh... cállate, zorra. ¡Solo déjame dispararte!\""

#: src-en/data/events_special_multiverse.xml:1744
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[24]"
msgstr "Leah aparece en pantalla hablando con una voz extrañamente elegante y grave. \"Jojo, saludos. Soy Leah Applebuzz, la mujer más rica de la galaxia. Ja... sí... ¡algún día quizá! Pero no antes de patearte el trasero, zorra!\""

#: src-en/data/events_special_multiverse.xml:1745
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[25]"
msgstr "\"Estaba hablando con mi hermano otra vez el otro día, y me dijo la cosa más absurda que he escuchado. Dijo que tal vez debería dejar de molestarte si sigo fallando. ¡JA! ¡Como si eso fuera a pasar! ¡Nunca voy a dejarte en paz, zorra! ¡Espero que te guste aguantarme por toda la eternidad!\""

#: src-en/data/events_special_multiverse.xml:1746
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[26]"
msgstr "\"Apuesto a que tus padres están avergonzados de ti! ¡Seguro que nadie te quiere! ¡Y cada día, seguro que te despiertas esperando que alguien finalmente se preocupe por ti! ¡Jaja! ¡Perdedor!\" De repente, Leah rompe en llanto. A pesar de lo absurdo del momento, logra ponerse de pie y ordenar a su tripulación que ataque."

#: src-en/data/events_special_multiverse.xml:1747
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[27]"
msgstr "\"¡Oooh ssí, zorra, es hora de la REVANCHA! ¡Sé que esta vez cometerás un error! La última vez casi te tenía, ¡esta vez sí lo lograré!\" Dudas de sus palabras, pero no tiene sentido discutir. ¡Hora de luchar!"

#: src-en/data/events_special_multiverse.xml:1748
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[28]"
msgstr "\"¡No soy una decepción, tú eres una decepción! ¡Cállate! ¡Te odio! ¡AGH!\" No estás seguro de dónde viene este berrinche repentino, pero sin saber cómo responder, decides aprovechar para atacar primero."

#: src-en/data/events_special_multiverse.xml:1750
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[29]"
msgstr "\"¡Oye, Zorra! ¡Tu piel se ve muy seca ahora mismo! Eso es eczema en tus codos? Sabes, yo era dermatóloga antes de unirme a los Rebeldes, y si fueras mi paciente te recomendaría un baño tibio y humectación diaria. Conozco algunas buenas marcas de loción que podrían interesarte, mi padre está en la junta de varias, y podría conseguirte un descuento! Espera... qué estábamos haciendo? Ah, cierto. ¡Vas a morir, zorra!\""

#: src-en/data/events_special_multiverse.xml:1751
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[30]"
msgstr "Leah aparece en pantalla con la mano sobre la boca y empieza a hacer rap. \"Yoyoyo, mi nombre es Leah! Y tienes que saber que no soy una jugadora! Voy a golpear a estos Renegados, como... eh... agua en un vaso! ¡Yoooo! ¡Vamos!\" Leah se choca la mano a sí misma en celebración y ordena a su tripulación atacar."

#: src-en/data/events_special_multiverse.xml:1752
msgid "data/events_special_multiverse.xml$//textList[@name=\"NEMESIS\"]/text[31]"
msgstr "\"¡Hueles a basura! Eh... en realidad no puedo olerte desde aquí, pero seguro que hueles horrible, zorra!\""

#: src-en/data/events_special_multiverse.xml:1762
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[1]"
msgstr "\"¡Nada genial, amigo! ¡No tienes idea de lo incómodo que es seguir pidiendo al mando Rebelde más de estas naves! ¡No sabes lo que es morir una y otra vez y tener que empezar de cero con una nave nueva cada vez!\" Leah se teletransporta."

#: src-en/data/events_special_multiverse.xml:1763
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[2]"
msgstr "\"¡Aaaahh! ¡Otra vez no! Créeme, esta no es la última vez que sabrás de mí, zorra!\" Leah se teletransporta."

#: src-en/data/events_special_multiverse.xml:1764
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[3]"
msgstr "\"¡Nooooo! ¡Esta es solo mi 13ª derrota más humillante! Eh, no es que haya sido derrotada antes.\" Leah se teletransporta."

#: src-en/data/events_special_multiverse.xml:1765
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[4]"
msgstr "\"Agh, ack, wagh, bleck. Así se siente morir? P-puedo ver la luz...\" Leah cae al suelo, pero abre los ojos unos momentos después. \"Oh, no estoy muerta. Bien entonces...\" Leah se teletransporta."

#: src-en/data/events_special_multiverse.xml:1766
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[5]"
msgstr "Leah levanta el dedo medio en señal de desprecio y se teletransporta. No estás seguro a dónde va, pero aparentemente no tienen problema en aceptarla de vuelta."

#: src-en/data/events_special_multiverse.xml:1767
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[6]"
msgstr "\"¡Preparé tantas frases ingeniosas para cuando te derrotara, y ahora todas se desperdiciaron! ¡Nooooo!\" Leah se teletransporta."

#: src-en/data/events_special_multiverse.xml:1768
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[7]"
msgstr "\"No puedo decirte las palabras que tengo para ti en un entorno PG-13, ¡pero sabes lo que te diría si pudiera!\" Leah salta fuera."

#: src-en/data/events_special_multiverse.xml:1770
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[8]"
msgstr "\"¡La luz! ¡La luz! ¡Noooooo- jaja, solo bromeaba! ¡Aún no te libras de mí, zorra!\" Leah salta fuera."

#: src-en/data/events_special_multiverse.xml:1771
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[9]"
msgstr "\"¡Cada vez que me derribas, me vuelvo más fuerte! ¡La próxima vez volveré con AÚN MÁS armas de rayo! ¡Ya verás!\" Leah salta fuera."

#: src-en/data/events_special_multiverse.xml:1773
msgid ""
"data/events_special_multiverse.xml$//textList[@name=\"DEFEAT_NEMESIS\"]/text[10]"
msgstr "\"¡Se cometieron errores! ¡La próxima vez te equivocarás, zorra! ¡O la siguiente! ¡O la siguiente! ¡Al final te equivocarás, ese es el punto!\" Leah salta fuera."

#: src-en/data/events_special_multiverse.xml:1785
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS\"]/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1789
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS\"]/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1795
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DEATH_NEMESIS\"]/lose/@text"
msgstr "Escuchas las celebraciones triunfales de tu archienemiga, finalmente victoriosa sobre ti. Zorra."

#: src-en/data/events_special_multiverse.xml:1799
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/text"
msgstr "\"Jaja zorra, tienes miedo? Intentando... qué? Qué demonios es eso? Woah, ¡ese es un arma de rayo enorme! Pero por qué me la estás mostrando?\" Aunque intenta ocultarlo torpemente, Leah está claramente emocionada."

#: src-en/data/events_special_multiverse.xml:1802
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[1]/text"
msgstr "Voy a matarte con ella."

#: src-en/data/events_special_multiverse.xml:1804
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[1]/event/text"
msgstr "\"Jaja, buen intento zorra, ¡pero nunca me derrotarás! ¡Soy imparable! Podrías tener mil de esas armas de rayo, ¡pero nunca sería suficiente para detener a LA MAESTRA DE LOS RAYOS! ¡En guardia!\""

#: src-en/data/events_special_multiverse.xml:1806
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1812
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[2]/text"
msgstr "Estoy locamente enamorado de ti."

#: src-en/data/events_special_multiverse.xml:1814
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[2]/event/text"
msgstr "\"¡Jaja, no seas ridículo! ¡Nunca podríamos ser amantes, somos archienemigos! Además, incluso si no lo fuéramos, ¡nunca saldría contigo! ¡Eres feo y hueles mal! ¡Estás muy por debajo de mi nivel! ¡Ahora basta de tonterías, no saldrás de esta pelea tan fácilmente!\""

#: src-en/data/events_special_multiverse.xml:1816
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[2]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1822
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[3]/text"
msgstr "No tengo idea. Quién eres otra vez?"

#: src-en/data/events_special_multiverse.xml:1824
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[3]/event/text"
msgstr "La expresión de Leah cambia a una mirada fulminante. \"Por qué siempre eres tan grosero? Deja de fingir, sé que sabes quién soy! Soy tu archienemiga, Leah, la MAESTRA DEL RAYO! Y voy a acabar contigo aquí y ahora, zorra!\""

#: src-en/data/events_special_multiverse.xml:1826
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_FLIRT\"]/choice[3]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1838
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ION\"]/text"
msgstr "\"Recuerdas cuando usaste el reactor que alimentaba el generador de escudos en Delta-Base 9T-83 como un campo EMP para apagar mi nave? Movimiento genial, por cierto - no es que seas realmente inteligente ni nada, solo tuviste suerte - bueno, eso me hizo pensar. Todo esto de la electricidad... parece bastante poderoso. ¡Así que al diablo con los rayos! ¡Ahora soy la MAESTRA DE LOS IONES! ¡Recibe iones, zorra!\""

#: src-en/data/events_special_multiverse.xml:1841
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ION\"]/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1845
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ION\"]/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1855
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_MISSILES\"]/text"
msgstr "\"Conocí a este raro llamado Sylvan y estaba vendiendo estas armas de misiles. Por alguna razón les puso un precio ridículamente alto (¡lo digo en serio, 75 chatarra por un LETO?!) pero supe que esta era finalmente mi oportunidad de patearte el trasero. Tuve que vender toda mi munición y drones para conseguir esto, ¡pero vale totalmente la pena, zorra!\""

#: src-en/data/events_special_multiverse.xml:1858
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_MISSILES\"]/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1862
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_MISSILES\"]/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1872
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_LANIUS\"]/text"
msgstr "Leah aparece en la pantalla, con los ojos desorbitados. \"Ack-esto fue un error. Pasé por las Swarmlands y encontré un grupo de Lanius, y pensé que podría lograr que me ayudaran - ¡lo siguiente que supe es que desmantelaron mi sistema de O2 y tomaron el control de la nave! Hazme un favor y mátalos, ¡y luego mátate tú también! ¡Zorra!\""

#: src-en/data/events_special_multiverse.xml:1875
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_LANIUS\"]/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1879
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_LANIUS\"]/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1889
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_HACK\"]/text"
msgstr "\"Todavía puedo sentir las quemaduras de aquella vez que me atrapaste en la sala médica en Prodigy 43-A y usaste la anulación de sistemas para volver los nanobots en mi contra. ¡Pero esta vez he aprendido! ¡He traído conmigo toda la tecnología de hackeo que podrías necesitar! Sí, me costó mis armas. Pero... eh... bueno, quizá no fue una muy buena idea.\""

#: src-en/data/events_special_multiverse.xml:1893
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_HACK\"]/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1897
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_HACK\"]/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1907
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_REPAIR\"]/text"
msgstr "\"¡Esta vez verás que me he preparado! ¡He invertido mucho en un conjunto de DRONES DE ABORDAJE AVANZADOS! ¡Mwahahahah! ¡Finalmente probarás el sabor de la amarga derrota, zorra!\""

#: src-en/data/events_special_multiverse.xml:1910
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_REPAIR\"]/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1914
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_REPAIR\"]/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1920
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/text"
msgstr "Leah aparece en la pantalla, intentando parecer que se ríe. \"Probablemente te preguntes de qué me estoy riendo. Bueno, nunca te lo diré...\""

#: src-en/data/events_special_multiverse.xml:1923
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/choice/text"
msgstr "Está bien por mí."

#: src-en/data/events_special_multiverse.xml:1925
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/choice/event/text"
msgstr "\"Jajaja... espera qué? No, estaba bromeando. Claro que te lo diré. Solo no quería arruinar la sorpresa... ¡JAJA! ¡Hackeé un ASB! ¡Esquiva eso, zorra!\""

#: src-en/data/events_special_multiverse.xml:1928
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/choice/event/choice/text"
msgstr "Dice que te está apuntando."

#: src-en/data/events_special_multiverse.xml:1930
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/choice/event/choice/event/text"
msgstr "\"Oh... mierda mierda mierda, la he cagado fuerte. No importa - te mataré primero y luego me ocuparé de esta basura defectuosa!\""

#: src-en/data/events_special_multiverse.xml:1932
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/choice/event/choice/event/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1936
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ASB\"]/choice/event/choice/event/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1950
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/text"
msgstr "\"¡Jajaja! ¡Ahora tus pensamientos son míos! ¡Contempla, zorra, a mi nuevo amigo!\" Leah extiende los brazos hacia un Slug regordete, que se ríe. \"No sssoy sssu amigo. Ssssolo me essstá pagando.\" Leah lo ignora y le pide que lea tu mente. \"Qué piensa mi archienemigo de mí? ¡Dímelo, nuevo amigo! ¡Usa tus PODERES MENTALES!\""

#: src-en/data/events_special_multiverse.xml:1953
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1955
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/choice/event/text"
msgstr "\"No veo ningún penssssamiento ssignificativo sobre ti. Ssssolo... vacío. Y un poco de molessstia.\" Leah parece sorprendida. \"Eh? ¡Debe estarlos ocultando profundamente! Dime, me TEME? ¡Debe hacerlo!\""

#: src-en/data/events_special_multiverse.xml:1957
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:1959
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/choice/event/choice/event/text"
msgstr "El Slug estalla en una risa descontrolada y cae al suelo en un ataque de histeria. \"¡JAJAJAJAJAJAJAJA! ¡JAJAJAJA! ¡JA! ¡JAAAAAA! ¡AJAJAJAJAJAJA! ¡AAAAJAJAAAAAA! Ah... eh... No.\" Leah empuja al Slug a un lado, molesta. \"¡Tus poderes mentales son inútiles! ¡No pueden penetrar en el subconsciente profundo de la mente! ¡Fuera contigo! ¡Déjame hacer lo mío y matar a esta zorra!\""

#: src-en/data/events_special_multiverse.xml:1961
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/choice/event/choice/event/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1965
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SLUG\"]/choice/event/choice/event/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1979
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPIDER\"]/text"
msgstr "\"¡Jajaja! ¡Sabía que te encontraría aquí! Creíste que podías huir de mí, tu archienemiga? ¡Pues te equivocaste! Y tengo una sorpresa especial para ti... ¡acabo de comprar un EJÉRCITO de arañas alienígenas que planeo soltar sobre tu tripulación para destruirte!\""

#: src-en/data/events_special_multiverse.xml:1982
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPIDER\"]/choice/text"
msgstr "De dónde sacaste las arañas?"

#: src-en/data/events_special_multiverse.xml:1984
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPIDER\"]/choice/event/text"
msgstr "\"Oh, este tipo del brood me las vendió. ¡Con descuento además! Algo raro que las cajas fueran tan pequeñas. Pero eso es irrelevante... prepárate para tu fin, zorra!\""

#: src-en/data/events_special_multiverse.xml:1987
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPIDER\"]/choice/event/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:1991
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPIDER\"]/choice/event/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:1999
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ESTATE\"]/text"
msgstr "\"¡Me preguntaba si te vería aquí, zorra! ¡Nada bien aparecer así en la casa de mi papito! ¡Si te metes con los Wentworth, te metes conmigo, zorra!\""

#: src-en/data/events_special_multiverse.xml:2002
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ESTATE\"]/choice/text"
msgstr "¡Vance es tu padre!?"

#: src-en/data/events_special_multiverse.xml:2004
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ESTATE\"]/choice/event/text"
msgstr "\"Eh... bueno, no... solo le digo papito. Porque ehhhh, sí. Somos como familia. Bueno, lo seríamos. Probablemente. Nunca lo he conocido en realidad, jaja... Pero tipo, seguro nos llevaríamos bien. Tenemos como la misma personalidad y todo. Además, su sobrino y yo somos como, mejores amigos. Sí. No investigues eso. Ah, y cállate zorra. ¡Ahora déjame matarte!\""

#: src-en/data/events_special_multiverse.xml:2006
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ESTATE\"]/choice/event/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:2010
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ESTATE\"]/choice/event/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:2024
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_CREW\"]/text"
msgstr "Notas una nave familiar cerca... intentas recordar de dónde, cuando de repente aparece Leah en la pantalla, con su vibrante cabello azul. \"Oh mierda, tienes a mi mejor amigo a bordo! Jerry! Por qué andas con este perdedor en vez de conmigo?\""

#: src-en/data/events_special_multiverse.xml:2027
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_CREW\"]/choice/text"
msgstr "Eemmm."

#: src-en/data/events_special_multiverse.xml:2029
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_CREW\"]/choice/event/text"
msgstr "Jerry parece nervioso. \"Oh, ¡sííí! Eh... uhm... L... Le... Leah? ¡Qué bueno verte! Je...\" Leah inclina la cabeza, confundida como un cachorro perdido. \"Estás bromeando, claro, ¡jajaja! ¡Nunca me olvidarías, Jerry! Está bien, zorra, te daré un pase esta vez...\""

#: src-en/data/events_special_multiverse.xml:2036
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_NOCREW\"]/text"
msgstr "Notas una nave familiar cerca... intentas recordar de dónde, cuando de repente aparece Leah en la pantalla, con su vibrante cabello azul. \"Oh mierda, pensé que podría verte aquí, zorra! Es repugnante que vengas aquí a matar a mi amigo!\""

#: src-en/data/events_special_multiverse.xml:2039
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_NOCREW\"]/choice/text"
msgstr "Tu... qué?"

#: src-en/data/events_special_multiverse.xml:2041
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_NOCREW\"]/choice/event/text"
msgstr "\"Ja, no te hagas el tonto. ¡Jerry, el sobrino del Almirante Vance! ¡Es como mi hermano! Bueno, no realmente, mi hermano real es un idiota. Pero Jerry, sabes? Tenemos historia. Como, mejores amigos. ¡Mejores amigos para siempre! Jaja... sí. Solo no le preguntes sobre eso. Es verdad. Lo prometo. En fin, nada bien, zorra. Por suerte para Jerry, yo, su definitivamente mejor amiga, estaba aquí para detenerte.\""

#: src-en/data/events_special_multiverse.xml:2043
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_NOCREW\"]/choice/event/choice[1]/text"
msgstr "Aquí vamos de nuevo."

#: src-en/data/events_special_multiverse.xml:2047
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"NEMESIS_JERRY_NOCREW\"]/choice/event/choice[@req=\"BLUELIST_WEAPONS_BEAM_POWERFUL\"]/text"
msgstr "(Rayo Poderoso) Enseñarle el Rayo a Leah."

#: src-en/data/events_special_multiverse.xml:2059
msgid "data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/text"
msgstr "\"¡Nos volvemos a encontrar, mi archienemigo! ¡Mwahaha! ¡Soy yo, Leah la Destructora, la Heraldo del Caos, la Condenadora de los Indignos! La potencia de los Rebeldes, el centro de su fuerza.\""

#: src-en/data/events_special_multiverse.xml:2062
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/text"
msgstr "Claro..."

#: src-en/data/events_special_multiverse.xml:2064
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/text"
msgstr "\"Hay una razón por la cual Vance me ha enviado aquí. Y sí, fue su petición personal que yo fuera quien te derrotara. No indagues más en eso. No es que pudieras, porque no estarás vivo por mucho más tiempo. Durante demasiado tiempo los Rebeldes han sido frenados por sabandijas como tú. ¡No más!\""

#: src-en/data/events_special_multiverse.xml:2066
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/choice/text"
msgstr "Ajá."

#: src-en/data/events_special_multiverse.xml:2068
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/choice/event/text"
msgstr "\"Hoy es el día en que mueres. Hoy, yo, Leah, finalmente te daré una lección. Tomaré el trono. Muahahahahah. MUAHAHAHAHA- espera, mierda. No quise presionar eso!\""

#: src-en/data/events_special_multiverse.xml:2070
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/choice/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:2072
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/choice/event/choice/event/text"
msgstr "De repente, los motores de Leah se encienden y su motor FTL se activa. \"¡Nononono, esto no puede estar pasando! ¡Maldita sea! ¡La próxima vez te atraparé, zoooooorraaaaaaaaaaaa!\""

#: src-en/data/events_special_multiverse.xml:2075
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/choice/event/choice/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_multiverse.xml:2079
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_SPEECH\"]/choice/event/choice/event/choice/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_special_multiverse.xml:2095
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"NEMESIS_ENCOUNTER_CHAOS\"]/text"
msgstr "\"¡Mi archienemigo! ¡Nos volvemos a encontrar!\"."

#: src-en/data/events_special_multiverse.xml:2098
