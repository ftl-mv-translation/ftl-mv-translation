#: src-en/data/events_special_multiverse.xml:14
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"DOOR_OPEN_SONG_NEW\"]/choice/event/text"
msgstr "“¡Esta es la Canción de Puerta Abierta! La cultura lizard incluye muchos bailes y cánticos. Así como tú golpeas la puerta para entrar, nosotros bailamos la Canción de Puerta Abierta. Es una canción tanto para pedir entrada con respeto, como para agradecer que nos la concedan. Muy sagrada, muy importante.”"

#: src-en/data/events_special_multiverse.xml:17
