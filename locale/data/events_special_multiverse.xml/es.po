#: src-en/data/events_special_multiverse.xml:2653
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"SYLVAN_ATTACKED\"]/text"
msgstr "\"Ahhh, desssconocido. Qué bueno verte de nuevo. Te fuissste tan rápido la última vez que nos vimos. Jej, y pensar que creí que no erasss un cobarde. Ssupongo que es hora de que terminemos esssto.\""

