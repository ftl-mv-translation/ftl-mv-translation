#: src-en/data/events_special_multiverse.xml:128
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DOOR_OPEN_SONG_METYUNT\"]/text"
msgstr "Sin embargo, en lugar de subir inmediatamente a tu nave, Metyunt mueve su brazo de forma torpe y murmura algunas palabras incoherentes. Lo miras fijamente y él te devuelve la mirada en silencio."

#: src-en/data/events_special_multiverse.xml:130
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DOOR_OPEN_SONG_METYUNT\"]/choice/text"
msgstr "Que fue eso?"

#: src-en/data/events_special_multiverse.xml:132
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DOOR_OPEN_SONG_METYUNT\"]/choice/event/text"
msgstr "\"Oh... eh... la Canción de Abrir Puerta. Creo. Es... eh... cosa de lizards. Una solicitud de entrada o algo así. Solo di que sí y terminemos con esto.\""

#: src-en/data/events_special_multiverse.xml:135
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DOOR_OPEN_SONG_METYUNT\"]/choice/event/choice[1]/text"
msgstr "Permitir subir a bordo."

#: src-en/data/events_special_multiverse.xml:137
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"DOOR_OPEN_SONG_METYUNT\"]/choice/event/choice[1]/event/text"
msgstr "\"Sí, sí. Perdón por eso. Solo es una tradición tonta. Ya sabes cómo son esas cosas. O tal vez no, recién nos conocemos.\""

#: src-en/data/events_special_multiverse.xml:139
