#: src-en/data/events_special_multiverse.xml:1145
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"temporal\"]/event/text"
msgstr "\"[ERROR]... Cómo o-o-obtuviste este sistema? Pensé... que no podía ser... oh cielos. ¡Corby no sabe qué pensar! Nos dijeron que si... olvídalo. ¡Corby nunca r-r-rompería el credo! Pero... bueno... no digas nada de esto, viajero. Te daré la Concesión del Tiempo. ¡Concesión del Tiempo! Guárdala - para el futuro, y mantén esto en secreto entre nosotros!\""

#: src-en/data/events_special_multiverse.xml:1149
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"temporal\"]/event/choice/text"
