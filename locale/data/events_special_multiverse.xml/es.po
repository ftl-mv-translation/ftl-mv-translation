#: src-en/data/events_special_multiverse.xml:1155
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"drones\"]/text"
msgstr "Presenta tu sistema de Control de Drones."

#: src-en/data/events_special_multiverse.xml:1157
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"drones\"]/event/text"
msgstr "\"¡Drones! -¡Drones!- ¡Drones! Corby aprueba. ¡Aprueba! Un sistema m-m-muy versátil, ya que sirve para: ofensiva - defensa - incluso puede suplir a la tripulación. B-b-b-buen sistema. Lo recomiendo. Por esto te otorgo: Concesión de Drones! Guárdala - para el futuro!\""

#: src-en/data/events_special_multiverse.xml:1161
msgid ""
"data/events_special_multiverse.xml$/FTL/event[@name=\"THE_JUDGES_ENGI_REAL\"]/choice[@req=\"drones\"]/event/choice/text"
