"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Nadie sobrevive después de desafiar a Tremor! Le mostraré a Sylvan lo que hago con enviar mercenario tras cosas de Tremor!\""

#: src-en/data/events_special_multiverse.xml:3012
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[1]/event/choice/text"
msgstr "Continuar..."

#: src-en/data/events_special_multiverse.xml:3018
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[2]/text"
msgstr "Sí, preferiría no pelear contigo."

#: src-en/data/events_special_multiverse.xml:3020
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[2]/event/text"
msgstr "\"Buena elección, pequeño hombre. La próxima vez, dile a Sylvan que se mantenga alejado de las cosas de Tremor!\""

#: src-en/data/events_special_multiverse.xml:3022
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_multiverse.xml:3026
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[1]/event/choice[2]/event/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_special_multiverse.xml:3034
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[2]/text"
msgstr "No podemos ser los únicos buscando esto. Irnos."

#: src-en/data/events_special_multiverse.xml:3036
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[2]/event/text"
msgstr "Puede que nunca veas esa tecnología que Sylvan prometió, pero es mejor que estar muerto."

#: src-en/data/events_special_multiverse.xml:3038
msgid ""
"data/events_special_multiverse.xml$//event[@name=\"SYLVAN_PREIGNITER\"]/choice[2]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_multiverse.xml:3042
