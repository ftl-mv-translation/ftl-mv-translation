#: src-en/data/events_special_ruins.xml:177
msgid ""
"data/events_special_ruins.xml$//event[@name=\"RUINS_REBEL_AUTO\"]/beaconType/visitedTooltip"
msgstr "Ubicación explorada. Nada más de interés."

