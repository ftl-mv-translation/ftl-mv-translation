"data/events_special_ruins.xml$//event[@name=\"RUINS_SALVAGE\"]/choice[@req=\"unique_anointed\"]/event/text"
msgstr "\"Intentaré lo mejor posible. Las palabras de los antepasados están oxidadas en mi mente, pero estoy captando la idea general. Aléjate.\""

#: src-en/data/events_special_ruins.xml:101
msgid ""
