msgid ""
"data/events_special_socialize.xml$/FTL/event[@name=\"SOCIALIZE_ANURAK_GENERIC_2\"]/text"
msgstr "\"Ah, hola Shellskenbry! ¡Qué maravilloso día estamos teniendo!\" Anurak te saluda."

#: src-en/data/events_special_socialize.xml:916
msgid ""
"data/events_special_socialize.xml$/FTL/event[@name=\"SOCIALIZE_ANURAK_GENERIC_2\"]/choice[1]/text"
msgstr "Gracias."

#: src-en/data/events_special_socialize.xml:930
