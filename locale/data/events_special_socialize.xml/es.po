"data/events_special_socialize.xml$/FTL/event[@name=\"SOCIALIZE_BILLY_GENERIC_4\"]/choice/event/choice[1]/event/choice[1]/event/choice[1]/event/choice[1]/event/choice[3]/text"
msgstr "No gracias."

#: src-en/data/events_special_socialize.xml:3188
msgid ""
"data/events_special_socialize.xml$/FTL/event[@name=\"SOCIALIZE_BILLY_GENERIC_4\"]/choice/event/choice[1]/event/choice[1]/event/choice[1]/event/choice[2]/text"
msgstr "Comprar el lapicero."

