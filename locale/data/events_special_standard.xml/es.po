#: src-en/data/events_special_standard.xml:12394
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/text"
msgstr "Una nave de Harmony ya se ha acoplado en la tienda aquí, aunque por lo que puedes escuchar en el comunicador, no parecen muy contentos."

#: src-en/data/events_special_standard.xml:12397
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/text"
