#: src-en/data/events_special_standard.xml:12356
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_SHIELD_CURIOSITY\"]/text"
msgstr "La nave en esta baliza está transmitiendo una señal de tienda. \"Querer comerciar. Tener cosas. Interesado en algo específico. Haber visto escudo verde en restos. No poder recuperar. Tú saber sobre eso?\""

#: src-en/data/events_special_standard.xml:12359
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_SHIELD_CURIOSITY\"]/choice[@req=\"LIST_CHECK_ENERGY_SHIELD\"]/text"
msgstr "(Escudo de Energía) Permitir que examinen tu escudo."

#: src-en/data/events_special_standard.xml:12361
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_SHIELD_CURIOSITY\"]/choice[@req=\"LIST_CHECK_ENERGY_SHIELD\"]/event/text"
msgstr "\"Mucho interés. Quizás copiar, haber visto uno roto. Expresando agradecimiento.\""

#: src-en/data/events_special_standard.xml:12367
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_SHIELD_CURIOSITY\"]/choice[2]/text"
