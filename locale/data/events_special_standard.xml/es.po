#: src-en/data/events_special_standard.xml:12437
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[@req=\"technoengi\"]/event/text"
msgstr "Llevas a tu Morph a la pantalla e intentas explicar la situación al Aumentado. \"Entonces... dices que el criminal era el clon malvado de este? ¡Claro, tiene perfecto sentido! ¡Muchas gracias, nuevo amigo!\" Intentas corregirlo, pero decides no hacerlo cuando ves un trozo de chatarra salir disparado por la esclusa de la tienda!"

#: src-en/data/events_special_standard.xml:12440
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[@req=\"technoengi\"]/event/choice/text"
msgstr "Continuar..."

