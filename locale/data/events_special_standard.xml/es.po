#: src-en/data/events_special_standard.xml:11752
msgid ""
"data/events_special_standard.xml$//eventList[@name=\"STOREEVENT_SECTOR_DUSK_SEARCH_LEAVE\"]/event[2]/choice[2]/event/text"
msgstr "Con una acción tan apresurada y mal planificada, no sorprende que no llegues lejos antes de ser detectado. ¡Prepárate para luchar por tu vida!"

#: src-en/data/events_special_standard.xml:11755
