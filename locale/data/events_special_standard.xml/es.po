#: src-en/data/events_special_standard.xml:12426
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[@req=\"engi\"]/event/text"
msgstr "Cuando tu Engi aparece en pantalla, las luces del Aumentado se atenúan hasta casi desaparecer, como si intentara camuflarse. \"Tú... mismo Engi en nave diferente? No, no... equivocado? Por favor, tomar chatarra mientras hago disculpas. Ambos bienvenidos.\""

#: src-en/data/events_special_standard.xml:12429
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[@req=\"engi\"]/event/choice/text"
msgstr "Continuar..."

