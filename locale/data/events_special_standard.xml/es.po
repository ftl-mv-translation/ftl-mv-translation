#: src-en/data/events_special_standard.xml:10824
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_NODE17_PATRIOTIC_STORE\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-2\"]/event/text"
msgstr "La tienda responde a tu saludo. \"¡Por favor, entra! Hemos oído de tus hazañas heroicas, y estamos aquí para mostrar nuestro apoyo. ¡Te damos un 30% de descuento! Cuando veas al Almirante Vance, ¡asegúrate de enviarle un misil de mi parte!\""

#: src-en/data/events_special_standard.xml:10826
