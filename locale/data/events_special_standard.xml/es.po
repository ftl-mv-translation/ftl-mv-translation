msgstr "(¡BOTÓN DE PÁNICO!) Haz algo épico."

#: src-en/data/events_special_standard.xml:5922
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_LOSTSUN_VOLCANO\"]/choice[1]/event/choice[2]/event/choice[@req=\"COMBAT_PANIC_BUTTON\"]/event/text"
msgstr "Aterrizas tu nave en la superficie del planeta y configuras el botón para que envíe su señal después de que te hayas alejado lo suficiente de tu propia nave. Sin embargo, mientras tu lanzadera asciende y tu punto de aterrizaje se convierte brevemente en el segundo sol del sistema, no puedes evitar sentir que necesitabas esa nave para algo..."

#: src-en/data/events_special_standard.xml:5923
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_LOSTSUN_VOLCANO\"]/choice[1]/event/choice[2]/event/choice[@req=\"COMBAT_PANIC_BUTTON\"]/event/lose/@text"
msgstr "Parece que ahora eres un residente permanente de la estación de los Lost Suns... pero al menos disfrutaron de tu espectáculo."

#: src-en/data/events_special_standard.xml:5927
