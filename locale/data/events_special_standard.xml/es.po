"data/events_special_standard.xml$//event[@name=\"STOREEVENT_NODE17_PATRIOTIC_STORE\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"4\"]/event/text"
msgstr "En lugar de comerciar contigo, preparan sus armas. \"¡Aléjate, traidor! Si caemos al nivel de lo que tú haces, en qué nos diferenciamos de los Rebeldes?\""

#: src-en/data/events_special_standard.xml:10879
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_NODE17_PATRIOTIC_STORE\"]/choice[@req=\"rep_comb_federation\""
