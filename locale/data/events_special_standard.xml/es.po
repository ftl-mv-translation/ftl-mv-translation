msgstr "Permanecer en silencio y ver qué sucede."

#: src-en/data/events_special_standard.xml:11750
msgid ""
"data/events_special_standard.xml$//eventList[@name=\"STOREEVENT_SECTOR_DUSK_SEARCH_LEAVE\"]/event[2]/choice[2]/text"
