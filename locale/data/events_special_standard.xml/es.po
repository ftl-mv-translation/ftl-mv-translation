msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[2]/text"
msgstr "Ignorar la conversación e ir de compras."

#: src-en/data/events_special_standard.xml:12495
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[2]/event/text"
msgstr "Te acercas para acoplarte con la tienda, y la nave Harmony se aparta en silencio."

#: src-en/data/events_special_standard.xml:12497
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[2]/event/choice/text"
