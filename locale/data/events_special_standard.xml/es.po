#: src-en/data/events_special_standard.xml:5956
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_LOSTSUN_VOLCANO\"]/choice[3]/event/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_standard.xml:5960
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_LOSTSUN_VOLCANO\"]/choice[3]/event/choice[2]/text"
