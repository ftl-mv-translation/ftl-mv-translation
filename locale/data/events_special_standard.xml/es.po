#: src-en/data/events_special_standard.xml:5912
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_LOSTSUN_VOLCANO\"]/choice[1]/event/choice[2]/event/choice[@req=\"COMBAT_HAZARD\"]/event/text"
msgstr "Usas tu Manipulador de la Realidad sobre el planeta. El dispositivo transforma instantáneamente todo el planeta en un infierno ardiente, con volcanes inundando toda la superficie con una lluvia de lava. Los Rockmen observan la transformación con asombro."

#: src-en/data/events_special_standard.xml:5914
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_LOSTSUN_VOLCANO\"]/choice[1]/event/choice[2]/event/choice[@req=\"COMBAT_HAZARD\"]/event/choice/text"
