"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[3]/event/text"
msgstr "Hay una forma sencilla de resolver esta disputa. Cortas las comunicaciones y atacas la nave Engi."

#: src-en/data/events_special_standard.xml:12418
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[3]/event/choice/text"
