"data/events_special_standard.xml$//event[@name=\"TONY_BALLPIT\"]/choice[1]/event/choice[1]/event/text"
msgstr "\"Eeehh... estásss... hablando en sssserio? Porque, bueno, nueessstrasss patrullasss de bússsqueda aún no han regresssado y han essstado fuera durante horasss."

#: src-en/data/events_special_standard.xml:9925
msgid ""
"data/events_special_standard.xml$//event[@name=\"TONY_BALLPIT\"]/choice[1]/event/choice[2]/text"
