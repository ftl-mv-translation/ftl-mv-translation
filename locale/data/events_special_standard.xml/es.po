" and @lvl=\"2\"]/event/choice[1]/event/text"
msgstr "La estación responde de inmediato activando sus propias armas. ¡Estaban preparados para esto!"

#: src-en/data/events_special_standard.xml:10851
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_NODE17_PATRIOTIC_STORE\"]/choice[@req=\"rep_comb_federation\""
