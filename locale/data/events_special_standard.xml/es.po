"data/events_special_standard.xml$//event[@name=\"STOREEVENT_UNION_WAR_ORPHANS\"]/choice[2]/event/choice[2]/event/text"
msgstr "\"¡Te insto a reconsiderarlo! Piensa por un momento cómo es ser huérfano. Piensa en la gran diferencia que podría hacer una pequeña donación.\""

