msgstr ""

#: src-en/data/events_special_standard.xml:13057
msgid ""
"data/events_special_standard.xml$//event[@name=\"EMPTY_MANTIS\"]/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_standard.xml:13061
msgid ""
"data/events_special_standard.xml$//event[@name=\"EMPTY_MANTIS\"]/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_special_standard.xml:13066
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_MANTIS\"]/text[1]"
msgstr "A estas alturas, ya te esperas un combate con las mantis, pero, en esta baliza, no parece haber ninguna otra nave. Te tomas tu tiempo para recuperar el aliento y revisar los sistemas."

#: src-en/data/events_special_standard.xml:13067
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_MANTIS\"]/text[2]"
msgstr "Lo único que tiene que ofrecer esta baliza son unas buenas vistas del espacio profundo y un breve descanso después de tanto combate. Para algunos, debe de ser un cálido refugio."

#: src-en/data/events_special_standard.xml:13068
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_MANTIS\"]/text[3]"
msgstr "Una explotación minera mantis cercana está empleando esclavos inges para trabajos pesados. Valoras la posibilidad de liberar a los esclavos, pero hay muchísimas mantis y prefieres mantener un perfil discreto."

#: src-en/data/events_special_standard.xml:13069
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_MANTIS\"]/text[4]"
msgstr "Pocas zonas del espacio mantis no están salpicadas de restos de antiguas batallas, pero esta es una de ellas. Respiras hondo y te preparas para seguir adelante."

#: src-en/data/events_special_standard.xml:13070
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_MANTIS\"]/text[5]"
msgstr "Aquí solo hay restos espaciales y unos cuantos planetoides inhabitables."

#: src-en/data/events_special_standard.xml:13071
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_MANTIS\"]/text[6]"
msgstr "Te parece ver que algo se mueve entre las sombras de la baliza, pero todo está en calma."

#: src-en/data/events_special_standard.xml:13077
msgid ""
"data/events_special_standard.xml$//event[@name=\"EMPTY_FREEMANTIS\"]/choice[1]/text"
msgstr "Hacer algo abordo de la nave."

#: src-en/data/events_special_standard.xml:13081
msgid ""
"data/events_special_standard.xml$//event[@name=\"EMPTY_FREEMANTIS\"]/choice[2]/text"
msgstr "No hacer nada."

#: src-en/data/events_special_standard.xml:13086
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_FREEMANTIS\"]/text[1]"
msgstr ""

#: src-en/data/events_special_standard.xml:13087
msgid ""
"data/events_special_standard.xml$//textList[@name=\"EMPTY_FREEMANTIS\"]/text[2]"
msgstr ""

