"data/events_special_standard.xml$//event[@name=\"STOREEVENT_NODE17_PATRIOTIC_STORE\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/event/text"
msgstr "La tienda responde de inmediato a tu saludo. \"¡Eres el héroe del que todos hablan! ¡Por favor, entra, bienvenido! ¡Acepta este regalo, además de un 30% de descuento!\""

#: src-en/data/events_special_standard.xml:10816
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_NODE17_PATRIOTIC_STORE\"]/choice[@req=\"rep_comb_federation\""
" and @lvl=\"-999\"]/event/choice/text"
