#: src-en/data/events_special_standard.xml:2782
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_ARCHIVE_REC_CENTER\"]/text"
msgstr "La tienda está ubicada en una región exuberante de un mundo terraformado cercano. Un cartel dice: \"¡Archive Inc. ofrece las experiencias recreativas antediluvianas más auténticas de la galaxia!\" Podrías probar algunas de las actividades del planeta."

#: src-en/data/events_special_standard.xml:2784
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_ARCHIVE_REC_CENTER\"]/choice[@req=\"COUNT_ALL_CREW\"]/text"
