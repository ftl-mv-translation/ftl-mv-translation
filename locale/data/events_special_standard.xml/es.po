#: src-en/data/events_special_standard.xml:12399
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/text"
msgstr ""
"\"Saludos, cliente. Disculpas, tratando con criminal; este solicitó ayuda antes del gran éxodo, ¡aún no ha pagado!\"\n"
"\n"
"\"Error: identidad equivocada. Unidades Harmony = idénticas, su enojo = mal dirigido. Sugerencia: nave Harmony anterior destruida antes del pago.\"\n"
"\n"
"\"¡He escuchado excusa de gemelo muerto muchas veces, nunca ser verdad! Ahora silencio. Cliente real está aquí, creerá?\""

#: src-en/data/events_special_standard.xml:12405
msgid ""
"data/events_special_standard.xml$//event[@name=\"STOREEVENT_AUGMENTED_GRUDGE\"]/choice[1]/event/choice[1]/text"
msgstr "Ponerse del lado del dueño de la tienda."

